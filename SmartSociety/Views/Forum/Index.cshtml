@model IEnumerable<SmartSociety.Models.ForumTopic>
@{
    ViewData["Title"] = "Discussion Forum - SmartSociety";
    var category = ViewBag.SelectedCategory as string;
    var currentUserId = ViewBag.CurrentUserId as int?;
    var isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Community</li>
    <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">Discussion Forum</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-1"><i class="fa-solid fa-comments text-info me-2"></i> Discussion Forum</h2>
        <p class="text-muted mb-0">Discuss issues, organize events, and share ideas with your society co-residents.</p>
    </div>
    <button type="button" class="btn btn-info text-white px-4 py-2.5 fw-semibold rounded-pill shadow-sm" onclick="openCreateTopicModal()">
        <i class="fa-solid fa-pen-nib me-2"></i> Start New Thread
    </button>
</div>

<!-- Categories Filter Nav -->
<div class="d-flex gap-2 mb-4 overflow-auto pb-2 flex-nowrap" style="scrollbar-width: none;">
    <a asp-action="Index" class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm transition-all @(string.IsNullOrEmpty(category) ? "btn-info text-white" : "btn-white border text-dark")">
        All Discussions
    </a>
    <a asp-action="Index" asp-route-category="General" class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm transition-all @(category == "General" ? "btn-info text-white" : "btn-white border text-dark")">
        <i class="fa-solid fa-hashtag me-1 text-primary"></i> General
    </a>
    <a asp-action="Index" asp-route-category="Events" class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm transition-all @(category == "Events" ? "btn-info text-white" : "btn-white border text-dark")">
        <i class="fa-regular fa-calendar-days me-1 text-success"></i> Events
    </a>
    <a asp-action="Index" asp-route-category="Issues" class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm transition-all @(category == "Issues" ? "btn-info text-white" : "btn-white border text-dark")">
        <i class="fa-solid fa-triangle-exclamation me-1 text-danger"></i> Issues / Complaints
    </a>
    <a asp-action="Index" asp-route-category="Suggestions" class="btn rounded-pill px-4 py-2 fw-semibold shadow-sm transition-all @(category == "Suggestions" ? "btn-info text-white" : "btn-white border text-dark")">
        <i class="fa-regular fa-lightbulb me-1 text-warning"></i> Suggestions
    </a>
</div>

<!-- Forum Feed -->
<div class="row">
    <div class="col-lg-9 col-md-12 mx-auto">
        @if (Model == null || !Model.Any())
        {
            <div class="bg-white rounded-4 shadow-sm p-5 text-center border">
                <i class="fa-regular fa-message fa-4x text-muted mb-3 opacity-50"></i>
                <h5 class="fw-bold text-secondary">No Discussions Yet</h5>
                <p class="text-muted small mb-3">Be the first one to start a thread about society events or issues!</p>
                <button class="btn btn-info text-white rounded-pill px-4" onclick="openCreateTopicModal()"><i class="fa-solid fa-pen-nib me-1"></i> Start Thread</button>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var topic in Model)
                {
                    <div class="card border-0 rounded-4 shadow-sm p-3 bg-white position-relative hover-lift">
                        <div class="card-body p-2 d-flex flex-column">
                            <!-- Top metadata -->
                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-1">
                                <div class="d-flex align-items-center gap-2">
                                    <!-- Category Badge -->
                                    <span class="badge rounded-pill px-2.5 py-1 text-xs fw-semibold @(
                                        topic.Category == "Issues" ? "bg-danger bg-opacity-10 text-danger border border-danger-subtle" :
                                        topic.Category == "Events" ? "bg-success bg-opacity-10 text-success border border-success-subtle" :
                                        topic.Category == "Suggestions" ? "bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle" :
                                        "bg-primary bg-opacity-10 text-primary border border-primary-subtle"
                                    )">
                                        @topic.Category
                                    </span>
                                    @if (topic.IsPinned)
                                    {
                                        <span class="badge rounded-pill bg-secondary text-white px-2 py-1 text-xs"><i class="fa-solid fa-thumbtack fa-xs me-1"></i> Pinned</span>
                                    }
                                </div>
                                <small class="text-muted"><i class="fa-solid fa-clock fa-sm me-1"></i> @topic.CreatedAt.ToString("hh:mm tt, dd MMM yyyy")</small>
                            </div>
                            
                            <!-- Title & Navigation -->
                            <a asp-action="Topic" asp-route-id="@topic.TopicId" class="text-decoration-none text-dark hover-info">
                                <h5 class="fw-bold mb-2 pr-4">@topic.Title</h5>
                            </a>
                            
                            <!-- Content Snippet -->
                            <p class="text-muted small text-clamp-2 mb-3">@topic.Content</p>
                            
                            <!-- Footer row -->
                            <div class="border-top pt-2 mt-auto d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-muted fw-bold me-2" style="width: 28px; height: 28px; font-size: 0.75rem;">
                                        @topic.AuthorName?.Substring(0, Math.Min(2, topic.AuthorName.Length)).ToUpper()
                                    </div>
                                    <span class="text-dark fw-semibold small text-muted"><i class="fa-solid fa-user fa-xs me-1"></i> @topic.AuthorName (Flat @topic.AuthorFlat)</span>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <span class="badge bg-light text-secondary rounded-pill px-3 py-1.5 fw-semibold border"><i class="fa-regular fa-comment-dots text-info me-1.5"></i> @topic.ReplyCount Comments</span>
                                    <a asp-action="Topic" asp-route-id="@topic.TopicId" class="btn btn-sm btn-info text-white rounded-pill px-3 fw-semibold">View Thread</a>
                                    
                                    @if (currentUserId.HasValue && (currentUserId.Value == topic.UserId || isAdmin))
                                    {
                                        <button class="btn btn-sm btn-outline-danger rounded-circle p-2 d-flex align-items-center justify-content-center" 
                                                onclick="deleteThread(@topic.TopicId)" style="width: 32px; height: 32px;" title="Delete Thread">
                                            <i class="fa-solid fa-trash-can fa-sm"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Create Topic Modal -->
<div class="modal fade" id="createTopicModal" tabindex="-1" aria-labelledby="createTopicModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-info text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="createTopicModalLabel"><i class="fa-solid fa-pen-nib me-2"></i> Start a Discussion Thread</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="createTopicForm" onsubmit="event.preventDefault(); submitTopic();">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="TopicTitle" class="form-label fw-semibold small text-muted mb-1">Thread Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control bg-light border-0" id="TopicTitle" name="Title" required placeholder="e.g. Society Independence Day Celebration Planning" />
                    </div>
                    <div class="mb-3">
                        <label for="TopicCategory" class="form-label fw-semibold small text-muted mb-1">Category <span class="text-danger">*</span></label>
                        <select class="form-select bg-light border-0" id="TopicCategory" name="Category" required>
                            <option value="General">General / General chit-chat</option>
                            <option value="Events">Events / Celebrations</option>
                            <option value="Issues">Issues / Complaints</option>
                            <option value="Suggestions">Suggestions / Ideas</option>
                        </select>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" role="switch" id="TopicIsPinned" name="IsPinned" value="true">
                            <label class="form-check-label fw-semibold small text-muted" for="TopicIsPinned">Pin this thread at the top</label>
                        </div>
                    }
                    <div class="mb-3">
                        <label for="TopicContent" class="form-label fw-semibold small text-muted mb-1">Body Content <span class="text-danger">*</span></label>
                        <textarea class="form-control bg-light border-0" id="TopicContent" name="Content" required rows="5" placeholder="Provide full details or descriptions for residents to read and comment..."></textarea>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-info text-white px-5 rounded-pill shadow-sm fw-semibold" id="btnSubmitTopic">
                            <i class="fa-solid fa-check me-2"></i> Start Thread
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var createTopicModal;

        $(document).ready(function() {
            createTopicModal = new bootstrap.Modal(document.getElementById('createTopicModal'));
        });

        function openCreateTopicModal() {
            $('#createTopicForm')[0].reset();
            createTopicModal.show();
        }

        function submitTopic() {
            var form = $('#createTopicForm')[0];
            var formData = new FormData(form);

            // Explicitly set IsPinned since checkbox value behaves differently when unchecked
            var isPinnedChecked = $('#TopicIsPinned').is(':checked');
            formData.set('IsPinned', isPinnedChecked ? 'true' : 'false');

            $('#btnSubmitTopic').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Creating...');

            $.ajax({
                url: '/Forum/CreateTopic',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        createTopicModal.hide();
                        Swal.fire({
                            icon: 'success',
                            title: 'Thread Created!',
                            text: res.message,
                            showConfirmButton: false,
                            timer: 2000
                        }).then(() => {
                            window.location.href = '/Forum/Topic/' + res.topicId;
                        });
                    } else {
                        Swal.fire('Failed', res.message, 'error');
                        $('#btnSubmitTopic').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Start Thread');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitTopic').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Start Thread');
                }
            });
        }

        function deleteThread(topicId) {
            Swal.fire({
                title: 'Delete Discussion?',
                text: 'Are you sure you want to permanently delete this thread and all its comments? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete Thread'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Forum/DeleteTopic/' + topicId,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted!',
                                    text: res.message,
                                    showConfirmButton: false,
                                    timer: 1500
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Failed to delete discussion thread.', 'error');
                        }
                    });
                }
            });
        }
    </script>
    <style>
        .hover-lift {
            transition: all 0.2s ease-in-out;
            border: 1px solid rgba(0, 0, 0, 0.04) !important;
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.05) !important;
        }
        .text-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .hover-info:hover h5 {
            color: #0dcaf0 !important;
        }
        .btn-white {
            background-color: #ffffff;
        }
        .btn-white:hover {
            background-color: #f8f9fa;
        }
    </style>
}
