@model SmartSociety.Models.ForumTopic
@{
    ViewData["Title"] = Model.Title + " - SmartSociety Forum";
    var replies = ViewBag.Replies as IEnumerable<SmartSociety.Models.ForumReply>;
    var currentUserId = ViewBag.CurrentUserId as int?;
    var isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Community</li>
    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Discussion Forum</a></li>
    <li class="breadcrumb-item active fw-bold text-truncate" aria-current="page" style="max-width: 250px;">@Model.Title</li>
  </ol>
</nav>

<div class="mb-4">
    <a asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3"><i class="fa-solid fa-arrow-left me-1"></i> Back to Forum Feed</a>
</div>

<div class="row">
    <div class="col-lg-9 col-md-12 mx-auto">
        <!-- Original Post Card -->
        <div class="card border-0 rounded-4 shadow-sm p-4 bg-white mb-4">
            <div class="card-body p-1">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge rounded-pill px-3 py-1.5 text-xs fw-semibold @(
                        Model.Category == "Issues" ? "bg-danger bg-opacity-10 text-danger border border-danger-subtle" :
                        Model.Category == "Events" ? "bg-success bg-opacity-10 text-success border border-success-subtle" :
                        Model.Category == "Suggestions" ? "bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle" :
                        "bg-primary bg-opacity-10 text-primary border border-primary-subtle"
                    )">
                        @Model.Category
                    </span>
                    <small class="text-muted"><i class="fa-solid fa-clock fa-sm me-1"></i> @Model.CreatedAt.ToString("hh:mm tt, dd MMM yyyy")</small>
                </div>
                
                <h3 class="fw-bold text-dark mb-3">@Model.Title</h3>
                
                <p class="text-dark fs-6" style="white-space: pre-wrap; line-height: 1.6; word-break: break-word;">@Model.Content</p>
                
                <div class="border-top pt-3 mt-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" style="width: 42px; height: 42px; font-size: 1rem;">
                            @Model.AuthorName?.Substring(0, Math.Min(2, Model.AuthorName.Length)).ToUpper()
                        </div>
                        <div>
                            <span class="d-block fw-bold text-dark">@Model.AuthorName</span>
                            <small class="text-muted"><i class="fa-solid fa-house-user fa-xs me-1"></i> Flat @Model.AuthorFlat</small>
                        </div>
                    </div>
                    
                    @if (currentUserId.HasValue && (currentUserId.Value == Model.UserId || isAdmin))
                    {
                        <button class="btn btn-outline-danger rounded-pill px-3 fw-semibold btn-sm shadow-sm" onclick="deleteThread(@Model.TopicId)">
                            <i class="fa-solid fa-trash-can me-1"></i> Delete Thread
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Comments Header -->
        <h5 class="fw-bold text-dark mb-3"><i class="fa-regular fa-comments me-2 text-info"></i> Comments (@(replies?.Count() ?? 0))</h5>

        <!-- Post a Comment Box -->
        <div class="card border-0 rounded-4 shadow-sm p-4 bg-white mb-4">
            <div class="card-body p-0">
                <form id="commentForm" onsubmit="event.preventDefault(); submitComment();">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TopicId" value="@Model.TopicId" />
                    <div class="mb-3">
                        <label for="CommentContent" class="form-label fw-semibold small text-muted mb-1">Write a comment</label>
                        <textarea class="form-control bg-light border-0 rounded-3" id="CommentContent" name="Content" required rows="3" placeholder="Share your opinion, query, or suggestion..."></textarea>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-info text-white rounded-pill px-4 fw-semibold shadow-sm" id="btnSubmitComment">
                            <i class="fa-solid fa-paper-plane me-1"></i> Post Comment
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Comments List -->
        <div class="d-flex flex-column gap-3 mb-5" id="commentsList">
            @if (replies == null || !replies.Any())
            {
                <div class="bg-light rounded-4 p-4 text-center border border-dashed py-5" id="emptyCommentsPlaceholder">
                    <i class="fa-regular fa-comment-dots fa-2x text-muted opacity-50 mb-2"></i>
                    <p class="text-muted small mb-0">No comments posted yet. Be the first to start the discussion!</p>
                </div>
            }
            else
            {
                @foreach (var reply in replies)
                {
                    <div class="card border-0 rounded-4 shadow-sm p-3 bg-white comment-item" data-id="@reply.ReplyId">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center">
                                <div class="bg-light text-secondary rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 32px; height: 32px; font-size: 0.8rem; border: 1px solid rgba(0,0,0,0.05)">
                                    @reply.AuthorName?.Substring(0, Math.Min(2, reply.AuthorName.Length)).ToUpper()
                                </div>
                                <div>
                                    <span class="fw-bold text-dark small">@reply.AuthorName</span>
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-2 py-0.5 text-xs ms-1">Flat @reply.AuthorFlat</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <small class="text-muted text-xs">@reply.CreatedAt.ToString("hh:mm tt, dd MMM")</small>
                                @if (currentUserId.HasValue && (currentUserId.Value == reply.UserId || isAdmin))
                                {
                                    <button class="btn btn-link text-danger p-0 border-0 ms-1 hover-scale" onclick="deleteComment(@reply.ReplyId)" title="Delete Comment">
                                        <i class="fa-solid fa-trash-can fa-xs"></i>
                                    </button>
                                }
                            </div>
                        </div>
                        <p class="text-muted small mb-0 ms-4 ps-1" style="white-space: pre-wrap; word-break: break-word;">@reply.Content</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function submitComment() {
            var form = $('#commentForm')[0];
            var formData = new FormData(form);

            $('#btnSubmitComment').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Posting...');

            $.ajax({
                url: '/Forum/AddReply',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: res.message,
                            showConfirmButton: false,
                            timer: 2000
                        });
                        setTimeout(() => location.reload(), 1200);
                    } else {
                        Swal.fire('Failed', res.message, 'error');
                        $('#btnSubmitComment').prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-1"></i> Post Comment');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitComment').prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-1"></i> Post Comment');
                }
            });
        }

        function deleteThread(topicId) {
            Swal.fire({
                title: 'Delete Discussion?',
                text: 'Are you sure you want to permanently delete this thread and all its comments? This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete Thread'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Forum/DeleteTopic/' + topicId,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted!',
                                    text: res.message,
                                    showConfirmButton: false,
                                    timer: 1500
                                }).then(() => {
                                    window.location.href = '/Forum';
                                });
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Failed to delete discussion thread.', 'error');
                        }
                    });
                }
            });
        }

        function deleteComment(replyId) {
            Swal.fire({
                title: 'Delete Comment?',
                text: 'Are you sure you want to delete this comment?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Forum/DeleteReply/' + replyId,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    toast: true,
                                    position: 'top-end',
                                    icon: 'success',
                                    title: res.message,
                                    showConfirmButton: false,
                                    timer: 2000
                                });
                                // Animate delete and reload
                                $('.comment-item[data-id="' + replyId + '"]').fadeOut(400, function() {
                                    $(this).remove();
                                    location.reload();
                                });
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error', 'Failed to delete comment.', 'error');
                        }
                    });
                }
            });
        }
    </script>
    <style>
        .comment-item {
            border: 1px solid rgba(0, 0, 0, 0.03) !important;
        }
        .hover-scale {
            transition: all 0.2s ease-in-out;
        }
        .hover-scale:hover {
            transform: scale(1.15);
        }
    </style>
}
