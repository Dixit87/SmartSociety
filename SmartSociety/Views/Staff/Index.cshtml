@model IEnumerable<SmartSociety.Models.Staff>

@{
    ViewData["Title"] = "Staff & Guard Control";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Admin</li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Staff & Guard Control</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-user-shield text-primary me-2"></i> Staff, Vendor & Guard Control</h2>
        <p class="text-muted mb-0">Manage security guards, regular vendors, and internal staff details.</p>
    </div>
    <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-semibold" onclick="openStaffModal()">
        <i class="fa-solid fa-plus me-2"></i> Register New Staff
    </button>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <table class="table table-hover align-middle w-100" id="staffTable">
            <thead class="table-light">
                <tr>
                    <th class="fw-semibold text-muted py-3">Profile</th>
                    <th class="fw-semibold text-muted py-3">Details</th>
                    <th class="fw-semibold text-muted py-3">Role</th>
                    <th class="fw-semibold text-muted py-3">Shift Timings</th>
                    <th class="fw-semibold text-muted py-3">Verification</th>
                    <th class="fw-semibold text-muted py-3">Status</th>
                    <th class="fw-semibold text-muted py-3 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var s in Model)
                    {
                        <tr>
                            <td class="py-3">
                                @if (!string.IsNullOrEmpty(s.PhotoPath))
                                {
                                    <img src="@s.PhotoPath" class="rounded-circle object-fit-cover shadow-sm border border-2 border-white" width="50" height="50" alt="@s.FullName" />
                                }
                                else
                                {
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-user fs-4"></i>
                                    </div>
                                }
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-dark mb-1">@s.FullName</div>
                                <div class="small text-muted"><i class="fa-solid fa-phone me-1"></i> @s.ContactNumber</div>
                                @if (!string.IsNullOrEmpty(s.AadharNumber))
                                {
                                    <div class="small text-muted mt-1"><i class="fa-regular fa-id-card me-1"></i> Aadhar: @s.AadharNumber</div>
                                }
                            </td>
                            <td class="py-3">
                                <span class="badge bg-info-subtle text-info-emphasis px-3 py-2 rounded-pill">
                                    @if(s.Role == "Security Guard") { <i class="fa-solid fa-shield-halved me-1"></i> }
                                    else if(s.Role == "Maid") { <i class="fa-solid fa-broom me-1"></i> }
                                    else if(s.Role == "Plumber") { <i class="fa-solid fa-wrench me-1"></i> }
                                    else if(s.Role == "Electrician") { <i class="fa-solid fa-bolt me-1"></i> }
                                    else { <i class="fa-solid fa-user-tag me-1"></i> }
                                    @s.Role
                                </span>
                            </td>
                            <td class="py-3">
                                <div class="bg-light px-3 py-2 rounded-3 d-inline-block small fw-semibold text-dark border">
                                    <i class="fa-regular fa-clock text-primary me-2"></i> @DateTime.Today.Add(s.ShiftStart).ToString("hh:mm tt") - @DateTime.Today.Add(s.ShiftEnd).ToString("hh:mm tt")
                                </div>
                            </td>
                            <td class="py-3">
                                @if (s.IsVerified)
                                {
                                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-shield-check me-1"></i> Verified</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-triangle-exclamation me-1"></i> Pending</span>
                                }
                            </td>
                            <td class="py-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input cursor-pointer" type="checkbox" role="switch" onchange="toggleStatus(@s.StaffId)" @(s.IsActive ? "checked" : "")>
                                </div>
                            </td>
                            <td class="py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-sm btn-light text-success border-0 shadow-sm" title="Mark Check-In" onclick="markAttendance(@s.StaffId, 'IN')">
                                        <i class="fa-solid fa-arrow-right-to-bracket"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-light text-danger border-0 shadow-sm" title="Mark Check-Out" onclick="markAttendance(@s.StaffId, 'OUT')">
                                        <i class="fa-solid fa-arrow-right-from-bracket"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-light text-info border-0 shadow-sm" title="Print ID Card" onclick="showIdCard(@s.StaffId, '@Uri.EscapeDataString(s.FullName)', '@Uri.EscapeDataString(s.Role)', '@(s.PhotoPath ?? "https://via.placeholder.com/150")')">
                                        <i class="fa-solid fa-id-badge"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-light text-primary border-0 shadow-sm" title="Edit Staff" onclick="openEditStaffModal(@s.StaffId, '@Uri.EscapeDataString(s.FullName)', '@Uri.EscapeDataString(s.Role)', '@Uri.EscapeDataString(s.ContactNumber)', '@Uri.EscapeDataString(s.AadharNumber ?? "")', '@s.ShiftStart.ToString(@"hh\:mm")', '@s.ShiftEnd.ToString(@"hh\:mm")', @s.IsVerified.ToString().ToLower(), @s.IsActive.ToString().ToLower(), '@(s.PhotoPath ?? "")', [@string.Join(",", s.AssignedFlatIds)])">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Staff Modal -->
<div class="modal fade" id="staffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-light rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="staffModalTitle"><i class="fa-solid fa-user-plus me-2"></i> Register New Staff</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="staffForm" onsubmit="event.preventDefault(); submitStaff();" enctype="multipart/form-data">
                    <input type="hidden" id="stId" name="staffId" value="0" />
                    
                    <div class="row g-4">
                        <!-- Left Column: Photo Upload -->
                        <div class="col-md-4 text-center border-end">
                            <div class="mb-3 position-relative d-inline-block">
                                <img id="photoPreview" src="https://via.placeholder.com/150" class="rounded-circle object-fit-cover border shadow-sm" width="150" height="150" alt="Preview" />
                                <label for="stPhoto" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 cursor-pointer shadow" style="cursor: pointer;">
                                    <i class="fa-solid fa-camera"></i>
                                </label>
                                <input type="file" id="stPhoto" name="photoFile" class="d-none" accept="image/*" onchange="previewImage(this)" />
                            </div>
                            <p class="small text-muted mb-0">Upload passport size photo</p>
                        </div>
                        
                        <!-- Right Column: Details -->
                        <div class="col-md-8">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Full Name <span class="text-danger">*</span></label>
                                    <input type="text" id="stName" name="fullName" class="form-control bg-light border-0 py-2" required maxlength="150" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Role / Category <span class="text-danger">*</span></label>
                                    <select id="stRole" name="role" class="form-select bg-light border-0 py-2" required>
                                        <option value="">-- Select Role --</option>
                                        <option value="Security Guard">Security Guard</option>
                                        <option value="Maid">Maid</option>
                                        <option value="Plumber">Plumber</option>
                                        <option value="Electrician">Electrician</option>
                                        <option value="Sweeper">Sweeper</option>
                                        <option value="Manager">Manager</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Contact Number <span class="text-danger">*</span></label>
                                    <input type="text" id="stContact" name="contactNumber" class="form-control bg-light border-0 py-2" required maxlength="20" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Aadhar Number</label>
                                    <input type="text" id="stAadhar" name="aadharNumber" class="form-control bg-light border-0 py-2" maxlength="20" placeholder="For Background Check" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Shift Start <span class="text-danger">*</span></label>
                                    <input type="time" id="stShiftStart" name="shiftStart" class="form-control bg-light border-0 py-2" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-muted mb-1">Shift End <span class="text-danger">*</span></label>
                                    <input type="time" id="stShiftEnd" name="shiftEnd" class="form-control bg-light border-0 py-2" required />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold small text-muted mb-1">Assigned Flats <span class="badge bg-secondary ms-2">Optional</span></label>
                                    <select id="stFlats" name="assignedFlatIds" class="form-select bg-light border-0 py-2" multiple style="height: 100px;">
                                        @if (ViewBag.Flats != null)
                                        {
                                            foreach (var f in ViewBag.Flats)
                                            {
                                                <option value="@f.FlatId">@f.FlatNumber - Block @f.BlockName</option>
                                            }
                                        }
                                    </select>
                                    <small class="text-muted">Hold Ctrl (Windows) or Command (Mac) to select multiple flats. Useful for Maids/Plumbers.</small>
                                </div>
                                
                                <div class="col-12 mt-4 pt-3 border-top d-flex gap-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="stIsVerified" name="isVerified" value="true">
                                        <label class="form-check-label fw-semibold text-dark" for="stIsVerified">Background Verified</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="stIsActive" name="isActive" value="true" checked>
                                        <label class="form-check-label fw-semibold text-dark" for="stIsActive">Currently Active</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitStaff">
                            <i class="fa-solid fa-save me-2"></i> Save Details
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ID Card Modal -->
<div class="modal fade" id="idCardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="bg-primary text-white text-center py-3">
                <h5 class="fw-bold mb-0">SmartSociety</h5>
                <small class="opacity-75">Staff Identity Card</small>
            </div>
            <div class="modal-body text-center p-4">
                <img id="idCardPhoto" src="" class="rounded-circle object-fit-cover border border-3 border-primary shadow-sm mb-3" width="100" height="100" alt="Staff Photo" />
                <h4 class="fw-bold text-dark mb-1" id="idCardName">Staff Name</h4>
                <p class="text-primary fw-semibold mb-3" id="idCardRole">Role</p>
                
                <div class="p-2 bg-light rounded-3 d-inline-block border">
                    <img id="idCardQr" src="" width="120" height="120" alt="QR Code" />
                </div>
                <p class="small text-muted mt-2 mb-0">Scan at Main Gate for Entry</p>
            </div>
            <div class="modal-footer bg-light border-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="window.print()"><i class="fa-solid fa-print me-2"></i> Print</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        var staffModal;

        $(document).ready(function () {
            $('#staffTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search staff..."
                },
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
            });
            $('.dataTables_filter input').addClass('form-control form-control-sm');

            staffModal = new bootstrap.Modal(document.getElementById('staffModal'));
            idCardModal = new bootstrap.Modal(document.getElementById('idCardModal'));
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#photoPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function openStaffModal() {
            $('#staffForm')[0].reset();
            $('#stId').val('0');
            $('#photoPreview').attr('src', 'https://via.placeholder.com/150');
            $('#stIsActive').prop('checked', true);
            $('#stIsVerified').prop('checked', false);
            $('#stFlats').val([]).trigger('change');
            $('#staffModalTitle').html('<i class="fa-solid fa-user-plus me-2"></i> Register New Staff');
            staffModal.show();
        }

        function openEditStaffModal(id, name, role, contact, aadhar, shiftStart, shiftEnd, isVerified, isActive, photoPath, assignedFlats) {
            $('#staffForm')[0].reset();
            $('#stId').val(id);
            $('#stName').val(decodeURIComponent(name));
            $('#stRole').val(decodeURIComponent(role));
            $('#stContact').val(decodeURIComponent(contact));
            $('#stAadhar').val(decodeURIComponent(aadhar));
            $('#stShiftStart').val(shiftStart);
            $('#stShiftEnd').val(shiftEnd);
            $('#stIsVerified').prop('checked', isVerified);
            $('#stIsActive').prop('checked', isActive);
            
            if (assignedFlats && assignedFlats.length > 0) {
                $('#stFlats').val(assignedFlats);
            } else {
                $('#stFlats').val([]);
            }
            
            if (photoPath && photoPath.length > 0) {
                $('#photoPreview').attr('src', photoPath);
            } else {
                $('#photoPreview').attr('src', 'https://via.placeholder.com/150');
            }
            
            $('#staffModalTitle').html('<i class="fa-solid fa-pen me-2"></i> Edit Staff Details');
            staffModal.show();
        }

        function showIdCard(id, name, role, photoPath) {
            $('#idCardName').text(decodeURIComponent(name));
            $('#idCardRole').text(decodeURIComponent(role));
            $('#idCardPhoto').attr('src', photoPath);
            $('#idCardQr').attr('src', 'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=STAFFID:' + id);
            idCardModal.show();
        }

        function markAttendance(id, type) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Staff/LogAttendance',
                type: 'POST',
                data: { id: id, logType: type, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                }
            });
        }

        function submitStaff() {
            var form = $('#staffForm')[0];
            var formData = new FormData(form);
            
            // Handle unchecked checkboxes which don't submit their value
            if (!$('#stIsVerified').is(':checked')) formData.append('isVerified', 'false');
            if (!$('#stIsActive').is(':checked')) formData.append('isActive', 'false');

            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $('#btnSubmitStaff').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

            $.ajax({
                url: '/Staff/SaveStaff',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitStaff').prop('disabled', false).html('<i class="fa-solid fa-save me-2"></i> Save Details');
                    }
                }
            });
        }

        function toggleStatus(id) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Staff/ToggleStatus',
                type: 'POST',
                data: { id: id, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        setTimeout(() => location.reload(), 1500); // revert toggle
                    }
                }
            });
        }
    </script>
}
