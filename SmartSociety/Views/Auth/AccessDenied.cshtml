@{
    ViewData["Title"] = "Access Denied";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="row justify-content-center w-100">
        <div class="col-md-6 col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5 bg-white position-relative overflow-hidden">
                <!-- Top red-orange accent line -->
                <div class="position-absolute top-0 start-0 w-100" style="height: 6px; background: linear-gradient(90deg, #dc3545 0%, #fd7e14 100%);"></div>
                
                <!-- Lock Icon -->
                <div class="mb-4 d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle shadow-sm" style="width: 100px; height: 100px;">
                    <i class="fa-solid fa-shield-halved fa-4x"></i>
                </div>
                
                <h1 class="fw-bold text-dark mb-2">Access Denied</h1>
                <h4 class="text-danger fw-semibold mb-3">Error 403: Forbidden</h4>
                <p class="text-muted mb-4 px-3">
                    You do not have the required permissions to access this page. Please contact the administrator if you believe this is an error.
                </p>
                
                <div class="d-flex justify-content-center gap-3">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold shadow-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i> Go Back
                    </a>
                    <a href="/" class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow-sm" style="background: linear-gradient(135deg, #dc3545 0%, #bd2130 100%); border: none;">
                        <i class="fa-solid fa-house me-2"></i> Home Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
