@model IEnumerable<SmartSociety.Models.MessageLog>

@{
    ViewData["Title"] = "Communication Center";
}

<!-- Summernote CSS for Rich Text Editor -->
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<style>
    .nav-pills .nav-link {
        color: #6c757d;
        border-radius: 8px;
        font-weight: 600;
        padding: 10px 20px;
        margin-right: 10px;
    }
    .nav-pills .nav-link.active {
        background-color: #0d6efd;
        color: white;
        box-shadow: 0 4px 6px rgba(13, 110, 253, 0.2);
    }
    .type-card {
        border: 2px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
    }
    .type-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .type-card.selected {
        border-color: #0d6efd;
        background-color: #f8fbff;
    }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Admin</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Communication Center</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1 text-dark"><i class="fa-solid fa-envelope-open-text text-primary me-2"></i> Communication Center</h2>
        <p class="text-muted mb-0">Broadcast messages, alerts, and emails to society residents.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <!-- Navigation Pills -->
        <div class="card border-0 shadow-sm rounded-4 bg-white p-3">
            <ul class="nav nav-pills flex-column" id="commTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active w-100 text-start mb-2" id="compose-tab" data-bs-toggle="pill" data-bs-target="#compose" type="button" role="tab">
                        <i class="fa-solid fa-pen-nib me-2"></i> Compose Message
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 text-start" id="history-tab" data-bs-toggle="pill" data-bs-target="#history" type="button" role="tab">
                        <i class="fa-solid fa-clock-rotate-left me-2"></i> Message History
                    </button>
                </li>
            </ul>
            <hr class="text-muted" />
            <div class="alert alert-info bg-info bg-opacity-10 border-0 rounded-3 small text-dark mb-0">
                <i class="fa-solid fa-circle-info text-info me-1"></i> <strong>Note:</strong> SMS is restricted to 160 characters. Use Email for longer updates.
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="tab-content" id="commTabsContent">
            
            <!-- Compose Tab -->
            <div class="tab-pane fade show active" id="compose" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-lg-5">
                        <form id="composeForm" onsubmit="event.preventDefault(); sendMessage();">
                            
                            <h6 class="fw-bold text-dark mb-3">1. Select Message Type</h6>
                            <div class="row g-3 mb-4">
                                <div class="col-md-4">
                                    <div class="card bg-light border-0 rounded-3 p-3 text-center type-card selected" id="typeEmail" onclick="selectType('Email')">
                                        <i class="fa-solid fa-envelope-open-text fa-2x text-primary mb-2"></i>
                                        <h6 class="fw-bold mb-0">Email Broadcast</h6>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card bg-light border-0 rounded-3 p-3 text-center type-card" id="typeSMS" onclick="selectType('SMS')">
                                        <i class="fa-solid fa-comment-sms fa-2x text-success mb-2"></i>
                                        <h6 class="fw-bold mb-0">SMS Alert</h6>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card bg-light border-0 rounded-3 p-3 text-center type-card" id="typeAlert" onclick="selectType('Emergency Alert')">
                                        <i class="fa-solid fa-triangle-exclamation fa-2x text-danger mb-2"></i>
                                        <h6 class="fw-bold mb-0">Emergency Push</h6>
                                    </div>
                                </div>
                            </div>
                            
                            <input type="hidden" id="cMessageType" name="MessageType" value="Email" />

                            <h6 class="fw-bold text-dark mb-3 mt-4">2. Select Audience</h6>
                            <div class="mb-4">
                                <select id="cAudience" name="Audience" class="form-select bg-light border-0 py-2 fw-semibold text-dark" required>
                                    <option value="All Residents">All Society Residents</option>
                                    <option value="Tower A Residents">Tower A Residents Only</option>
                                    <option value="Tower B Residents">Tower B Residents Only</option>
                                    <option value="Maintenance Defaulters">Maintenance Defaulters</option>
                                    <option value="Committee Members">Committee Members Only</option>
                                    <option value="Security Guards">Security Guards</option>
                                </select>
                            </div>

                            <h6 class="fw-bold text-dark mb-3 mt-4">3. Compose Content</h6>
                            <div id="subjectContainer" class="mb-3">
                                <label class="form-label fw-semibold small text-muted mb-1">Email Subject <span class="text-danger">*</span></label>
                                <input type="text" id="cSubject" name="Subject" class="form-control border border-1 py-2 fw-bold" placeholder="e.g. Important Update regarding Water Supply" required />
                            </div>

                            <div class="mb-4 position-relative">
                                <label class="form-label fw-semibold small text-muted mb-1">Message Body <span class="text-danger">*</span></label>
                                
                                <!-- Editor for Email -->
                                <div id="emailEditorContainer">
                                    <textarea id="cBodyEmail" name="BodyEmail"></textarea>
                                </div>

                                <!-- Textarea for SMS / Alert -->
                                <div id="smsEditorContainer" class="d-none">
                                    <textarea id="cBodySMS" name="BodySMS" class="form-control border border-1 p-3" rows="4" placeholder="Type your short message here..." onkeyup="countChars()"></textarea>
                                    <div class="text-end mt-1 small fw-bold text-muted" id="charCount">0 / 160 characters</div>
                                </div>
                            </div>
                            
                            <hr class="my-4" />
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold fs-6" id="btnSend">
                                    <i class="fa-solid fa-paper-plane me-2"></i> Send Now
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- History Tab -->
            <div class="tab-pane fade" id="history" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <table class="table table-hover align-middle w-100" id="historyTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold text-muted py-3">Sent On</th>
                                    <th class="fw-semibold text-muted py-3">Type</th>
                                    <th class="fw-semibold text-muted py-3">Audience</th>
                                    <th class="fw-semibold text-muted py-3 w-25">Subject / Preview</th>
                                    <th class="fw-semibold text-muted py-3">Status</th>
                                    <th class="fw-semibold text-muted py-3 text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr>
                                        <td class="py-3 fw-semibold text-dark small">@log.SentAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                                        <td class="py-3">
                                            @if(log.MessageType == "Email") { <span class="badge bg-primary-subtle text-primary rounded-pill"><i class="fa-solid fa-envelope me-1"></i> Email</span> }
                                            else if(log.MessageType == "SMS") { <span class="badge bg-success-subtle text-success rounded-pill"><i class="fa-solid fa-comment-sms me-1"></i> SMS</span> }
                                            else { <span class="badge bg-danger-subtle text-danger rounded-pill"><i class="fa-solid fa-triangle-exclamation me-1"></i> Alert</span> }
                                        </td>
                                        <td class="py-3 small fw-bold text-secondary">@log.Audience</td>
                                        <td class="py-3 small text-muted text-truncate" style="max-width: 200px;">
                                            @(log.MessageType == "Email" ? log.Subject : log.Body)
                                        </td>
                                        <td class="py-3">
                                            @if(log.Status == "Sent") { <span class="text-success small fw-bold"><i class="fa-solid fa-check-circle me-1"></i> Sent</span> }
                                            else { <span class="text-danger small fw-bold"><i class="fa-solid fa-xmark-circle me-1"></i> Failed</span> }
                                        </td>
                                        <td class="py-3 text-end">
                                            <button type="button" class="btn btn-light btn-sm text-primary rounded-pill px-3" onclick="viewMessageLog(@log.MessageId)">
                                                View
                                            </button>
                                            <!-- Hidden div to store full body for the modal -->
                                            <div id="logBody_@log.MessageId" class="d-none">@Html.Raw(log.Body)</div>
                                            <div id="logSubj_@log.MessageId" class="d-none">@log.Subject</div>
                                            <div id="logType_@log.MessageId" class="d-none">@log.MessageType</div>
                                            <div id="logAud_@log.MessageId" class="d-none">@log.Audience</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- View Message Modal -->
<div class="modal fade" id="viewMsgModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-light rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-regular fa-envelope-open me-2 text-primary"></i> Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <div class="mb-3 d-flex gap-3 border-bottom pb-3">
                    <div>
                        <div class="small text-muted fw-semibold">Sent Via</div>
                        <div class="fw-bold text-dark" id="vType"></div>
                    </div>
                    <div>
                        <div class="small text-muted fw-semibold">Target Audience</div>
                        <div class="fw-bold text-dark" id="vAud"></div>
                    </div>
                </div>
                <div class="mb-3" id="vSubjContainer">
                    <div class="small text-muted fw-semibold">Subject</div>
                    <div class="fw-bold text-dark fs-5" id="vSubj"></div>
                </div>
                <div>
                    <div class="small text-muted fw-semibold mb-2">Message Body</div>
                    <div class="p-3 bg-light rounded-3 border" id="vBody" style="min-height: 150px;"></div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-dark px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- Summernote JS -->
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

    <script>
        var viewMsgModal;

        $(document).ready(function () {
            // Initialize DataTable
            $('#historyTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": { "search": "", "searchPlaceholder": "Search history..." },
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
            });
            $('.dataTables_filter input').addClass('form-control form-control-sm border-0 shadow-sm bg-light').css('width', '250px');

            // Initialize Summernote
            $('#cBodyEmail').summernote({
                placeholder: 'Type your detailed email message here...',
                tabsize: 2,
                height: 250,
                toolbar: [
                    ['style', ['style']],
                    ['font', ['bold', 'underline', 'clear']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['insert', ['link']]
                ]
            });

            viewMsgModal = new bootstrap.Modal(document.getElementById('viewMsgModal'));
        });

        function selectType(type) {
            // Update UI
            $('.type-card').removeClass('selected');
            if (type === 'Email') $('#typeEmail').addClass('selected');
            else if (type === 'SMS') $('#typeSMS').addClass('selected');
            else $('#typeAlert').addClass('selected');

            $('#cMessageType').val(type);

            // Toggle Form Fields based on type
            if (type === 'Email') {
                $('#subjectContainer').removeClass('d-none');
                $('#cSubject').attr('required', true);
                
                $('#emailEditorContainer').removeClass('d-none');
                $('#smsEditorContainer').addClass('d-none');
                $('#cBodySMS').removeAttr('required');
            } else {
                $('#subjectContainer').addClass('d-none');
                $('#cSubject').removeAttr('required');
                
                $('#emailEditorContainer').addClass('d-none');
                $('#smsEditorContainer').removeClass('d-none');
                $('#cBodySMS').attr('required', true);
            }
        }

        function countChars() {
            var len = $('#cBodySMS').val().length;
            var counter = $('#charCount');
            counter.text(len + ' / 160 characters');
            
            if (len > 160) {
                counter.removeClass('text-muted').addClass('text-danger');
            } else {
                counter.removeClass('text-danger').addClass('text-muted');
            }
        }

        function sendMessage() {
            var type = $('#cMessageType').val();
            var bodyData = '';
            
            if (type === 'Email') {
                if ($('#cBodyEmail').summernote('isEmpty')) {
                    Swal.fire('Error', 'Message body cannot be empty.', 'error');
                    return;
                }
                bodyData = $('#cBodyEmail').summernote('code');
            } else {
                var len = $('#cBodySMS').val().length;
                if (len > 160) {
                    Swal.fire('Error', 'SMS cannot exceed 160 characters.', 'warning');
                    return;
                }
                bodyData = $('#cBodySMS').val();
            }

            var data = {
                MessageType: type,
                Audience: $('#cAudience').val(),
                Subject: type === 'Email' ? $('#cSubject').val() : null,
                Body: bodyData,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            };

            var btn = $('#btnSend');
            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Sending...');

            $.ajax({
                url: '/Communication/SendMessage',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            title: 'Sent!',
                            text: res.message,
                            icon: 'success',
                            confirmButtonText: 'Great',
                            confirmButtonColor: '#0d6efd'
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i> Send Now');
                    }
                },
                error: function() {
                    Swal.fire('Error', 'A network error occurred.', 'error');
                    btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i> Send Now');
                }
            });
        }

        function viewMessageLog(id) {
            var type = $('#logType_' + id).text();
            
            $('#vType').html(type === 'Email' ? '<i class="fa-solid fa-envelope text-primary me-1"></i> Email' : 
                            (type === 'SMS' ? '<i class="fa-solid fa-comment-sms text-success me-1"></i> SMS' : 
                            '<i class="fa-solid fa-triangle-exclamation text-danger me-1"></i> Alert'));
            
            $('#vAud').text($('#logAud_' + id).text());
            
            if (type === 'Email') {
                $('#vSubjContainer').removeClass('d-none');
                $('#vSubj').text($('#logSubj_' + id).text());
            } else {
                $('#vSubjContainer').addClass('d-none');
            }

            $('#vBody').html($('#logBody_' + id).html());
            
            viewMsgModal.show();
        }
    </script>
}
