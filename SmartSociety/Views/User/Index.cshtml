@model IEnumerable<SmartSociety.Models.User>

@{
    ViewData["Title"] = "User Management";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Admin</li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">User Management</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">User Management</h2>
        <p class="text-muted mb-0">Manage system users, residents, and staff.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="DownloadTemplate" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-pill shadow-sm">
            <i class="fa-solid fa-download me-1"></i> Template
        </a>
        <button type="button" class="btn btn-outline-primary px-3 py-2 fw-semibold rounded-pill shadow-sm" onclick="$('#bulkUploadFile').click()">
            <i class="fa-solid fa-file-excel me-1"></i> Bulk Upload
        </button>
        <a asp-action="Upsert" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Add New User
        </a>
    </div>
    <form id="bulkUploadForm" style="display:none;">
        <input type="file" id="bulkUploadFile" accept=".xlsx" onchange="handleBulkUpload(this)" />
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="bg-white rounded-4 shadow-sm p-4">
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label text-muted small fw-bold mb-1">Filter by Role</label>
            <select id="roleFilter" class="form-select form-select-sm">
                <option value="">All Roles</option>
                <option value="Admin">Admin</option>
                <option value="Resident">Resident</option>
                <option value="Guard">Guard</option>
                <option value="Accountant">Accountant</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label text-muted small fw-bold mb-1">Filter by Status</label>
            <select id="statusFilter" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="usersTable">
            <thead class="table-light">
                <tr>
                    <th class="text-secondary fw-semibold py-3 border-0 rounded-start">User</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Contact Info</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Role</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Status</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Joined Date</th>
                    <th class="text-end text-secondary fw-semibold py-3 border-0 rounded-end">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <tr>
                            <td class="py-3">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(user.ProfilePicture))
                                        {
                                            <img src="@user.ProfilePicture" alt="" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="bg-light text-primary rounded-circle d-flex justify-content-center align-items-center fw-bold" style="width: 40px; height: 40px;">
                                                @(string.IsNullOrEmpty(user.FullName) ? "U" : user.FullName.Substring(0, 1).ToUpper())
                                            </div>
                                        }
                                    </div>
                                    <div class="ms-3">
                                        <h6 class="mb-0 fw-semibold text-dark">@user.FullName</h6>
                                        <small class="text-muted">ID: @user.UserId</small>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="text-dark"><i class="fa-solid fa-phone fa-sm text-muted me-1"></i> @user.PhoneNumber</div>
                                @if (!string.IsNullOrEmpty(user.Email))
                                {
                                    <small class="text-muted"><i class="fa-regular fa-envelope fa-sm me-1"></i> @user.Email</small>
                                }
                            </td>
                            <td class="py-3">
                                @{
                                    var roleClass = user.Role switch {
                                        "Admin" => "bg-primary-subtle text-primary",
                                        "Resident" => "bg-success-subtle text-success",
                                        "Guard" => "bg-warning-subtle text-warning",
                                        "Accountant" => "bg-info-subtle text-info",
                                        _ => "bg-secondary-subtle text-secondary"
                                    };
                                }
                                <span class="badge @roleClass rounded-pill px-3 py-2 fw-medium">@user.Role</span>
                                @if (!string.IsNullOrEmpty(user.FlatNumber))
                                {
                                    <div class="mt-1 small text-muted"><i class="fa-solid fa-house fa-sm me-1"></i> @user.FlatNumber</div>
                                }
                            </td>
                            <td class="py-3">
                                <div class="form-check form-switch d-flex align-items-center">
                                    <input class="form-check-input me-2 mt-0" type="checkbox" role="switch" id="statusSwitch_@user.UserId" 
                                           @(user.IsActive ? "checked" : "") onchange="toggleStatus(@user.UserId, this.checked)" style="cursor:pointer;">
                                    <label class="form-check-label mb-0" for="statusSwitch_@user.UserId">
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success rounded-pill" id="statusBadge_@user.UserId"><i class="fa-solid fa-check me-1"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill" id="statusBadge_@user.UserId"><i class="fa-solid fa-xmark me-1"></i> Inactive</span>
                                        }
                                    </label>
                                </div>
                            </td>
                            <td class="py-3 text-muted">
                                @user.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="py-3 text-end">
                                <div class="btn-group shadow-sm">
                                    <button type="button" class="btn btn-light btn-sm text-info" title="View Details" 
                                            onclick="viewUser({ 
                                                id: @user.UserId, 
                                                name: '@user.FullName.Replace("'", "\\'")', 
                                                email: '@(user.Email ?? "")', 
                                                phone: '@user.PhoneNumber', 
                                                role: '@user.Role', 
                                                flat: '@(user.FlatNumber ?? "")', 
                                                joined: '@user.CreatedAt.ToString("MMM dd, yyyy")', 
                                                image: '@(string.IsNullOrEmpty(user.ProfilePicture) ? "" : user.ProfilePicture)'
                                            })">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                    <button type="button" class="btn btn-light btn-sm text-warning" title="Reset Password" onclick="resetUserPassword(@user.UserId, '@user.FullName.Replace("'", "\\'")')">
                                        <i class="fa-solid fa-key"></i>
                                    </button>
                                    <a asp-action="Upsert" asp-route-id="@user.UserId" class="btn btn-light btn-sm text-primary" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-light btn-sm text-danger" title="Delete" onclick="deleteUser(@user.UserId, '@user.FullName')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa-solid fa-users fa-3x mb-3 text-light"></i>
                            <h5>No Users Found</h5>
                            <p>Get started by creating a new user.</p>
                            <a asp-action="Upsert" class="btn btn-outline-primary mt-2">Create First User</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- View User Modal -->
<div class="modal fade" id="viewUserModal" tabindex="-1" aria-labelledby="viewUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0 pb-4 px-4">
                <div class="mb-3">
                    <img id="viewUserImage" src="" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover; display: none;">
                    <div id="viewUserInitials" class="bg-light text-primary rounded-circle d-inline-flex justify-content-center align-items-center fw-bold shadow-sm" style="width: 100px; height: 100px; font-size: 2.5rem; display: none;"></div>
                </div>
                <h4 id="viewUserName" class="fw-bold mb-1"></h4>
                <p id="viewUserRoleBadge" class="mb-3"></p>
                
                <div class="bg-light rounded-3 p-3 text-start">
                    <div class="row mb-2">
                        <div class="col-4 text-muted small fw-semibold">User ID</div>
                        <div class="col-8 fw-medium" id="viewUserId"></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 text-muted small fw-semibold">Phone</div>
                        <div class="col-8 fw-medium" id="viewUserPhone"></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 text-muted small fw-semibold">Email</div>
                        <div class="col-8 fw-medium" id="viewUserEmail"></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 text-muted small fw-semibold">Flat No.</div>
                        <div class="col-8 fw-medium" id="viewUserFlat"></div>
                    </div>
                    <div class="row">
                        <div class="col-4 text-muted small fw-semibold">Joined</div>
                        <div class="col-8 fw-medium" id="viewUserJoined"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pt-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 rounded-pill" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- DataTables Export Buttons -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    
    <script>
        $(document).ready(function () {
            var table = $('#usersTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "responsive": true,
                "dom": '<"row"<"col-sm-12 col-md-6"B><"col-sm-12 col-md-6"f>>rt<"row"<"col-sm-12 col-md-6"i><"col-sm-12 col-md-6"p>>',
                "buttons": [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        className: 'btn btn-sm btn-outline-success mb-2',
                        init: function(api, node, config) { $(node).removeClass('btn-secondary'); },
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        className: 'btn btn-sm btn-outline-danger mb-2',
                        init: function(api, node, config) { $(node).removeClass('btn-secondary'); },
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    },
                    {
                        extend: 'print',
                        text: '<i class="fa-solid fa-print me-1"></i> Print',
                        className: 'btn btn-sm btn-outline-secondary mb-2',
                        init: function(api, node, config) { $(node).removeClass('btn-secondary'); },
                        exportOptions: { columns: [0, 1, 2, 3, 4] }
                    }
                ],
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search users..."
                }
            });

            // Custom Filters
            $('#roleFilter').on('change', function () {
                table.column(2).search(this.value).draw();
            });

            $('#statusFilter').on('change', function () {
                table.column(3).search(this.value).draw();
            });
        });

        function deleteUser(id, name) {
            Swal.fire({
                title: 'Are you sure?',
                text: `You are about to delete ${name}. This action cannot be undone!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Get token
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    
                    $.ajax({
                        url: '/User/Delete/' + id,
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: token
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire(
                                    'Deleted!',
                                    res.message,
                                    'success'
                                ).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire(
                                    'Error!',
                                    res.message,
                                    'error'
                                );
                            }
                        },
                        error: function (err) {
                            Swal.fire(
                                'Error!',
                                'An unexpected error occurred.',
                                'error'
                            );
                        }
                    });
                }
            });
        }

        function resetUserPassword(id, name) {
            Swal.fire({
                title: 'Reset Password',
                text: `Enter new password for ${name}:`,
                input: 'password',
                inputPlaceholder: 'New password (min 6 chars)',
                inputAttributes: {
                    autocapitalize: 'off',
                    autocorrect: 'off'
                },
                icon: 'info',
                showCancelButton: true,
                confirmButtonText: 'Reset',
                showLoaderOnConfirm: true,
                preConfirm: (newPassword) => {
                    if (!newPassword || newPassword.length < 6) {
                        Swal.showValidationMessage('Password must be at least 6 characters long.');
                        return false;
                    }
                    
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    
                    return $.ajax({
                        url: '/User/ResetPassword',
                        type: 'POST',
                        data: {
                            id: id,
                            newPassword: newPassword,
                            __RequestVerificationToken: token
                        }
                    }).then(response => {
                        if (!response.success) {
                            throw new Error(response.message);
                        }
                        return response;
                    }).catch(error => {
                        Swal.showValidationMessage(
                            `Request failed: ${error.message || error.statusText}`
                        );
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire(
                        'Success!',
                        result.value.message,
                        'success'
                    );
                }
            });
        }

        function toggleStatus(id, isActive) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            
            $.ajax({
                url: '/User/ToggleStatus/' + id,
                type: 'POST',
                data: {
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        // Update the label
                        var badge = $('#statusBadge_' + id);
                        if (isActive) {
                            badge.removeClass('bg-danger').addClass('bg-success').html('<i class="fa-solid fa-check me-1"></i> Active');
                        } else {
                            badge.removeClass('bg-success').addClass('bg-danger').html('<i class="fa-solid fa-xmark me-1"></i> Inactive');
                        }
                        
                        // Show subtle toast notification
                        Swal.fire({
                            toast: true,
                            position: 'top-end',
                            icon: 'success',
                            title: res.message,
                            showConfirmButton: false,
                            timer: 3000
                        });
                    } else {
                        // Revert the switch if failed
                        $('#statusSwitch_' + id).prop('checked', !isActive);
                        Swal.fire('Error!', res.message, 'error');
                    }
                },
                error: function () {
                    $('#statusSwitch_' + id).prop('checked', !isActive);
                    Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                }
            });
        }

        function viewUser(data) {
            $('#viewUserId').text(data.id);
            $('#viewUserName').text(data.name);
            $('#viewUserPhone').text(data.phone || 'N/A');
            $('#viewUserEmail').text(data.email || 'N/A');
            $('#viewUserFlat').text(data.flat || 'N/A');
            $('#viewUserJoined').text(data.joined);
            
            var roleClass = "bg-secondary-subtle text-secondary";
            if(data.role === "Admin") roleClass = "bg-primary-subtle text-primary";
            else if(data.role === "Resident") roleClass = "bg-success-subtle text-success";
            else if(data.role === "Guard") roleClass = "bg-warning-subtle text-warning";
            else if(data.role === "Accountant") roleClass = "bg-info-subtle text-info";
            
            $('#viewUserRoleBadge').html(`<span class="badge ${roleClass} rounded-pill px-3 py-2 fw-medium">${data.role}</span>`);
            
            if (data.image && data.image !== '') {
                $('#viewUserImage').attr('src', data.image).show();
                $('#viewUserInitials').hide();
            } else {
                $('#viewUserImage').hide();
                $('#viewUserInitials').text(data.name ? data.name.charAt(0).toUpperCase() : 'U').show();
            }
            
            var modal = new bootstrap.Modal(document.getElementById('viewUserModal'));
            modal.show();
        }

        function handleBulkUpload(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                var formData = new FormData();
                formData.append("uploadFile", file);
                formData.append("__RequestVerificationToken", $('input[name="__RequestVerificationToken"]').val());

                Swal.fire({
                    title: 'Uploading...',
                    html: 'Please wait while we process the users.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/User/BulkUpload',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                        // Reset input so the same file can be selected again
                        $('#bulkUploadFile').val('');
                    },
                    error: function (err) {
                        Swal.fire('Error', 'An unexpected error occurred during upload.', 'error');
                        $('#bulkUploadFile').val('');
                    }
                });
            }
        }
    </script>
}
