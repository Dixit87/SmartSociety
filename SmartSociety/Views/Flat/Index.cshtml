@model IEnumerable<SmartSociety.Models.Flat>

@{
    ViewData["Title"] = "Flat Management";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Admin</li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Flat Management</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Flat & Unit Management</h2>
        <p class="text-muted mb-0">Manage all society blocks, flats, owners, and tenants.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="DownloadTemplate" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-pill shadow-sm">
            <i class="fa-solid fa-download me-1"></i> Template
        </a>
        <button type="button" class="btn btn-outline-primary px-3 py-2 fw-semibold rounded-pill shadow-sm" onclick="$('#bulkUploadFile').click()">
            <i class="fa-solid fa-file-excel me-1"></i> Bulk Upload
        </button>
        <button type="button" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-pill shadow-sm" onclick="openManageBlocksModal()">
            <i class="fa-solid fa-layer-group me-1"></i> Manage Blocks
        </button>
        <a asp-action="Upsert" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Add New Flat
        </a>
    </div>
    <form id="bulkUploadForm" style="display:none;">
        <input type="file" id="bulkUploadFile" accept=".xlsx" onchange="handleBulkUpload(this)" />
    </form>
</div>

<!-- Dashboard Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="bg-primary bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-building fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Total Flats</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.TotalFlats</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-success bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-house-user fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Self-Occupied</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.SelfOccupiedFlats</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-info bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-info text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-users fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Rented</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.RentedFlats</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-warning bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-warning text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-door-open fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Vacant</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.VacantFlats</h4>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="bg-white rounded-4 shadow-sm p-4">
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label text-muted small fw-bold mb-1">Filter by Block</label>
            <select id="blockFilter" class="form-select form-select-sm">
                <option value="">All Blocks</option>
                @if (ViewBag.Blocks != null)
                {
                    foreach (var block in ViewBag.Blocks)
                    {
                        <option value="@block.BlockName">@block.BlockName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label text-muted small fw-bold mb-1">Filter by Type</label>
            <select id="typeFilter" class="form-select form-select-sm">
                <option value="">All Types</option>
                <option value="1BHK">1BHK</option>
                <option value="2BHK">2BHK</option>
                <option value="3BHK">3BHK</option>
                <option value="4BHK">4BHK</option>
                <option value="Penthouse">Penthouse</option>
            </select>
        </div>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="flatsTable">
            <thead class="table-light">
                <tr>
                    <th class="text-secondary fw-semibold py-3 border-0 rounded-start">Unit Details</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Type & Area</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Occupancy</th>
                    <th class="text-secondary fw-semibold py-3 border-0">Status</th>
                    <th class="text-end text-secondary fw-semibold py-3 border-0 rounded-end">Actions</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var flat in Model)
                    {
                        <tr>
                            <td class="py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary-subtle text-primary rounded-3 d-flex justify-content-center align-items-center fw-bold me-3" style="width: 45px; height: 45px;">
                                        <i class="fa-solid fa-door-closed fa-lg"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark">@flat.BlockName - @flat.FlatNumber</h6>
                                        <small class="text-muted">Floor @flat.FloorNumber</small>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="badge bg-secondary-subtle text-secondary px-2 py-1 mb-1">@flat.FlatType</span>
                                <div class="small text-muted"><i class="fa-solid fa-vector-square fa-sm me-1"></i> @flat.AreaSqFt Sq.Ft.</div>
                                @if(!string.IsNullOrEmpty(flat.IntercomNumber))
                                {
                                    <div class="small text-muted mt-1"><i class="fa-solid fa-phone fa-sm me-1"></i> Ext: @flat.IntercomNumber</div>
                                }
                            </td>
                            <td class="py-3">
                                @{
                                    bool hasOwner = !string.IsNullOrEmpty(flat.OwnerName);
                                    bool hasTenant = !string.IsNullOrEmpty(flat.TenantName);
                                    
                                    if(hasOwner && !hasTenant)
                                    {
                                        <span class="badge bg-success-subtle text-success mb-2"><i class="fa-solid fa-house-user me-1"></i> Self-Occupied</span>
                                    }
                                    else if(hasTenant)
                                    {
                                        <span class="badge bg-info-subtle text-info mb-2"><i class="fa-solid fa-users me-1"></i> Rented</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning mb-2"><i class="fa-solid fa-door-open me-1"></i> Vacant</span>
                                    }
                                }
                                
                                @if (hasOwner)
                                {
                                    <div class="text-dark small"><i class="fa-solid fa-user-tie text-muted me-1" title="Owner"></i> @flat.OwnerName</div>
                                }
                                else
                                {
                                    <div class="text-muted small fst-italic"><i class="fa-solid fa-user-tie text-muted me-1"></i> No Owner</div>
                                }
                                
                                @if (!string.IsNullOrEmpty(flat.TenantName))
                                {
                                    <div class="text-dark small mt-1"><i class="fa-solid fa-user text-muted me-1" title="Tenant"></i> @flat.TenantName</div>
                                }
                            </td>
                            <td class="py-3">
                                <div class="form-check form-switch d-flex align-items-center">
                                    <input class="form-check-input me-2 mt-0" type="checkbox" role="switch" id="statusSwitch_@flat.FlatId" 
                                           @(flat.IsActive ? "checked" : "") onchange="toggleStatus(@flat.FlatId, this.checked)" style="cursor:pointer;">
                                    <label class="form-check-label mb-0" for="statusSwitch_@flat.FlatId">
                                        @if (flat.IsActive)
                                        {
                                            <span class="badge bg-success rounded-pill" id="statusBadge_@flat.FlatId">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill" id="statusBadge_@flat.FlatId">Inactive</span>
                                        }
                                    </label>
                                </div>
                            </td>
                            <td class="py-3 text-end">
                                <div class="btn-group shadow-sm">
                                    <button type="button" class="btn btn-light btn-sm text-info" title="View Details" 
                                            onclick="viewFlat({ 
                                                id: @flat.FlatId, 
                                                block: '@flat.BlockName', 
                                                flatNo: '@flat.FlatNumber', 
                                                floor: @flat.FloorNumber, 
                                                type: '@flat.FlatType', 
                                                area: @flat.AreaSqFt, 
                                                owner: '@(flat.OwnerName ?? "N/A")', 
                                                tenant: '@(flat.TenantName ?? "N/A")'
                                            })">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                    <a asp-action="Upsert" asp-route-id="@flat.FlatId" class="btn btn-light btn-sm text-primary" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-light btn-sm text-danger" title="Delete" onclick="deleteFlat(@flat.FlatId, '@flat.BlockName - @flat.FlatNumber')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- View Flat Modal -->
<div class="modal fade" id="viewFlatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Flat Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary-subtle text-primary rounded-4 d-flex justify-content-center align-items-center fw-bold me-3 shadow-sm" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fa-solid fa-building"></i>
                    </div>
                    <div>
                        <h3 id="viewFlatName" class="fw-bold mb-0 text-dark"></h3>
                        <span id="viewFlatTypeBadge" class="badge bg-secondary-subtle text-secondary mt-1"></span>
                    </div>
                </div>
                
                <div class="bg-light rounded-4 p-3 mb-3">
                    <div class="row mb-2">
                        <div class="col-5 text-muted small fw-semibold"><i class="fa-solid fa-layer-group me-2"></i>Floor</div>
                        <div class="col-7 fw-medium text-dark" id="viewFlatFloor"></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted small fw-semibold"><i class="fa-solid fa-vector-square me-2"></i>Area</div>
                        <div class="col-7 fw-medium text-dark" id="viewFlatArea"></div>
                    </div>
                </div>
                
                <div class="bg-light rounded-4 p-3">
                    <div class="row mb-3">
                        <div class="col-5 text-muted small fw-semibold"><i class="fa-solid fa-user-tie me-2"></i>Owner</div>
                        <div class="col-7 fw-bold text-primary" id="viewFlatOwner"></div>
                    </div>
                    <div class="row">
                        <div class="col-5 text-muted small fw-semibold"><i class="fa-solid fa-user me-2"></i>Tenant</div>
                        <div class="col-7 fw-medium text-dark" id="viewFlatTenant"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 justify-content-center pt-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 rounded-pill shadow-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Manage Blocks Modal -->
<div class="modal fade" id="manageBlocksModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-light rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold text-dark"><i class="fa-solid fa-layer-group me-2 text-primary"></i> Manage Blocks (Wings)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <!-- Add / Edit Form -->
                <div class="card border-0 shadow-sm rounded-3 mb-4 bg-light">
                    <div class="card-body p-3">
                        <form id="blockForm" onsubmit="event.preventDefault(); saveBlock();">
                            <input type="hidden" id="blockId" value="0" />
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label class="form-label small fw-semibold text-muted mb-1">Block Name</label>
                                    <input type="text" id="blockName" class="form-control" placeholder="e.g. A-Wing, Tower 1" required />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small fw-semibold text-muted mb-1">Total Floors</label>
                                    <input type="number" id="blockFloors" class="form-control" placeholder="e.g. 10" required min="1" max="200" />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-primary w-100 fw-semibold" id="btnSaveBlock">
                                        <i class="fa-solid fa-plus me-1"></i> Add
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Blocks Table -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle border mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-secondary fw-semibold">Block Name</th>
                                <th class="text-secondary fw-semibold text-center">Total Floors</th>
                                <th class="text-end text-secondary fw-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="blocksTableBody">
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">Loading blocks...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    
    <script>
        $(document).ready(function () {
            var table = $('#flatsTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "responsive": true,
                "dom": '<"row"<"col-sm-12 col-md-6"B><"col-sm-12 col-md-6"f>>rt<"row"<"col-sm-12 col-md-6"i><"col-sm-12 col-md-6"p>>',
                "buttons": [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="fa-solid fa-file-excel me-1"></i> Excel',
                        className: 'btn btn-sm btn-outline-success mb-2',
                        init: function(api, node, config) { $(node).removeClass('btn-secondary'); },
                        exportOptions: { columns: [0, 1, 2, 3] }
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="fa-solid fa-file-pdf me-1"></i> PDF',
                        className: 'btn btn-sm btn-outline-danger mb-2',
                        init: function(api, node, config) { $(node).removeClass('btn-secondary'); },
                        exportOptions: { columns: [0, 1, 2, 3] }
                    }
                ],
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search flats..."
                }
            });

            // Filters
            $('#blockFilter').on('change', function () {
                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                table.column(0).search(val ? '^' + val + '.*' : '', true, false).draw();
            });

            $('#typeFilter').on('change', function () {
                table.column(1).search(this.value).draw();
            });
        });

        function deleteFlat(id, name) {
            Swal.fire({
                title: 'Delete Flat?',
                text: `Are you sure you want to delete ${name}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Flat/Delete/' + id,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Deleted!', res.message, 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        function toggleStatus(id, isActive) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Flat/ToggleStatus/' + id,
                type: 'POST',
                data: { __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        var badge = $('#statusBadge_' + id);
                        if (isActive) {
                            badge.removeClass('bg-danger').addClass('bg-success').text('Active');
                        } else {
                            badge.removeClass('bg-success').addClass('bg-danger').text('Inactive');
                        }
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 3000 });
                    } else {
                        $('#statusSwitch_' + id).prop('checked', !isActive);
                        Swal.fire('Error!', res.message, 'error');
                    }
                }
            });
        }

        function viewFlat(data) {
            $('#viewFlatName').text(data.block + ' - ' + data.flatNo);
            $('#viewFlatTypeBadge').text(data.type);
            $('#viewFlatFloor').text(data.floor);
            $('#viewFlatArea').text(data.area + ' Sq.Ft.');
            $('#viewFlatOwner').text(data.owner);
            $('#viewFlatTenant').text(data.tenant);
            
            var modal = new bootstrap.Modal(document.getElementById('viewFlatModal'));
            modal.show();
        }

        function handleBulkUpload(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                var formData = new FormData();
                formData.append("uploadFile", file);
                formData.append("__RequestVerificationToken", $('input[name="__RequestVerificationToken"]').val());

                Swal.fire({
                    title: 'Uploading...',
                    html: 'Please wait while we process the flats.',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/Flat/BulkUpload',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                        $('#bulkUploadFile').val('');
                    },
                    error: function (err) {
                        Swal.fire('Error', 'An unexpected error occurred during upload.', 'error');
                        $('#bulkUploadFile').val('');
                    }
                });
            }
        }

        // --- Block Management JS ---
        var manageBlocksModal;

        function openManageBlocksModal() {
            if (!manageBlocksModal) {
                manageBlocksModal = new bootstrap.Modal(document.getElementById('manageBlocksModal'));
            }
            resetBlockForm();
            loadBlocks();
            manageBlocksModal.show();
        }

        function resetBlockForm() {
            $('#blockId').val('0');
            $('#blockName').val('');
            $('#blockFloors').val('');
            $('#btnSaveBlock').html('<i class="fa-solid fa-plus me-1"></i> Add').removeClass('btn-success').addClass('btn-primary');
        }

        function loadBlocks() {
            $.ajax({
                url: '/Flat/GetBlocks',
                type: 'GET',
                success: function (res) {
                    var tbody = $('#blocksTableBody');
                    tbody.empty();
                    
                    if (res.data && res.data.length > 0) {
                        res.data.forEach(function (block) {
                            var tr = `
                                <tr>
                                    <td class="fw-bold text-dark">${block.blockName}</td>
                                    <td class="text-center">${block.totalFloors}</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-light text-primary me-1" onclick="editBlock(${block.blockId}, '${block.blockName}', ${block.totalFloors})" title="Edit">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light text-danger" onclick="deleteBlock(${block.blockId}, '${block.blockName}')" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `;
                            tbody.append(tr);
                        });
                    } else {
                        tbody.html('<tr><td colspan="3" class="text-center text-muted py-3">No blocks found.</td></tr>');
                    }
                },
                error: function () {
                    $('#blocksTableBody').html('<tr><td colspan="3" class="text-center text-danger py-3">Error loading blocks.</td></tr>');
                }
            });
        }

        function editBlock(id, name, floors) {
            $('#blockId').val(id);
            $('#blockName').val(name);
            $('#blockFloors').val(floors);
            $('#btnSaveBlock').html('<i class="fa-solid fa-save me-1"></i> Update').removeClass('btn-primary').addClass('btn-success');
        }

        function saveBlock() {
            var id = $('#blockId').val();
            var name = $('#blockName').val();
            var floors = $('#blockFloors').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            if (!name || !floors) return;

            $.ajax({
                url: '/Flat/UpsertBlock',
                type: 'POST',
                data: {
                    BlockId: id,
                    BlockName: name,
                    TotalFloors: floors,
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        resetBlockForm();
                        loadBlocks();
                    } else {
                        Swal.fire('Error!', res.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                }
            });
        }

        function deleteBlock(id, name) {
            Swal.fire({
                title: 'Delete Block?',
                text: `Are you sure you want to delete ${name}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Flat/DeleteBlock/' + id,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                loadBlocks();
                            } else {
                                Swal.fire('Cannot Delete!', res.message, 'warning');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
