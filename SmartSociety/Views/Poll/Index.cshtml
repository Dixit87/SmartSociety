@model IEnumerable<SmartSociety.Models.Poll>

@{
    ViewData["Title"] = "Polls & Voting";
    var activePolls = Model.Where(p => p.Status == "Active").ToList();
    var closedPolls = Model.Where(p => p.Status == "Closed").ToList();
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<style>
    .progress { height: 25px; border-radius: 12px; background-color: #f1f3f5; }
    .progress-bar { font-weight: 600; line-height: 25px; }
    .poll-option-input { border-radius: 8px; border: 1px solid #dee2e6; }
    .option-list { max-height: 300px; overflow-y: auto; overflow-x: hidden; }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Admin</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Polls & Voting</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1 text-dark"><i class="fa-solid fa-check-to-slot text-primary me-2"></i> Polls & Voting</h2>
        <p class="text-muted mb-0">Create surveys and track resident votes in real-time.</p>
    </div>
    <button class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm" onclick="openCreatePollModal()">
        <i class="fa-solid fa-plus me-2"></i> Create Poll
    </button>
</div>

<!-- Active Polls Section -->
<h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-bolt text-warning me-2"></i> Active Polls</h5>
<div class="row g-4 mb-5">
    @if (!activePolls.Any())
    {
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 bg-light">
                <div class="card-body text-center py-5">
                    <i class="fa-regular fa-folder-open fa-3x text-muted mb-3"></i>
                    <h5 class="fw-bold text-muted">No active polls</h5>
                    <p class="text-muted">Click 'Create Poll' to start a new survey.</p>
                </div>
            </div>
        </div>
    }
    @foreach (var p in activePolls)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 position-relative">
                <div class="position-absolute top-0 end-0 mt-3 me-3">
                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-spinner fa-spin me-1"></i> Live</span>
                </div>
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-2 mt-2 pe-5">@p.Question</h5>
                    @if (!string.IsNullOrEmpty(p.Description))
                    {
                        <p class="small text-muted mb-3 line-clamp-2">@p.Description</p>
                    }
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div class="small fw-semibold text-muted">
                            <i class="fa-solid fa-users me-1"></i> @p.TotalVotes Votes
                        </div>
                        <div class="small fw-bold text-danger">
                            <i class="fa-regular fa-clock me-1"></i> Ends: @p.EndDate.ToString("dd MMM yy")
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 p-3 pt-0 d-flex gap-2">
                    <button class="btn btn-light text-primary fw-bold w-100 rounded-pill" onclick="viewResults(@p.PollId, '@Uri.EscapeDataString(p.Question)')">
                        <i class="fa-solid fa-chart-pie me-1"></i> View Results
                    </button>
                    <button class="btn btn-outline-danger btn-sm rounded-circle px-3" title="Delete Poll" onclick="deletePoll(@p.PollId)">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Closed Polls Table -->
<h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-box-archive text-secondary me-2"></i> Closed Polls History</h5>
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <table class="table table-hover align-middle w-100" id="pollsTable">
            <thead class="table-light">
                <tr>
                    <th class="fw-semibold text-muted py-3">Poll Question</th>
                    <th class="fw-semibold text-muted py-3">Start Date</th>
                    <th class="fw-semibold text-muted py-3">End Date</th>
                    <th class="fw-semibold text-muted py-3">Total Votes</th>
                    <th class="fw-semibold text-muted py-3 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in closedPolls)
                {
                    <tr>
                        <td class="py-3">
                            <h6 class="fw-bold text-dark mb-1">@p.Question</h6>
                        </td>
                        <td class="py-3 text-muted small fw-semibold">@p.StartDate.ToString("dd MMM yyyy")</td>
                        <td class="py-3 text-muted small fw-semibold">@p.EndDate.ToString("dd MMM yyyy")</td>
                        <td class="py-3"><span class="badge bg-secondary-subtle text-secondary-emphasis px-3 py-2 rounded-pill">@p.TotalVotes Votes</span></td>
                        <td class="py-3 text-end">
                            <div class="btn-group shadow-sm">
                                <button type="button" class="btn btn-light btn-sm text-primary" title="View Results"
                                        onclick="viewResults(@p.PollId, '@Uri.EscapeDataString(p.Question)')">
                                    <i class="fa-solid fa-chart-pie"></i>
                                </button>
                                <button type="button" class="btn btn-light btn-sm text-danger" title="Delete Poll" 
                                        onclick="deletePoll(@p.PollId)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Create Poll Modal -->
<div class="modal fade" id="pollModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="pollModalTitle"><i class="fa-solid fa-plus-circle me-2"></i> Create New Poll</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="pollForm" onsubmit="event.preventDefault(); submitPoll();">
                    <h6 class="fw-bold text-dark mb-3 border-bottom pb-2">Poll Details</h6>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted mb-1">Question <span class="text-danger">*</span></label>
                        <input type="text" id="pQuestion" name="Question" class="form-control bg-light border-0 py-2 fs-5 fw-semibold" required placeholder="What do you want to ask the residents?" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted mb-1">Description (Optional)</label>
                        <textarea id="pDesc" name="Description" class="form-control bg-light border-0 py-2" rows="2" placeholder="Provide any additional context here..."></textarea>
                    </div>
                    <div class="mb-4 w-50">
                        <label class="form-label fw-semibold small text-muted mb-1">End Date <span class="text-danger">*</span></label>
                        <input type="date" id="pEndDate" name="EndDate" class="form-control bg-light border-0 py-2" required />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                        <h6 class="fw-bold text-info mb-0">Voting Options</h6>
                        <button type="button" class="btn btn-sm btn-outline-info rounded-pill fw-bold" onclick="addOptionField()">
                            <i class="fa-solid fa-plus"></i> Add Option
                        </button>
                    </div>
                    
                    <div id="optionsContainer" class="option-list px-2 py-2">
                        <!-- Options will be appended here -->
                    </div>
                    
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitPoll">
                            <i class="fa-solid fa-paper-plane me-2"></i> Publish Poll
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Results & Mock Vote Modal -->
<div class="modal fade" id="resultsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-dark text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-chart-bar me-2"></i> Poll Results</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <h4 class="fw-bold text-dark mb-1" id="resQuestion">Loading...</h4>
                <p class="text-muted small mb-4" id="resTotalVotes">Total Votes: 0</p>
                
                <div id="resultsContainer" class="mb-4">
                    <div class="text-center py-4 text-muted"><i class="fa-solid fa-spinner fa-spin fa-2x"></i></div>
                </div>

                <div class="alert alert-warning border-0 shadow-sm rounded-3 mt-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="fa-solid fa-flask text-warning fs-4 me-2"></i>
                        <h6 class="fw-bold text-dark mb-0">Testing Area: Mock Vote</h6>
                    </div>
                    <p class="small text-muted mb-2">Since the Resident Portal is not connected yet, use this area to cast fake votes and see the charts update live.</p>
                    <div id="mockVoteContainer" class="d-flex flex-wrap gap-2">
                        <!-- Mock vote buttons -->
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold w-100" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        var pollModal, resultsModal;
        var optionCount = 0;

        $(document).ready(function () {
            $('#pollsTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": { "search": "", "searchPlaceholder": "Search past polls..." },
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
            });
            
            $('.dataTables_filter input').addClass('form-control form-control-sm border-0 shadow-sm bg-light').css('width', '250px');

            pollModal = new bootstrap.Modal(document.getElementById('pollModal'));
            resultsModal = new bootstrap.Modal(document.getElementById('resultsModal'));
        });

        function openCreatePollModal() {
            $('#pollForm')[0].reset();
            $('#pEndDate').val(new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0]); // Default 7 days
            $('#optionsContainer').empty();
            optionCount = 0;
            // Add 2 default options
            addOptionField();
            addOptionField();
            pollModal.show();
        }

        function addOptionField() {
            if (optionCount >= 10) {
                Swal.fire({ toast: true, position: 'top-end', icon: 'warning', title: 'Maximum 10 options allowed', showConfirmButton: false, timer: 2000 });
                return;
            }
            optionCount++;
            var html = `
                <div class="input-group mb-2 option-row" id="optRow_${optionCount}">
                    <span class="input-group-text bg-light border-0 text-muted fw-bold">${optionCount}.</span>
                    <input type="text" class="form-control bg-light border-0 py-2 poll-option-input" placeholder="Option text..." required />
                    <button class="btn btn-light text-danger px-3 border-0" type="button" onclick="removeOptionField(${optionCount})"><i class="fa-solid fa-xmark"></i></button>
                </div>
            `;
            $('#optionsContainer').append(html);
        }

        function removeOptionField(id) {
            if ($('.option-row').length <= 2) {
                Swal.fire({ toast: true, position: 'top-end', icon: 'warning', title: 'Minimum 2 options required', showConfirmButton: false, timer: 2000 });
                return;
            }
            $('#optRow_' + id).remove();
            // Re-number
            var count = 1;
            $('.option-row .input-group-text').each(function() {
                $(this).text(count + '.');
                count++;
            });
            optionCount = count - 1;
        }

        function submitPoll() {
            var options = [];
            $('.poll-option-input').each(function() {
                if ($(this).val().trim() !== '') {
                    options.push($(this).val().trim());
                }
            });

            if (options.length < 2) {
                Swal.fire('Error', 'Please provide at least 2 valid options.', 'error');
                return;
            }

            var data = {
                Question: $('#pQuestion').val(),
                Description: $('#pDesc').val(),
                EndDate: $('#pEndDate').val(),
                Options: options
            };

            $('#btnSubmitPoll').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Publishing...');

            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/Poll/CreatePoll',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                headers: { "RequestVerificationToken": token },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitPoll').prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i> Publish Poll');
                    }
                }
            });
        }

        function deletePoll(id) {
            Swal.fire({
                title: 'Delete Poll?',
                text: "This will delete the poll and all associated votes. Cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Poll/DeletePoll',
                        type: 'POST',
                        data: { pollId: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => window.location.reload(), 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        // --- RESULTS & MOCK VOTING ---
        var currentPollId = 0;
        
        function viewResults(pollId, question) {
            currentPollId = pollId;
            $('#resQuestion').text(decodeURIComponent(question));
            $('#resTotalVotes').text('Loading...');
            $('#resultsContainer').html('<div class="text-center py-4 text-muted"><i class="fa-solid fa-spinner fa-spin fa-2x"></i></div>');
            $('#mockVoteContainer').empty();
            
            resultsModal.show();
            loadResults(pollId);
        }

        function loadResults(pollId) {
            $.get('/Poll/GetPollResults?pollId=' + pollId, function(res) {
                if(res.success && res.data) {
                    var poll = res.data;
                    $('#resTotalVotes').text('Total Votes: ' + poll.totalVotes);
                    
                    var colors = ['bg-primary', 'bg-success', 'bg-info', 'bg-warning', 'bg-danger', 'bg-secondary'];
                    var html = '';
                    var mockHtml = '';
                    
                    poll.options.forEach(function(opt, index) {
                        var color = colors[index % colors.length];
                        
                        // Progress Bar HTML
                        html += `
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold text-dark">${opt.optionText}</span>
                                    <span class="fw-bold text-muted">${opt.votePercentage}% (${opt.voteCount})</span>
                                </div>
                                <div class="progress shadow-sm">
                                    <div class="progress-bar ${color} progress-bar-striped progress-bar-animated" role="progressbar" style="width: ${opt.votePercentage}%" aria-valuenow="${opt.votePercentage}" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        `;
                        
                        // Mock Vote Button HTML
                        mockHtml += `
                            <button class="btn btn-outline-dark btn-sm rounded-pill fw-semibold" onclick="castMockVote(${poll.pollId}, ${opt.optionId})">
                                Vote: ${opt.optionText}
                            </button>
                        `;
                    });
                    
                    $('#resultsContainer').html(html);
                    
                    if(poll.status === 'Active') {
                        $('#mockVoteContainer').html(mockHtml);
                    } else {
                        $('#mockVoteContainer').html('<span class="badge bg-secondary">Poll is Closed</span>');
                    }
                }
            });
        }

        function castMockVote(pollId, optionId) {
            var token = $('input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Poll/MockVote',
                type: 'POST',
                data: { pollId: pollId, optionId: optionId, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        // Reload the results dynamically
                        loadResults(pollId);
                    } else {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'error', title: res.message, showConfirmButton: false, timer: 2000 });
                    }
                }
            });
        }
    </script>
}
