@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
    
    <script>
        var entryModal;
        var verifyInviteModal;
        var logDeliveryModal;
        var childExitModal;
        var staffHistoryModal;
        var html5QrCode = null;

        $(document).ready(function () {
            $('#visitorTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search visitors..."
                }
            });

            $('#deliveryTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search deliveries..."
                }
            });

            $('#staffTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search staff..."
                }
            });
            
            entryModal = new bootstrap.Modal(document.getElementById('newEntryModal'));
            verifyInviteModal = new bootstrap.Modal(document.getElementById('verifyInviteModal'));
            logDeliveryModal = new bootstrap.Modal(document.getElementById('logDeliveryModal'));
            childExitModal = new bootstrap.Modal(document.getElementById('childExitModal'));
            staffHistoryModal = new bootstrap.Modal(document.getElementById('staffHistoryModal'));

            // Clean up QR Scanner when modal is closed
            document.getElementById('verifyInviteModal').addEventListener('hidden.bs.modal', function () {
                stopQRScanner();
            });

            // Clean up QR Scanner when switching to Manual tab
            document.getElementById('manual-tab').addEventListener('shown.bs.tab', function () {
                stopQRScanner();
            });

            // Automatically query cameras and start scanner when switching to Scan tab
            document.getElementById('qr-tab').addEventListener('shown.bs.tab', function () {
                initAndStartQRScanner();
            });

            $('#qr-camera-select').change(function() {
                if (html5QrCode && html5QrCode.isScanning) {
                    html5QrCode.stop().then(() => {
                        startQRScanner();
                    });
                } else {
                    startQRScanner();
                }
            });
            
            loadFlats();

            $('#ChildExitFlatId').change(function() {
                var flatId = $(this).val();
                loadChildrenForFlat(flatId);
            });
        });

        function loadFlats() {
            $.ajax({
                url: '/Visitor/GetFlatsDropdown',
                type: 'GET',
                success: function (res) {
                    var select = $('#FlatId');
                    var delivSelect = $('#DelivFlatId');
                    var childExitSelect = $('#ChildExitFlatId');
                    
                    select.empty();
                    delivSelect.empty();
                    childExitSelect.empty();
                    
                    select.append('<option value="">-- Select Flat --</option>');
                    delivSelect.append('<option value="">-- Select Flat --</option>');
                    childExitSelect.append('<option value="">-- Select Flat --</option>');
                    
                    res.forEach(function (f) {
                        var option = `<option value="${f.value}">${f.text}</option>`;
                        select.append(option);
                        delivSelect.append(option);
                        childExitSelect.append(option);
                    });
                }
            });
        }

        function openNewEntryModal() {
            $('#entryForm')[0].reset();
            entryModal.show();
        }

        function openVerifyInviteModal() {
            $('#verifyInviteForm')[0].reset();
            if (document.getElementById('manual-tab')) {
                var manualTab = new bootstrap.Tab(document.getElementById('manual-tab'));
                manualTab.show();
            }
            stopQRScanner();
            verifyInviteModal.show();
        }

        function openLogDeliveryModal() {
            $('#deliveryForm')[0].reset();
            logDeliveryModal.show();
        }

        function openChildExitModal() {
            $('#childExitForm')[0].reset();
            $('#ChildExitChildId').empty().append('<option value="">-- Select Flat First --</option>');
            childExitModal.show();
        }

        function loadChildrenForFlat(flatId) {
            var select = $('#ChildExitChildId');
            select.empty();
            select.append('<option value="">Loading children...</option>');
            if (!flatId) {
                select.empty();
                select.append('<option value="">-- Select Flat First --</option>');
                return;
            }
            $.ajax({
                url: '/Visitor/GetChildrenForFlat',
                type: 'GET',
                data: { flatId: flatId },
                success: function (res) {
                    select.empty();
                    if (res.success) {
                        if (res.data.length === 0) {
                            select.append('<option value="">No children registered for this flat</option>');
                        } else {
                            select.append('<option value="">-- Select Child --</option>');
                            res.data.forEach(function (child) {
                                select.append(`<option value="${child.familyMemberId}">${child.fullName}</option>`);
                            });
                        }
                    } else {
                        select.append('<option value="">Error loading children</option>');
                    }
                },
                error: function() {
                    select.empty();
                    select.append('<option value="">Error loading children</option>');
                }
            });
        }

        function submitChildExitRequest() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var flatId = $('#ChildExitFlatId').val();
            var familyMemberId = $('#ChildExitChildId').val();
            var guardRemarks = $('#ChildExitRemarks').val();

            if (!flatId || !familyMemberId) {
                Swal.fire('Error', 'Please select both Flat and Child.', 'error');
                return;
            }

            $('#btnSubmitChildExit').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Logging...');

            $.ajax({
                url: '/Visitor/LogChildExitRequest',
                type: 'POST',
                data: {
                    flatId: flatId,
                    familyMemberId: familyMemberId,
                    guardRemarks: guardRemarks,
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        childExitModal.hide();
                        Swal.fire({
                            icon: 'success',
                            title: 'Exit Request Logged!',
                            text: res.message,
                            showConfirmButton: false,
                            timer: 2000
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Error', res.message, 'error');
