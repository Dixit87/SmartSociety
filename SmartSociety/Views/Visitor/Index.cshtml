@model IEnumerable<SmartSociety.Models.Visitor>

@{
    ViewData["Title"] = "Visitor Logs";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Gate Security</li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Visitor Logs</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Gate Visitor Logs</h2>
        <p class="text-muted mb-0">Track incoming guests, deliveries, and vendors.</p>
    </div>
    <div class="d-flex gap-2">
        <form asp-action="History" method="get" class="d-flex gap-2 align-items-center bg-white p-1 rounded-pill shadow-sm border me-3">
            <input type="date" name="startDate" class="form-control form-control-sm border-0 bg-transparent" value="@ViewBag.StartDate" />
            <span class="text-muted small">to</span>
            <input type="date" name="endDate" class="form-control form-control-sm border-0 bg-transparent" value="@ViewBag.EndDate" />
            <button type="submit" class="btn btn-sm btn-light rounded-pill px-3"><i class="fa-solid fa-filter text-muted"></i></button>
            @if(ViewBag.StartDate != null) {
                <a asp-action="Index" class="btn btn-sm btn-light rounded-pill px-2 text-danger" title="Clear Filter"><i class="fa-solid fa-xmark"></i></a>
            }
        </form>

        <button type="button" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm" onclick="openNewEntryModal()">
            <i class="fa-solid fa-person-walking-arrow-right me-2"></i> New Visitor Entry
        </button>
    </div>
</div>

<!-- Gatekeeping Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="bg-white rounded-4 shadow-sm p-4 border-start border-primary border-4 h-100 d-flex flex-column justify-content-between">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; min-width: 50px;">
                    <i class="fa-solid fa-key fa-lg"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1 fs-6">Invite Verification</h5>
                    <p class="text-muted small mb-0">Verify 6-digit invite passcodes from pre-approved guests.</p>
                </div>
            </div>
            <div class="text-end">
                <button class="btn btn-primary rounded-pill px-4 btn-sm" onclick="openVerifyInviteModal()">
                    <i class="fa-solid fa-shield-check me-1"></i> Verify Guest Pass
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-4 shadow-sm p-4 border-start border-warning border-4 h-100 d-flex flex-column justify-content-between">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-warning bg-opacity-10 text-warning-emphasis rounded-circle p-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; min-width: 50px;">
                    <i class="fa-solid fa-truck-ramp-box fa-lg"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1 fs-6">Gate Delivery Log</h5>
                    <p class="text-muted small mb-0">Record incoming courier packages and alert residents.</p>
                </div>
            </div>
            <div class="text-end">
                <button class="btn btn-warning rounded-pill px-4 btn-sm text-dark fw-semibold" onclick="openLogDeliveryModal()">
                    <i class="fa-solid fa-box-archive me-1"></i> Log New Parcel
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-white rounded-4 shadow-sm p-4 border-start border-danger border-4 h-100 d-flex flex-column justify-content-between">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; min-width: 50px;">
                    <i class="fa-solid fa-child-reaching fa-lg"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1 fs-6">Child Safety Exit Request</h5>
                    <p class="text-muted small mb-0">Verify unaccompanied child departures and alert parents.</p>
                </div>
            </div>
            <div class="text-end">
                <button class="btn btn-danger rounded-pill px-4 btn-sm text-white fw-semibold" onclick="openChildExitModal()">
                    <i class="fa-solid fa-shield-cat me-1"></i> Trigger Exit Alert
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Active Child Exit Requests (Today) -->
@if (ViewBag.ChildRequests != null && ((IEnumerable<SmartSociety.Models.ChildExitRequest>)ViewBag.ChildRequests).Any())
{
    <div class="card border-0 rounded-4 shadow-sm p-4 mb-4 bg-light">
        <h6 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-child fa-lg me-2 text-danger"></i> Unaccompanied Child Exit Requests (Today)</h6>
        <div class="row g-3">
            @foreach (var req in (IEnumerable<SmartSociety.Models.ChildExitRequest>)ViewBag.ChildRequests)
            {
                <div class="col-md-4">
                    <div class="bg-white rounded-4 p-3 shadow-sm border border-2 @(req.Status == "Pending" ? "border-warning" : req.Status == "Approved" ? "border-success" : "border-danger")">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge @(req.Status == "Pending" ? "bg-warning-subtle text-warning-emphasis" : req.Status == "Approved" ? "bg-success-subtle text-success-emphasis" : "bg-danger-subtle text-danger-emphasis") rounded-pill px-3 py-1 fw-bold">
                                @req.Status
                            </span>
                            <small class="text-muted"><i class="fa-solid fa-clock me-1"></i> @req.CreatedAt.ToString("hh:mm tt")</small>
                        </div>
                        <h6 class="fw-bold mb-1 text-dark">@req.ChildName</h6>
                        <p class="text-muted small mb-2">Flat: @req.BlockName - @req.FlatNumber</p>
                        @if(!string.IsNullOrEmpty(req.GuardRemarks))
                        {
                            <p class="text-muted small fst-italic mb-2">"@req.GuardRemarks"</p>
                        }
                        <div class="border-top pt-2 mt-2 d-flex justify-content-between align-items-center">
                            <small class="text-muted">Parent Action:</small>
                            @if(req.Status == "Pending")
                            {
                                <span class="text-warning small fw-bold"><i class="fa-solid fa-hourglass-half me-1"></i> Awaiting App Approval</span>
                            }
                            else if(req.Status == "Approved")
                            {
                                <span class="text-success small fw-bold"><i class="fa-solid fa-circle-check me-1"></i> Exit Allowed</span>
                            }
                            else
                            {
                                <span class="text-danger small fw-bold"><i class="fa-solid fa-circle-xmark me-1"></i> Stop Child!</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- Dashboard Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="bg-primary bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-users fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Total</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.TotalToday</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-info bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-info text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-clock-rotate-left fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Pending Approval</p>
                <h4 class="fw-bold text-dark mb-0">@(ViewBag.Pending ?? 0)</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-warning bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-warning text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-hourglass-half fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Inside</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.Inside</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="bg-success bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center">
            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 48px; height: 48px;">
                <i class="fa-solid fa-person-walking-dashed-line-arrow-right fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0">Exited</p>
                <h4 class="fw-bold text-dark mb-0">@ViewBag.Exited</h4>
            </div>
        </div>
    </div>
</div>

<style>
    #pills-tab .nav-link {
        background-color: #ffffff;
        color: #212529;
        border: 1px solid #dee2e6;
        transition: all 0.2s ease;
    }
    #pills-tab .nav-link:hover {
        background-color: #f8f9fa;
        color: #000000;
    }
    #pills-tab .nav-link.active {
        background-color: #0d6efd !important;
        color: #ffffff !important;
        border-color: #0d6efd;
    }
    .scanner-laser {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(to right, rgba(25, 135, 84, 0), rgba(25, 135, 84, 0.8), rgba(25, 135, 84, 0));
        box-shadow: 0 0 10px #198754;
        animation: scanner-sweep 2.5s linear infinite;
        pointer-events: none;
        z-index: 10;
    }
    @@keyframes scanner-sweep {
        0% { top: 0%; }
        50% { top: 100%; }
        100% { top: 0%; }
    }
    #qr-reader {
        border: none !important;
    }
    #qr-reader video {
        object-fit: cover !important;
        width: 100% !important;
        height: 100% !important;
    }
    #inviteVerifyTabs .nav-link {
        color: #495057;
        background: transparent;
        border: none;
    }
    #inviteVerifyTabs .nav-link.active {
        color: #fff !important;
        background-color: #0d6efd !important;
    }
</style>

<ul class="nav nav-pills mb-4" id="pills-tab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold px-4 py-2.5 rounded-pill shadow-sm" id="pills-visitors-tab" data-bs-toggle="pill" data-bs-target="#pills-visitors" type="button" role="tab" aria-controls="pills-visitors" aria-selected="true">
            <i class="fa-solid fa-users-viewfinder me-2"></i> Visitor Logs
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold px-4 py-2.5 rounded-pill ms-2 shadow-sm text-dark bg-white border border-light" id="pills-deliveries-tab" data-bs-toggle="pill" data-bs-target="#pills-deliveries" type="button" role="tab" aria-controls="pills-deliveries" aria-selected="false">
            <i class="fa-solid fa-box-open me-2 text-warning"></i> Deliveries at Gate
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold px-4 py-2.5 rounded-pill ms-2 shadow-sm text-dark bg-white border border-light" id="pills-staff-tab" data-bs-toggle="pill" data-bs-target="#pills-staff" type="button" role="tab" aria-controls="pills-staff" aria-selected="false">
            <i class="fa-solid fa-user-check me-2 text-success"></i> Daily Staff Attendance
        </button>
    </li>
</ul>

<div class="tab-content" id="pills-tabContent">
    <div class="tab-pane fade show active" id="pills-visitors" role="tabpanel" aria-labelledby="pills-visitors-tab">
        <div class="bg-white rounded-4 shadow-sm p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="visitorTable">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 border-0 rounded-start">Visitor Info</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Visiting Flat</th>
                            <th class="text-secondary fw-semibold py-3 border-0">In-Time</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Status</th>
                            <th class="text-end text-secondary fw-semibold py-3 border-0 rounded-end">Action</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var visitor in Model)
                            {
                                <tr class="@(visitor.IsOverstaying ? "bg-danger bg-opacity-10" : "")">
                                    <td class="py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle d-flex justify-content-center align-items-center text-muted me-3" style="width: 45px; height: 45px;">
                                                @if(visitor.VisitorType == "Guest") { <i class="fa-solid fa-user-group fa-lg"></i> }
                                                else if(visitor.VisitorType == "Delivery") { <i class="fa-solid fa-box fa-lg"></i> }
                                                else if(visitor.VisitorType == "Maid/Helper") { <i class="fa-solid fa-broom fa-lg"></i> }
                                                else { <i class="fa-solid fa-id-badge fa-lg"></i> }
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold text-dark">@visitor.FullName</h6>
                                                <div class="small text-muted"><i class="fa-solid fa-phone fa-sm me-1"></i> @visitor.PhoneNumber</div>
                                                <span class="badge bg-secondary-subtle text-secondary px-2 py-0 mt-1">@visitor.VisitorType</span>
                                                @if(!string.IsNullOrEmpty(visitor.InviteCode))
                                                {
                                                    <span class="badge bg-primary bg-opacity-10 text-primary px-2 py-0 mt-1 ms-1"><i class="fa-solid fa-key me-1"></i> Invite: @visitor.InviteCode</span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@visitor.BlockName - @visitor.FlatNumber</div>
                                        @if(!string.IsNullOrEmpty(visitor.Purpose))
                                        {
                                            <div class="text-muted small fst-italic">"@visitor.Purpose"</div>
                                        }
                                        @if(!string.IsNullOrEmpty(visitor.VehicleNumber))
                                        {
                                            <div class="text-muted small mt-1"><i class="fa-solid fa-car-side fa-sm me-1"></i> @visitor.VehicleNumber</div>
                                        }
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-medium">@visitor.InTime.ToString("hh:mm tt")</div>
                                        <div class="small text-muted">@visitor.InTime.ToString("dd MMM yyyy")</div>
                                    </td>
                                    <td class="py-3">
                                        @if (visitor.Status == "Pending")
                                        {
                                            <span class="badge bg-info-subtle text-info px-2 py-1"><i class="fa-solid fa-clock me-1"></i> Pending Approval</span>
                                        }
                                        else if (visitor.Status == "Inside")
                                        {
                                            if(visitor.IsOverstaying)
                                            {
                                                <span class="badge bg-danger text-white px-2 py-1 shadow-sm"><i class="fa-solid fa-triangle-exclamation me-1"></i> Overstaying</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning px-2 py-1"><i class="fa-solid fa-clock me-1"></i> Inside</span>
                                            }
                                        }
                                        else if (visitor.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-2 py-1"><i class="fa-solid fa-xmark me-1"></i> Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success px-2 py-1"><i class="fa-solid fa-check-double me-1"></i> Exited</span>
                                            <div class="small text-muted mt-1">@visitor.OutTime?.ToString("hh:mm tt")</div>
                                        }
                                    </td>
                                    <td class="py-3 text-end">
                                        @if (visitor.Status == "Pending")
                                        {
                                            <div class="d-flex gap-1 justify-content-end">
                                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-semibold shadow-sm" onclick="approveVisitor(@visitor.VisitorId, '@visitor.FullName')" title="Approve Entry">
                                                    <i class="fa-solid fa-check"></i> Approve
                                                </button>
                                                <button class="btn btn-sm btn-danger rounded-pill px-3 fw-semibold shadow-sm" onclick="rejectVisitor(@visitor.VisitorId, '@visitor.FullName')" title="Reject Entry">
                                                    <i class="fa-solid fa-xmark"></i> Reject
                                                </button>
                                            </div>
                                        }
                                        else if (visitor.Status == "Inside")
                                        {
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold shadow-sm" onclick="checkoutVisitor(@visitor.VisitorId, '@visitor.FullName')">
                                                <i class="fa-solid fa-person-walking-arrow-right me-1"></i> Checkout
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="tab-pane fade" id="pills-deliveries" role="tabpanel" aria-labelledby="pills-deliveries-tab">
        <div class="bg-white rounded-4 shadow-sm p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="deliveryTable" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 border-0 rounded-start">Courier Info</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Visiting Flat</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Delivery Agent</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Receipt Photo</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Logged At</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Status</th>
                            <th class="text-end text-secondary fw-semibold py-3 border-0 rounded-end">Collected At</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (ViewBag.Deliveries != null && ((IEnumerable<SmartSociety.Models.Delivery>)ViewBag.Deliveries).Any())
                        {
                            foreach (var delivery in (IEnumerable<SmartSociety.Models.Delivery>)ViewBag.Deliveries)
                            {
                                <tr>
                                    <td class="py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-warning bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center text-warning me-3" style="width: 45px; height: 45px;">
                                                <i class="fa-solid fa-box fa-lg"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold text-dark">@delivery.Company</h6>
                                                <span class="badge bg-warning-subtle text-warning-emphasis px-2 py-0 mt-1">Parcel</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@delivery.BlockName - @delivery.FlatNumber</div>
                                        <div class="text-muted small">Resident: @delivery.ResidentName</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-semibold text-dark">@delivery.DeliveryAgentName</div>
                                        <div class="small text-muted"><i class="fa-solid fa-phone fa-sm me-1"></i> @delivery.DeliveryAgentPhone</div>
                                    </td>
                                    <td class="py-3">
                                        @if (!string.IsNullOrEmpty(delivery.ReceiptPhoto))
                                        {
                                            <a href="@delivery.ReceiptPhoto" target="_blank" class="btn btn-sm btn-light border rounded-pill px-3">
                                                <i class="fa-solid fa-image me-1 text-primary"></i> View Photo
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">No Photo</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-medium">@delivery.LoggedAt.ToString("hh:mm tt")</div>
                                        <div class="small text-muted">@delivery.LoggedAt.ToString("dd MMM yyyy")</div>
                                    </td>
                                    <td class="py-3">
                                        @if (delivery.Status == "LoggedAtGate")
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle px-2 py-1"><i class="fa-solid fa-clock me-1"></i> At Gate</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1"><i class="fa-solid fa-check-double me-1"></i> Collected</span>
                                        }
                                    </td>
                                    <td class="py-3 text-end">
                                        @if (delivery.CollectedAt.HasValue)
                                        {
                                            <div class="fw-medium text-dark">@delivery.CollectedAt.Value.ToString("hh:mm tt")</div>
                                            <div class="small text-muted">@delivery.CollectedAt.Value.ToString("dd MMM yyyy")</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">Awaiting Collection</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="pills-staff" role="tabpanel" aria-labelledby="pills-staff-tab">
        <div class="bg-white rounded-4 shadow-sm p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="staffTable" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary fw-semibold py-3 border-0 rounded-start">Staff Member</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Role</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Shift</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Verification Status</th>
                            <th class="text-secondary fw-semibold py-3 border-0">Today's Status</th>
                            <th class="text-end text-secondary fw-semibold py-3 border-0 rounded-end">Attendance Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (ViewBag.StaffWithAttendance != null)
                        {
                            foreach (var item in ViewBag.StaffWithAttendance)
                            {
                                var staff = item.Staff;
                                var attendance = item.TodayAttendance;
                                <tr>
                                    <td class="py-3">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(staff.PhotoPath))
                                            {
                                                <img src="@staff.PhotoPath" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;" alt="@staff.FullName" />
                                            }
                                            else
                                            {
                                                <div class="bg-info bg-opacity-10 text-info rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 45px; height: 45px; min-width: 45px;">
                                                    <i class="fa-solid fa-user fa-lg"></i>
                                                </div>
                                            }
                                            <div>
                                                <h6 class="mb-0 fw-bold text-dark">@staff.FullName</h6>
                                                <div class="small text-muted"><i class="fa-solid fa-phone fa-sm me-1"></i> @staff.ContactNumber</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge bg-info bg-opacity-10 text-info px-2 py-1">@staff.Role</span>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-medium text-dark">
                                            @staff.ShiftStart.ToString(@"hh\:mm") - @staff.ShiftEnd.ToString(@"hh\:mm")
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        @if (staff.IsVerified)
                                        {
                                            <span class="text-success fw-semibold"><i class="fa-solid fa-circle-check me-1"></i> Verified</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted"><i class="fa-solid fa-circle-minus me-1"></i> Pending</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        @if (attendance == null)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary px-2 py-1"><i class="fa-solid fa-circle-exclamation me-1"></i> Not Present</span>
                                        }
                                        else if (attendance.CheckInTime != null && attendance.CheckOutTime == null)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1"><i class="fa-solid fa-right-to-bracket me-1"></i> In (Checked-in @(((TimeSpan)attendance.CheckInTime).ToString(@"hh\:mm")))</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1"><i class="fa-solid fa-right-from-bracket me-1"></i> Out (Checked-out @(((TimeSpan)attendance.CheckOutTime).ToString(@"hh\:mm")))</span>
                                        }
                                    </td>
                                    <td class="py-3 text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            @if (attendance == null)
                                            {
                                                <button class="btn btn-sm btn-success rounded-pill px-3 fw-semibold shadow-sm" onclick="clockStaff(@staff.StaffId, 'IN')">
                                                    <i class="fa-solid fa-right-to-bracket me-1"></i> Clock In
                                                </button>
                                            }
                                            else if (attendance.CheckInTime != null && attendance.CheckOutTime == null)
                                            {
                                                <button class="btn btn-sm btn-danger rounded-pill px-3 fw-semibold shadow-sm" onclick="clockStaff(@staff.StaffId, 'OUT')">
                                                    <i class="fa-solid fa-right-from-bracket me-1"></i> Clock Out
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 fw-semibold" disabled>
                                                    <i class="fa-solid fa-check me-1"></i> Completed
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold" onclick="viewStaffAttendanceHistory(@staff.StaffId, '@staff.FullName')">
                                                <i class="fa-solid fa-clock-rotate-left me-1"></i> Log
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

