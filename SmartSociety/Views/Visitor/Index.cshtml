                                <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-semibold" id="btnVerifySubmit">
                                    <i class="fa-solid fa-shield-check me-2"></i> Verify & Approve Entry
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- QR Scan Pane -->
                    <div class="tab-pane fade" id="qr-pane" role="tabpanel" aria-labelledby="qr-tab">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Select Camera</label>
                            <select id="qr-camera-select" class="form-select bg-light border-0 rounded-pill">
                                <option value="">-- Accessing Cameras... --</option>
                            </select>
                        </div>
                        <div class="position-relative mx-auto border rounded-4 bg-dark overflow-hidden mb-3" style="max-width: 320px; aspect-ratio: 1/1; box-shadow: inset 0 0 20px rgba(0,0,0,0.6);">
                            <!-- Scanning Container -->
                            <div id="qr-reader" style="width: 100%; height: 100%;"></div>
                            <!-- Glowing Laser Line Overlay -->
                            <div class="scanner-laser" id="scanner-laser" style="display: none;"></div>
                        </div>
                        <div class="d-flex justify-content-center gap-2 mb-2">
                            <button type="button" class="btn btn-success btn-sm rounded-pill px-4" id="btnStartScan" onclick="startQRScanner()">
                                <i class="fa-solid fa-video me-1"></i> Start Camera
                            </button>
                            <button type="button" class="btn btn-danger btn-sm rounded-pill px-4" id="btnStopScan" onclick="stopQRScanner()" disabled>
                                <i class="fa-solid fa-video-slash me-1"></i> Stop Camera
                            </button>
                        </div>
                        <div class="text-center text-muted small mt-3">
                            <i class="fa-solid fa-info-circle me-1 text-primary"></i> Present guest's invite QR code to verify instantly.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

