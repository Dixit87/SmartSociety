<!-- Verify Invite Code Modal -->
<div class="modal fade" id="verifyInviteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-key me-2"></i> Verify Guest Invite Code</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <!-- Navigation Tabs inside Modal -->
                <ul class="nav nav-pills nav-fill mb-4 p-1 bg-light rounded-pill border" id="inviteVerifyTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold py-2 rounded-pill" id="manual-tab" data-bs-toggle="pill" data-bs-target="#manual-pane" type="button" role="tab" aria-controls="manual-pane" aria-selected="true">
                            <i class="fa-solid fa-keyboard me-1"></i> Manual Code
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold py-2 rounded-pill" id="qr-tab" data-bs-toggle="pill" data-bs-target="#qr-pane" type="button" role="tab" aria-controls="qr-pane" aria-selected="false">
                            <i class="fa-solid fa-qrcode me-1"></i> Scan QR Code
                        </button>
                    </li>
                </ul>

                <div class="tab-content" id="inviteVerifyTabsContent">
                    <!-- Manual Entry Pane -->
                    <div class="tab-pane fade show active" id="manual-pane" role="tabpanel" aria-labelledby="manual-tab">
                        <form id="verifyInviteForm" onsubmit="event.preventDefault(); submitInviteVerification();">
                            <div class="mb-3">
                                <label class="form-label fw-semibold small text-muted mb-1">Enter 6-Digit Invite Pass Code <span class="text-danger">*</span></label>
                                <input type="text" id="InviteCodeInput" class="form-control bg-light border-0 text-center fw-bold fs-4" style="letter-spacing: 5px;" required maxlength="6" placeholder="123456" />
                            </div>
                            <div class="mt-4 pt-3 border-top text-end">
