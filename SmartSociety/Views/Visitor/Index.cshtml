        function initAndStartQRScanner() {
            var select = $('#qr-camera-select');
            select.html('<option value="">Accessing cameras...</option>');
            
            Html5Qrcode.getCameras().then(devices => {
                select.empty();
                if (devices && devices.length) {
                    devices.forEach(device => {
                        select.append(`<option value="${device.id}">${device.label || 'Camera ' + (select.children().length + 1)}</option>`);
                    });
                    
                    // Auto-start scanner
                    startQRScanner();
                } else {
                    select.html('<option value="">No cameras found</option>');
                    Swal.fire('No Camera Detected', 'We could not find any cameras on this device.', 'warning');
                }
            }).catch(err => {
                console.error("Error getting cameras: ", err);
                select.html('<option value="">Permission denied / Error</option>');
                Swal.fire('Camera Permission Error', 'Please grant camera access permission to scan QR codes.', 'error');
            });
        }

        function startQRScanner() {
            var cameraId = $('#qr-camera-select').val();
            if (!cameraId) {
                Swal.fire('Camera Error', 'Please select a valid camera.', 'error');
                return;
            }
            if (html5QrCode === null) {
                html5QrCode = new Html5Qrcode("qr-reader");
            }
            
            $('#scanner-laser').show();
            $('#btnStartScan').prop('disabled', true);
            $('#btnStopScan').prop('disabled', false);

            html5QrCode.start(
                cameraId, 
                {
                    fps: 10,
                    qrbox: { width: 220, height: 220 }
                },
                (decodedText, decodedResult) => {
                    // Try to beep
                    try {
                        if (typeof AudioContext !== "undefined" || typeof webkitAudioContext !== "undefined") {
                            var audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                            var oscillator = audioCtx.createOscillator();
                            var gainNode = audioCtx.createGain();
                            oscillator.connect(gainNode);
                            gainNode.connect(audioCtx.destination);
                            oscillator.type = "sine";
                            oscillator.frequency.setValueAtTime(1200, audioCtx.currentTime);
                            gainNode.gain.setValueAtTime(0.15, audioCtx.currentTime);
                            oscillator.start();
                            oscillator.stop(audioCtx.currentTime + 0.12);
                        }
                    } catch (e) {
                        console.log("Audio feedback error: ", e);
                    }
                    
                    stopQRScanner();
                    
                    $('#InviteCodeInput').val(decodedText);
                    
                    // Switch back to manual tab to show the code being submitted
                    var manualTab = new bootstrap.Tab(document.getElementById('manual-tab'));
                    manualTab.show();
                    
                    submitInviteVerification();
                },
                (errorMessage) => {
                    // parse error, ignore
                })
                .catch((err) => {
                    console.error("Unable to start scanning: ", err);
                    Swal.fire('Scan Error', 'Unable to start camera. Please check permissions.', 'error');
                    $('#scanner-laser').hide();
                    $('#btnStartScan').prop('disabled', false);
                    $('#btnStopScan').prop('disabled', true);
                });
        }

        function stopQRScanner() {
            if (html5QrCode && html5QrCode.isScanning) {
                html5QrCode.stop().then(() => {
                    $('#scanner-laser').hide();
                    $('#btnStartScan').prop('disabled', false);
                    $('#btnStopScan').prop('disabled', true);
                }).catch(err => {
                    console.error("Failed to stop scanner: ", err);
                });
            } else {
                $('#scanner-laser').hide();
                $('#btnStartScan').prop('disabled', false);
                $('#btnStopScan').prop('disabled', true);
            }
        }

