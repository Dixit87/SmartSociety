@model SmartSociety.Models.MaintenanceSetting

@{
    ViewData["Title"] = "Maintenance Settings";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Finance</a></li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Billing Settings</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Billing Configuration</h2>
        <p class="text-muted mb-0">Set up standard rates, penalties, and billing cycles.</p>
    </div>
    <a asp-action="Index" class="btn btn-light rounded-pill px-4 shadow-sm border"><i class="fa-solid fa-arrow-left me-2"></i> Back to Bills</a>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Settings" method="post">
                    <h5 class="fw-bold text-dark mb-4 border-bottom pb-2"><i class="fa-solid fa-calculator text-primary me-2"></i> Standard Charges Config</h5>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="BillingType" class="form-label fw-semibold text-muted small">Billing Type</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-scale-unbalanced"></i></span>
                                <select asp-for="BillingType" class="form-select bg-light border-0 py-2">
                                    <option value="Fixed">Fixed Amount per Flat</option>
                                    <option value="PerSqFt">Per Square Foot</option>
                                </select>
                            </div>
                            <span asp-validation-for="BillingType" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="Rate" class="form-label fw-semibold text-muted small">Base Rate (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-indian-rupee-sign"></i></span>
                                <input asp-for="Rate" class="form-control bg-light border-0 py-2" placeholder="e.g. 2500 or 2.5" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="Rate" class="text-danger small"></span>
                            <div class="form-text text-muted mt-1" style="font-size: 0.8rem;">Amount if Fixed, Rate if Per Sq.Ft.</div>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mb-4 border-bottom pb-2 mt-5"><i class="fa-solid fa-gavel text-danger me-2"></i> Penalty & Rules</h5>
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="DueDays" class="form-label fw-semibold text-muted small">Days until Due</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fa-regular fa-calendar-days"></i></span>
                                <input asp-for="DueDays" class="form-control bg-light border-0 py-2" type="number" min="1" max="31" />
                            </div>
                            <span asp-validation-for="DueDays" class="text-danger small"></span>
                            <div class="form-text text-muted mt-1" style="font-size: 0.8rem;">How many days from billing to due date.</div>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="PenaltyAmount" class="form-label fw-semibold text-muted small">Late Payment Penalty (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fa-solid fa-indian-rupee-sign"></i></span>
                                <input asp-for="PenaltyAmount" class="form-control bg-light border-0 py-2" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="PenaltyAmount" class="text-danger small"></span>
                            <div class="form-text text-muted mt-1" style="font-size: 0.8rem;">Fixed penalty added to next bill if unpaid.</div>
                        </div>
                    </div>

                    <div class="mt-5 text-end">
                        <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill shadow-sm fw-semibold">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Save Configuration
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
