@model SmartSociety.Models.MaintenanceReceiptViewModel

@{
    ViewData["Title"] = "Maintenance Tax Invoice";
    Layout = "_Layout";
    var settings = ViewBag.Settings as SmartSociety.Models.MaintenanceSetting;
    var isGstInvoice = Model.Bill.TaxAmount > 0;
}

<style>
    .invoice-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border: none;
    }
    .invoice-header {
        border-bottom: 2px solid #f1f3f7;
    }
    .tax-table th {
        background-color: #f8f9fa !important;
        font-weight: 600;
        color: #495057;
    }
    .badge-paid {
        background-color: #d1e7dd;
        color: #0f5132;
        font-size: 0.9rem;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 600;
    }
    .badge-unpaid {
        background-color: #f8d7da;
        color: #842029;
        font-size: 0.9rem;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 600;
    }
    .badge-partial {
        background-color: #fff3cd;
        color: #664d03;
        font-size: 0.9rem;
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 600;
    }
    .invoice-footer {
        border-top: 2px dashed #e9ecef;
    }
    @@media print {
        body {
            background: #fff;
            color: #000;
        }
        .no-print {
            display: none !important;
        }
        .invoice-card {
            box-shadow: none;
            border: none;
            padding: 0 !important;
        }
        .printable-area {
            width: 100%;
        }
    }
</style>

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <a asp-action="@(User.IsInRole("Resident") ? "MyBills" : "Index")" class="btn btn-light rounded-pill px-4 shadow-sm border"><i class="fa-solid fa-arrow-left me-2"></i> Back to Bills</a>
        <button onclick="window.print()" class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold">
            <i class="fa-solid fa-print me-2"></i> Print Tax Invoice
        </button>
    </div>

    <div class="card invoice-card printable-area">
        <div class="card-body p-5">
            <!-- Header Banner / GST Stamp -->
            <div class="d-flex justify-content-between align-items-start invoice-header pb-4 mb-4 flex-wrap">
                <div>
                    <h2 class="fw-bold text-primary mb-1"><i class="fa-solid fa-building me-2"></i> SmartSociety</h2>
                    <p class="text-muted small mb-1">Registered Address: 123 Premium Lane, Tech City, 400001</p>
                    <p class="text-muted small mb-1">Email: finance@smartsociety.com | Phone: +91 9876543210</p>
                    @if (settings != null && !string.IsNullOrEmpty(settings.Gstin))
                    {
                        <p class="mb-0"><span class="badge bg-dark text-white px-3 py-2 fw-semibold"><i class="fa-solid fa-file-invoice-dollar me-1"></i> Society GSTIN: @settings.Gstin</span></p>
                    }
                </div>
                <div class="text-sm-end mt-3 mt-sm-0">
                    <h3 class="fw-bold text-dark mb-1">@(isGstInvoice ? "TAX INVOICE" : "PAYMENT RECEIPT")</h3>
                    <p class="text-muted mb-1"><strong>Invoice No:</strong> INV/@Model.Bill.BillYear/@Model.Bill.BillMonth.ToString("D2")/@Model.Bill.BillId</p>
                    <p class="text-muted mb-1"><strong>Invoice Date:</strong> @Model.Bill.CreatedAt.ToString("dd MMM yyyy")</p>
                    <p class="text-muted mb-0"><strong>Due Date:</strong> @Model.Bill.DueDate.ToString("dd MMM yyyy")</p>
                </div>
            </div>

            <!-- Bill From / Bill To Grid -->
            <div class="row mb-5">
                <div class="col-md-6 mb-3 mb-md-0">
                    <h6 class="text-uppercase text-muted fw-bold small mb-2">Invoice To:</h6>
                    <h5 class="fw-bold text-dark mb-1">@Model.Bill.OwnerName</h5>
                    <p class="mb-1 text-secondary fw-semibold">Block @Model.Bill.BlockName - Flat @Model.Bill.FlatNumber</p>
                    @if (!string.IsNullOrEmpty(Model.Bill.TenantName))
                    {
                        <p class="text-muted small mb-1">Tenant: @Model.Bill.TenantName</p>
                    }
                    <span class="text-muted small">Resident ID: RES-@Model.Bill.FlatId</span>
                </div>
                <div class="col-md-6 text-md-end">
                    <h6 class="text-uppercase text-muted fw-bold small mb-2">Payment Status:</h6>
                    <div class="mb-3">
                        @if (Model.Bill.Status == "Paid")
                        {
                            <span class="badge-paid"><i class="fa-solid fa-check-circle me-1"></i> FULLY PAID</span>
                        }
                        else if (Model.Bill.Status == "Partial")
                        {
                            <span class="badge-partial"><i class="fa-solid fa-circle-half-stroke me-1"></i> PARTIALLY PAID</span>
                        }
                        else
                        {
                            <span class="badge-unpaid"><i class="fa-solid fa-exclamation-triangle me-1"></i> UNPAID</span>
                        }
                    </div>
                    <p class="text-muted small mb-0"><strong>Billing Month:</strong> @Model.Bill.DisplayMonthYear</p>
                </div>
            </div>

            <!-- Particulars Table -->
            <div class="table-responsive mb-4">
                <table class="table table-bordered tax-table align-middle">
                    <thead>
                        <tr>
                            <th class="text-center" style="width: 60px;">#</th>
                            <th>Description</th>
                            <th class="text-center" style="width: 120px;">SAC Code</th>
                            <th class="text-end" style="width: 150px;">Taxable Value</th>
                            @if (isGstInvoice)
                            {
                                <th class="text-end" style="width: 100px;">CGST</th>
                                <th class="text-end" style="width: 100px;">SGST</th>
                            }
                            <th class="text-end" style="width: 150px;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int itemNo = 1;
                            decimal subtotal = Model.Bill.BaseAmount;
                            decimal cgstAmount = Model.Bill.CGST;
                            decimal sgstAmount = Model.Bill.SGST;
                            decimal totalTax = Model.Bill.TaxAmount;
                        }
                        <tr>
                            <td class="text-center">@(itemNo++)</td>
                            <td>
                                <div class="fw-bold text-dark">Society Maintenance Charges</div>
                                <div class="text-muted small">Billing period: @Model.Bill.DisplayMonthYear</div>
                            </td>
                            <td class="text-center text-muted">999511</td>
                            <td class="text-end">₹@Model.Bill.BaseAmount.ToString("N2")</td>
                            @if (isGstInvoice)
                            {
                                <td class="text-end text-muted">@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                                <td class="text-end text-muted">@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                            }
                            <td class="text-end fw-bold">₹@((Model.Bill.BaseAmount + (isGstInvoice ? Model.Bill.CGST + Model.Bill.SGST : 0)).ToString("N2"))</td>
                        </tr>

                        @if (Model.Bill.ExtraCharges > 0)
                        {
                            subtotal += Model.Bill.ExtraCharges;
                            <tr>
                                <td class="text-center">@(itemNo++)</td>
                                <td>
                                    <div class="fw-bold text-dark">Extra Charges</div>
                                    <div class="text-muted small">@Model.Bill.ExtraChargeRemarks</div>
                                </td>
                                <td class="text-center text-muted">999511</td>
                                <td class="text-end">₹@Model.Bill.ExtraCharges.ToString("N2")</td>
                                @if (isGstInvoice)
                                {
                                    <td class="text-end text-muted">@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                                    <td class="text-end text-muted">@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                                }
                                <td class="text-end fw-bold">₹@((Model.Bill.ExtraCharges + (isGstInvoice ? (Model.Bill.ExtraCharges * (Model.Bill.GstRate / 2 / 100) * 2) : 0)).ToString("N2"))</td>
                            </tr>
                        }

                        @if (Model.Bill.PenaltyAmount > 0)
                        {
                            <tr>
                                <td class="text-center">@(itemNo++)</td>
                                <td>
                                    <div class="fw-bold text-dark">Late Payment Penalty</div>
                                    <div class="text-muted small">Penalty for delay beyond @Model.Bill.DueDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td class="text-center text-muted">-</td>
                                <td class="text-end">₹@Model.Bill.PenaltyAmount.ToString("N2")</td>
                                @if (isGstInvoice)
                                {
                                    <td class="text-end text-muted">-</td>
                                    <td class="text-end text-muted">-</td>
                                }
                                <td class="text-end fw-bold">₹@Model.Bill.PenaltyAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Totals Breakdown Grid -->
            <div class="row justify-content-end mb-4">
                <div class="col-md-5 col-sm-8 text-end">
                    <div class="row mb-2">
                        <div class="col text-muted">Taxable Subtotal:</div>
                        <div class="col-auto fw-semibold text-dark">₹@subtotal.ToString("N2")</div>
                    </div>
                    @if (isGstInvoice)
                    {
                        <div class="row mb-2">
                            <div class="col text-muted">CGST (@((Model.Bill.GstRate / 2).ToString("N1"))%):</div>
                            <div class="col-auto fw-semibold text-dark">₹@cgstAmount.ToString("N2")</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col text-muted">SGST (@((Model.Bill.GstRate / 2).ToString("N1"))%):</div>
                            <div class="col-auto fw-semibold text-dark">₹@sgstAmount.ToString("N2")</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col text-muted">Total Tax (GST):</div>
                            <div class="col-auto fw-semibold text-dark">₹@totalTax.ToString("N2")</div>
                        </div>
                    }
                    @if (Model.Bill.PenaltyAmount > 0)
                    {
                        <div class="row mb-2">
                            <div class="col text-muted">Penalty Charges:</div>
                            <div class="col-auto fw-semibold text-dark">₹@Model.Bill.PenaltyAmount.ToString("N2")</div>
                        </div>
                    }
                    <div class="row border-top pt-2">
                        <div class="col fw-bold text-dark fs-5">Grand Total:</div>
                        <div class="col-auto fw-bold text-primary fs-4">₹@Model.Bill.TotalAmount.ToString("N2")</div>
                    </div>
                </div>
            </div>

            <!-- Tax Summary Table (Legal Requirement for GST) -->
            @if (isGstInvoice)
            {
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-bold small mb-2"><i class="fa-solid fa-list-check me-1"></i> Tax Breakdown Summary:</h6>
                    <table class="table table-bordered table-sm text-center small align-middle mb-0">
                        <thead class="table-light text-muted">
                            <tr>
                                <th>SAC Code</th>
                                <th>Taxable Amount</th>
                                <th colspan="2">CGST</th>
                                <th colspan="2">SGST</th>
                                <th>Total Tax Amount</th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th>Rate</th>
                                <th>Amount</th>
                                <th>Rate</th>
                                <th>Amount</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>999511</td>
                                <td>₹@subtotal.ToString("N2")</td>
                                <td>@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                                <td>₹@cgstAmount.ToString("N2")</td>
                                <td>@((Model.Bill.GstRate / 2).ToString("N1"))%</td>
                                <td>₹@sgstAmount.ToString("N2")</td>
                                <td class="fw-bold">₹@totalTax.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }

            <!-- Payment Logs -->
            @if (Model.Payments != null && Model.Payments.Any())
            {
                <h6 class="text-uppercase text-muted fw-bold small mb-2 mt-5"><i class="fa-solid fa-clock-rotate-left me-1"></i> Payment Transaction Log:</h6>
                <div class="table-responsive mb-4">
                    <table class="table table-sm table-hover align-middle border">
                        <thead class="table-light">
                            <tr>
                                <th>Date & Time</th>
                                <th>Payment Mode</th>
                                <th>Transaction ID / Reference</th>
                                <th>Remarks / Notes</th>
                                <th class="text-end">Paid Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td>@p.PaymentDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td><span class="badge bg-secondary rounded-pill px-2">@p.PaymentMode</span></td>
                                    <td><code class="text-dark">@(p.TransactionId ?? "-")</code></td>
                                    <td class="text-muted small">@(p.Remarks ?? "No remarks")</td>
                                    <td class="text-end text-success fw-bold">₹@p.PaidAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="fw-bold bg-light">
                            <tr>
                                <td colspan="4" class="text-end text-dark">Total Amount Received:</td>
                                <td class="text-end text-success fs-6">₹@Model.Bill.AmountPaid.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }

            <!-- Footer & Signature -->
            <div class="row invoice-footer mt-5 pt-4">
                <div class="col-md-7">
                    @if (Model.Bill.BalanceAmount > 0)
                    {
                        <div class="alert alert-warning border-0 rounded-3 shadow-sm d-flex align-items-center mb-0">
                            <i class="fa-solid fa-circle-exclamation fs-3 me-3 text-warning"></i>
                            <div>
                                <h6 class="alert-heading fw-bold mb-0">Outstanding Balance: ₹@Model.Bill.BalanceAmount.ToString("N2")</h6>
                                <p class="mb-0 small text-muted">Please pay the remaining amount promptly to ensure continued maintenance services.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success border-0 rounded-3 shadow-sm d-flex align-items-center mb-0">
                            <i class="fa-solid fa-circle-check fs-3 me-3 text-success"></i>
                            <div>
                                <h6 class="alert-heading fw-bold mb-0">Invoice Fully Settled</h6>
                                <p class="mb-0 small text-muted">Thank you! Your payment has been successfully recorded in the society general ledger.</p>
                            </div>
                        </div>
                    }
                </div>
                <div class="col-md-5 text-end mt-4 mt-md-0 d-flex flex-column align-items-end justify-content-end">
                    <div class="border-top pt-3 text-center" style="width: 220px;">
                        <div class="fw-bold text-dark mb-0">SmartSociety Management</div>
                        <div class="text-muted small">Authorized Finance Signatory</div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <p class="text-muted small mb-0">This is a computer-generated tax invoice issued by SmartSociety ERP system. No physical signature is required.</p>
            </div>
        </div>
    </div>
</div>
