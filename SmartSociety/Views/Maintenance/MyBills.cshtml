@model IEnumerable<SmartSociety.Models.MaintenanceBill>
@{
    ViewData["Title"] = "My Maintenance & Invoices";
    var flat = ViewBag.Flat as SmartSociety.Models.Flat;
    var unpaidTotal = Model.Where(b => b.Status != "Paid").Sum(b => b.BalanceAmount);
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Resident</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">My Maintenance & Bills</li>
      </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Maintenance & Invoices</h2>
            <p class="text-muted mb-0">View monthly maintenance bills, transaction statements, and pay dues.</p>
        </div>
    </div>

    <!-- Stats & Flat Details Header -->
    <div class="row g-4 mb-4">
        <!-- Flat Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 d-flex align-items-center justify-content-center me-4" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-hotel fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-semibold text-muted mb-1">Registered Flat</h6>
                        <h4 class="fw-bold text-dark mb-1">Block @flat?.BlockName - @flat?.FlatNumber</h4>
                        <div class="small text-muted">
                            <span class="me-3"><strong>Area:</strong> @flat?.AreaSqFt.ToString("N0") SqFt</span>
                            <span><strong>Intercom:</strong> @(flat?.IntercomNumber ?? "N/A")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Outstanding -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3 d-flex align-items-center justify-content-center me-4" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-wallet fs-3"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold text-muted mb-1">Total Outstanding Dues</h6>
                            <h3 class="fw-bold text-dark mb-0">₹@unpaidTotal.ToString("N2")</h3>
                        </div>
                    </div>
                    @if (unpaidTotal > 0)
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-2 rounded-pill fs-6"><i class="fa-solid fa-triangle-exclamation me-1"></i> Payment Pending</span>
                    }
                    else
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill fs-6"><i class="fa-solid fa-circle-check me-1"></i> No Pending Dues</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Bills Table -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-list text-primary me-2"></i> Billing History & Invoices</h5>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Bill ID</th>
                            <th>Billing Month</th>
                            <th>Base Cost</th>
                            <th>Extra & Penalty</th>
                            <th>Total Invoice</th>
                            <th>Paid Amount</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var bill in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">#MNT-@bill.BillYear-@bill.BillMonth-@bill.BillId</td>
                                    <td class="fw-semibold text-dark py-3">@bill.DisplayMonthYear</td>
                                    <td>₹@bill.BaseAmount.ToString("N2")</td>
                                    <td>
                                        <span class="text-muted">₹@(bill.ExtraCharges + bill.PenaltyAmount)</span>
                                        @if (bill.ExtraCharges > 0 && !string.IsNullOrEmpty(bill.ExtraChargeRemarks))
                                        {
                                            <i class="fa-solid fa-info-circle text-info ms-1 cursor-pointer" title="Remarks: @bill.ExtraChargeRemarks"></i>
                                        }
                                    </td>
                                    <td class="fw-bold text-dark">₹@bill.TotalAmount.ToString("N2")</td>
                                    <td class="text-success fw-semibold">₹@bill.AmountPaid.ToString("N2")</td>
                                    <td>
                                        @if (bill.Status == "Paid")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i> Paid</span>
                                        }
                                        else if (bill.Status == "Partial")
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-half-stroke me-1"></i> Partial</span>
                                        }
                                        else
                                        {
                                            if (bill.DueDate < DateTime.Now)
                                            {
                                                <span class="badge bg-danger px-3 py-2 rounded-pill text-white shadow-sm"><i class="fa-solid fa-triangle-exclamation me-1"></i> Overdue</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-1"></i> Unpaid</span>
                                            }
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (bill.Status != "Paid")
                                        {
                                            <button class="btn btn-sm btn-primary px-3 rounded-pill fw-semibold shadow-sm" onclick="openPaymentGateway(@bill.BillId, @bill.BalanceAmount, '@bill.DisplayMonthYear')">
                                                <i class="fa-solid fa-credit-card me-1"></i> Pay Now
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-action="Receipt" asp-route-id="@bill.BillId" class="btn btn-sm btn-outline-secondary px-3 rounded-pill fw-semibold"><i class="fa-solid fa-file-pdf"></i> Receipt</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">No maintenance invoices found for your flat.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Mock Payment Modal -->
<div class="modal fade" id="paymentGatewayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-0 bg-dark text-white p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-2 me-3">
                        <i class="fa-solid fa-shield-halved fs-3"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold mb-0">SmartSociety Pay</h5>
                        <p class="text-muted small mb-0"><i class="fa-solid fa-lock me-1"></i> 256-bit Secure Checkout</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <!-- Quick Invoice Summary -->
            <div class="bg-primary bg-opacity-10 px-4 py-3 d-flex justify-content-between align-items-center border-bottom border-primary border-opacity-10">
                <div>
                    <span class="text-muted small text-uppercase fw-bold d-block">Maintenance Dues</span>
                    <span class="fw-bold text-dark" id="payCycleText">Cycle: June 2026</span>
                </div>
                <div class="text-end">
                    <span class="text-muted small d-block">Amount Payable</span>
                    <h3 class="fw-bold text-primary mb-0" id="payAmountText">₹0.00</h3>
                </div>
            </div>

            <div class="modal-body p-4 bg-white">
                <!-- Payment Forms -->
                <form id="secureCheckoutForm" onsubmit="event.preventDefault(); processMockPayment();">
                    <input type="hidden" id="modalBillId" />
                    <input type="hidden" id="modalPayAmount" />
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted mb-2"><i class="fa-solid fa-credit-card me-1"></i> Select Payment Method</label>
                        <div class="row g-2">
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="checkoutModeOptions" id="modeUpi" value="UPI" checked onchange="toggleCheckoutFields()">
                                <label class="btn btn-outline-light text-dark border w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center hover-scale" for="modeUpi">
                                    <i class="fa-solid fa-qrcode fs-4 mb-2 text-primary"></i>
                                    <span class="small fw-semibold">UPI / QR</span>
                                </label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="checkoutModeOptions" id="modeCard" value="Card" onchange="toggleCheckoutFields()">
                                <label class="btn btn-outline-light text-dark border w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center hover-scale" for="modeCard">
                                    <i class="fa-regular fa-credit-card fs-4 mb-2 text-success"></i>
                                    <span class="small fw-semibold">Cards</span>
                                </label>
                            </div>
                            <div class="col-4">
                                <input type="radio" class="btn-check" name="checkoutModeOptions" id="modeBank" value="BankTransfer" onchange="toggleCheckoutFields()">
                                <label class="btn btn-outline-light text-dark border w-100 py-3 rounded-3 d-flex flex-column align-items-center justify-content-center hover-scale" for="modeBank">
                                    <i class="fa-solid fa-building-columns fs-4 mb-2 text-warning"></i>
                                    <span class="small fw-semibold">NetBanking</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- UPI Form Fields -->
                    <div id="checkoutUpiFields" class="mb-3 animate__animated animate__fadeIn">
                        <div class="text-center p-3 border rounded-4 bg-light mb-3">
                            <div class="bg-white p-3 d-inline-block rounded-3 shadow-sm mb-2">
                                <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=upi://pay?pa=smartsociety@bank&pn=SmartSociety&mc=0000&tr=123" width="130" height="130" alt="UPI QR" />
                            </div>
                            <p class="small text-muted mb-0"><i class="fa-solid fa-scan me-1"></i> Scan QR Code with GPay, PhonePe, or BHIM</p>
                        </div>
                        <div class="mb-1">
                            <label class="form-label small fw-bold text-muted mb-1">Or Enter UPI ID (VPA)</label>
                            <input type="text" id="upiId" class="form-control py-2 rounded-3 border-secondary-subtle" placeholder="username@upi" required />
                        </div>
                    </div>

                    <!-- Card Form Fields -->
                    <div id="checkoutCardFields" class="mb-3 d-none animate__animated animate__fadeIn">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted mb-1">Card Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 border-secondary-subtle" id="cardIcon"><i class="fa-regular fa-credit-card text-muted"></i></span>
                                <input type="text" id="cardNumber" class="form-control py-2 rounded-end-3 border-start-0 border-secondary-subtle" placeholder="4111 2222 3333 4444" maxlength="19" />
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">Expiry Date</label>
                                <input type="text" id="cardExpiry" class="form-control py-2 rounded-3 border-secondary-subtle" placeholder="MM/YY" maxlength="5" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">CVV / CVV2</label>
                                <input type="password" id="cardCvv" class="form-control py-2 rounded-3 border-secondary-subtle" placeholder="***" maxlength="3" />
                            </div>
                        </div>
                    </div>

                    <!-- Net Banking Form Fields -->
                    <div id="checkoutBankFields" class="mb-3 d-none animate__animated animate__fadeIn">
                        <label class="form-label small fw-bold text-muted mb-1">Select Bank</label>
                        <select id="bankName" class="form-select py-2 rounded-3 border-secondary-subtle bg-white">
                            <option value="SBI">State Bank of India</option>
                            <option value="HDFC">HDFC Bank Ltd</option>
                            <option value="ICICI">ICICI Bank Ltd</option>
                            <option value="AXIS">Axis Bank Ltd</option>
                            <option value="KOTAK">Kotak Mahindra Bank</option>
                        </select>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex align-items-center justify-content-between">
                        <div class="text-muted small">
                            <i class="fa-solid fa-shield-halved text-success me-1"></i> Razorpay Mock Gateway
                        </div>
                        <div>
                            <button type="button" class="btn btn-light px-4 rounded-pill border" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnConfirmPay">
                                <i class="fa-solid fa-lock me-2"></i> Pay Securely
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var paymentModal;

        $(document).ready(function() {
            paymentModal = new bootstrap.Modal(document.getElementById('paymentGatewayModal'));

            // Auto-format Card Number with spaces
            $('#cardNumber').on('input', function(e) {
                var value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
                var formatted = '';
                for (var i = 0; i < value.length; i++) {
                    if (i > 0 && i % 4 === 0) {
                        formatted += ' ';
                    }
                    formatted += value[i];
                }
                e.target.value = formatted;

                // Detect card type for visual feedback
                var icon = $('#cardIcon i');
                if (value.startsWith('4')) {
                    icon.removeClass().addClass('fa-brands fa-cc-visa text-primary fs-5');
                } else if (value.startsWith('5')) {
                    icon.removeClass().addClass('fa-brands fa-cc-mastercard text-danger fs-5');
                } else {
                    icon.removeClass().addClass('fa-regular fa-credit-card text-muted');
                }
            });

            // Auto-format Expiry date with slash
            $('#cardExpiry').on('input', function(e) {
                var value = e.target.value.replace(/[^0-9]/gi, '');
                if (value.length >= 2) {
                    e.target.value = value.substring(0,2) + '/' + value.substring(2,4);
                } else {
                    e.target.value = value;
                }
            });
        });

        function openPaymentGateway(billId, balance, displayCycle) {
            $('#secureCheckoutForm')[0].reset();
            $('#modalBillId').val(billId);
            $('#modalPayAmount').val(balance);
            $('#payCycleText').text('Cycle: ' + displayCycle);
            $('#payAmountText').text('₹' + balance.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
            $('#cardIcon i').removeClass().addClass('fa-regular fa-credit-card text-muted');
            
            // Reset to UPI radio and update fields
            $('#modeUpi').prop('checked', true);
            toggleCheckoutFields();
            paymentModal.show();
        }

        function toggleCheckoutFields() {
            var mode = $('input[name="checkoutModeOptions"]:checked').val();
            
            // Hide all
            $('#checkoutUpiFields').addClass('d-none');
            $('#checkoutCardFields').addClass('d-none');
            $('#checkoutBankFields').addClass('d-none');
            
            // Remove required attributes
            $('#upiId').prop('required', false);
            $('#cardNumber').prop('required', false);
            $('#cardExpiry').prop('required', false);
            $('#cardCvv').prop('required', false);

            if (mode === 'UPI') {
                $('#checkoutUpiFields').removeClass('d-none');
                $('#upiId').prop('required', true);
            } else if (mode === 'Card') {
                $('#checkoutCardFields').removeClass('d-none');
                $('#cardNumber').prop('required', true);
                $('#cardExpiry').prop('required', true);
                $('#cardCvv').prop('required', true);
            } else if (mode === 'BankTransfer') {
                $('#checkoutBankFields').removeClass('d-none');
            }
        }

        function processMockPayment() {
            var billId = $('#modalBillId').val();
            var paidAmount = $('#modalPayAmount').val();
            var paymentMode = $('input[name="checkoutModeOptions"]:checked').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            // Generate mock transaction id
            var transactionId = 'TXN-' + Math.random().toString(36).substring(2, 10).toUpperCase();

            // Hide the modal & initiate security steps overlay
            paymentModal.hide();

            Swal.fire({
                title: 'Securing Connection...',
                html: '<div class="py-4 text-center">' +
                      '  <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;"></div>' +
                      '  <h5 id="payment-step-title" class="fw-bold text-dark mt-2 mb-1">Authenticating Credentials</h5>' +
                      '  <p id="payment-step-msg" class="text-muted small">Connecting with securely encrypted bank API...</p>' +
                      '</div>',
                allowOutsideClick: false,
                allowEscapeKey: false,
                showConfirmButton: false,
                didOpen: () => {
                    Swal.showLoading();
                    
                    // Transition to step 2 after 1.2 seconds
                    setTimeout(() => {
                        document.getElementById('payment-step-title').innerText = "Authorizing Funds Transfer";
                        document.getElementById('payment-step-msg').innerText = "Verifying sufficient balance and logging authorization receipt...";
                    }, 1200);

                    // Transition to step 3 after 2.4 seconds
                    setTimeout(() => {
                        document.getElementById('payment-step-title').innerText = "Logging General Ledger Dues";
                        document.getElementById('payment-step-msg').innerText = "Allocating 10% contribution automatically to Sinking Fund Ledger...";
                    }, 2400);
                }
            });

            // Perform the AJAX request after 3.6 seconds to give the mock checkout portal a rich, secure feel
            setTimeout(() => {
                $.ajax({
                    url: '/Maintenance/RecordPayment',
                    type: 'POST',
                    data: {
                        billId: billId,
                        paidAmount: paidAmount,
                        paymentMode: paymentMode,
                        transactionId: transactionId,
                        remarks: 'Paid through Resident Portal secure checkout',
                        __RequestVerificationToken: token
                    },
                    success: function (res) {
                        Swal.close();
                        if (res.success) {
                            Swal.fire({
                                title: 'Payment Successful!',
                                text: 'Your payment of ₹' + parseFloat(paidAmount).toLocaleString('en-IN', { minimumFractionDigits: 2 }) + ' was received. 10% has been credited to the Society Sinking Fund.',
                                icon: 'success',
                                confirmButtonColor: '#198754',
                                confirmButtonText: 'View Receipts'
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Payment Failed', res.message, 'error');
                        }
                    },
                    error: function () {
                        Swal.close();
                        Swal.fire('Error', 'An unexpected error occurred during secure checkout authorization.', 'error');
                    }
                });
            }, 3600);
        }
    </script>
}
