@model IEnumerable<SmartSociety.Models.RfidGateLog>
@{
    ViewData["Title"] = "My Parking & RFID Logs";
    var mySlots = ViewBag.MySlots as IEnumerable<SmartSociety.Models.ParkingSlot> ?? new List<SmartSociety.Models.ParkingSlot>();
    var flat = ViewBag.Flat as SmartSociety.Models.Flat;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold"><i class="fa-solid fa-square-parking text-primary me-2"></i> My Parking & RFID Logs</h1>
            <p class="text-muted small mb-0">Flat: <span class="fw-bold text-dark">@flat?.BlockName - @flat?.FlatNumber</span> | View registered RFID vehicle tags and boom barrier logs.</p>
        </div>
    </div>

    <!-- Parking Slots Allocation -->
    <div class="card border-0 rounded-4 shadow-sm p-4 bg-white mb-4">
        <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-car text-muted me-1.5"></i> My Registered Vehicles & Parking Slots</h5>
        
        <div class="row g-3">
            @if (!mySlots.Any())
            {
                <div class="col-12 text-center py-4 text-muted">
                    <i class="fa-solid fa-car-rear fa-3x mb-3 text-secondary opacity-50 d-block"></i>
                    No parking slots allocated to your flat. Please contact the Admin management.
                </div>
            }
            else
            {
                foreach (var s in mySlots)
                {
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-4 border border-light-subtle h-100">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1 fw-bold text-xs">
                                    Slot: @s.SlotNumber
                                </span>
                                <span class="text-muted small fw-medium">@s.VehicleType</span>
                            </div>
                            
                            <div class="row g-2 mb-2 align-items-center">
                                <div class="col-4 text-muted small">Vehicle No:</div>
                                <div class="col-8 fw-bold text-dark text-uppercase">@(s.VehicleNumber ?? "Not Registered")</div>
                            </div>
                            <div class="row g-2 mb-2 align-items-center">
                                <div class="col-4 text-muted small">Make & Model:</div>
                                <div class="col-8 fw-semibold text-secondary">@(s.VehicleMakeModel ?? "N/A")</div>
                            </div>
                            <div class="row g-2 align-items-center">
                                <div class="col-4 text-muted small">RFID Sticker Tag:</div>
                                <div class="col-8">
                                    @if (!string.IsNullOrEmpty(s.StickerNumber))
                                    {
                                        <code class="text-primary bg-primary bg-opacity-10 px-2 py-0.5 rounded fw-bold">@s.StickerNumber</code>
                                    }
                                    else
                                    {
                                        <span class="text-danger small"><i class="fa-solid fa-triangle-exclamation me-1"></i> Tag Not Linked</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- RFID Gate logs table -->
    <div class="card border-0 rounded-4 shadow-sm p-4 bg-white">
        <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-clock-rotate-left text-muted me-1.5"></i> Vehicle Entry & Exit Logs</h5>

        <div class="table-responsive">
            <table class="table table-hover align-middle border-0" id="parkingLogsTable">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="border-0">Timestamp</th>
                        <th class="border-0">Gate Name</th>
                        <th class="border-0">Direction</th>
                        <th class="border-0">Vehicle Number</th>
                        <th class="border-0">RFID Sticker Tag</th>
                        <th class="border-0 text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="small text-secondary">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="fa-solid fa-clipboard-question fa-3x mb-3 text-secondary opacity-50 d-block"></i>
                                No gate logs found for your vehicles.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var log in Model)
                        {
                            var dirClass = log.Direction == "Entry" ? "text-success" : "text-warning";
                            var isAuth = log.Status.StartsWith("Authorized");
                            var statusClass = isAuth ? "bg-success bg-opacity-10 text-success border border-success-subtle" : "bg-danger bg-opacity-10 text-danger border border-danger-subtle";
                            
                            <tr>
                                <td>@log.Timestamp.ToString("dd MMM yyyy, hh:mm:ss tt")</td>
                                <td class="fw-medium text-dark">@log.GateName</td>
                                <td class="@dirClass fw-bold">
                                    @if (log.Direction == "Entry")
                                    {
                                        <i class="fa-solid fa-right-to-bracket me-1"></i> <span>ENTRY</span>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-right-from-bracket me-1"></i> <span>EXIT</span>
                                    }
                                </td>
                                <td class="fw-bold text-uppercase text-dark">@(log.VehicleNumber ?? "-")</td>
                                <td><code class="text-dark">@log.RfidTag</code></td>
                                <td class="text-center">
                                    <span class="badge @statusClass rounded-pill px-2.5 py-1">@(isAuth ? "Granted" : "Denied")</span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
