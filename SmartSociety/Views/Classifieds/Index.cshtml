@model IEnumerable<SmartSociety.Models.ClassifiedAd>
@{
ViewData["Title"] = "Society Bazaar - Local Classifieds";
var category = ViewBag.SelectedCategory as string;
var type = ViewBag.SelectedType as string;
var currentUserId = ViewBag.CurrentUserId as int?;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Community</li>
        <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">Society Bazaar</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-1"><i class="fa-solid fa-store text-warning me-2"></i> Society Bazaar</h2>
        <p class="text-muted mb-0">Buy, sell, or rent items securely with your society co-residents.</p>
    </div>
    <button type="button" class="btn btn-primary px-4 py-2.5 fw-semibold rounded-pill shadow-sm" onclick="openPostAdModal()">
        <i class="fa-solid fa-circle-plus me-2"></i> Post Classified Ad
    </button>
</div>

<!-- Filters Bar -->
<div class="card border-0 shadow-sm rounded-4 p-3 mb-4 bg-white">
    <form method="get" asp-action="Index" class="row g-3 align-items-center">
        <div class="col-md-4 col-sm-6">
            <label class="form-label small fw-bold text-secondary mb-1">Filter by Category</label>
            <select name="category" class="form-select bg-light border-0 rounded-3" onchange="this.form.submit()">
                <option value="">-- All Categories --</option>
                <option value="Electronics" selected="@(category == "Electronics")">Electronics & Appliances</option>
                <option value="Furniture" selected="@(category == "Furniture")">Furniture & Home Decor</option>
                <option value="Vehicles" selected="@(category == "Vehicles")">Vehicles & Accessories</option>
                <option value="Books" selected="@(category == "Books")">Books & Hobbies</option>
                <option value="Other" selected="@(category == "Other")">Other Miscellaneous</option>
            </select>
        </div>
        <div class="col-md-3 col-sm-6">
            <label class="form-label small fw-bold text-secondary mb-1">Listing Type</label>
            <select name="type" class="form-select bg-light border-0 rounded-3" onchange="this.form.submit()">
                <option value="">-- All Types --</option>
                <option value="Sell" selected="@(type == "Sell")">For Sale</option>
                <option value="Rent" selected="@(type == "Rent")">For Rent</option>
            </select>
        </div>
        <div class="col-md-5 d-flex justify-content-md-end justify-content-start align-self-end">
            @if (!string.IsNullOrEmpty(category) || !string.IsNullOrEmpty(type))
            {
                <a asp-action="Index" class="btn btn-outline-danger rounded-pill px-4 me-2"><i class="fa-solid fa-filter-circle-xmark me-1"></i> Clear Filters</a>
            }
            <button type="submit" class="btn btn-light border rounded-pill px-4"><i class="fa-solid fa-magnifying-glass me-1 text-muted"></i> Search</button>
        </div>
    </form>
</div>

<!-- Classified Ads Grid -->
<div class="row g-4">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center py-5">
            <img src="https://img.icons8.com/illustrations/external-justicon-lineal-color-justicon/150/external-online-shopping-ecommerce-justicon-lineal-color-justicon-1.png" alt="No Ads" class="mb-3 opacity-75" style="width: 150px;" />
            <h5 class="fw-bold text-secondary">No Advertisements Found</h5>
            <p class="text-muted small">Be the first to post something in the Society Bazaar!</p>
            <button class="btn btn-primary rounded-pill px-4 mt-2" onclick="openPostAdModal()"><i class="fa-solid fa-circle-plus me-1"></i> Post Ad Now</button>
        </div>
    }
    else
    {
        @foreach (var ad in Model)
        {
            <div class="col-md-4 col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm h-100 overflow-hidden ad-card hover-scale bg-white">
                    <!-- Image Area -->
                    <div class="position-relative bg-light d-flex justify-content-center align-items-center" style="height: 200px;">
                        @if (!string.IsNullOrEmpty(ad.ImagePath))
                        {
                            <img src="@ad.ImagePath" class="w-100 h-100" style="object-fit: contain;" alt="@ad.Title" />
                        }
                        else
                        {
                            <div class="text-center text-muted">
                                <i class="fa-solid fa-image fa-3x mb-2 opacity-50"></i>
                                <span class="d-block small">No Image Uploaded</span>
                            </div>
                        }

                        <!-- Badges -->
                        <span class="position-absolute top-0 start-0 m-3 badge rounded-pill @(ad.AdType == "Sell" ? "bg-success" : "bg-info") px-3 py-1.5 shadow-sm fw-bold">
                            @(ad.AdType == "Sell" ? "For Sale" : "Rent")
                        </span>

                        <span class="position-absolute bottom-0 end-0 m-3 badge rounded-pill bg-dark bg-opacity-75 px-3 py-1.5 text-warning font-monospace fs-6 fw-bold">
                            ₹@ad.Price.ToString("N0")
                        </span>
                    </div>

                    <!-- Content Area -->
                    <div class="card-body p-4 d-flex flex-column">
                        <span class="text-uppercase tracking-wider small text-primary fw-bold mb-1">
                            @ad.AdCategory
                        </span>
                        <h5 class="card-title fw-bold text-dark mb-2 text-truncate" title="@ad.Title">@ad.Title</h5>
                        <p class="card-text text-muted small flex-grow-1 text-clamp-2">@ad.Description</p>

                        <div class="border-top pt-3 mt-3 d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted d-block">Posted By</small>
                                <span class="fw-semibold text-dark small"><i class="fa-solid fa-house-user me-1 text-muted"></i> @ad.OwnerName (Flat @ad.OwnerFlatNumber)</span>
                            </div>
                            <div class="d-flex gap-1">
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold"
                                onclick="viewAdDetails(@ad.ClassifiedId, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ad.Title))', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ad.Description))', '@ad.Price.ToString("N0")', '@ad.AdCategory', '@ad.AdType', '@ad.ImagePath', '@ad.OwnerName', '@ad.OwnerFlatNumber', '@ad.OwnerPhone')">
                                Details
                            </button>
                            @if (currentUserId.HasValue && (currentUserId.Value == ad.UserId || User.IsInRole("Admin")))
                            {
                                <button class="btn btn-sm btn-outline-danger rounded-circle p-2 d-flex align-items-center justify-content-center"
                                onclick="deleteClassified(@ad.ClassifiedId)" style="width: 32px; height: 32px;" title="Delete Ad">
                                <i class="fa-solid fa-trash-can fa-sm"></i>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
}
</div>

<!-- Details Modal -->
<div class="modal fade" id="adDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-light rounded-top-4 pb-3">
                <span class="badge rounded-pill bg-primary px-3 py-1.5 fw-bold me-2" id="modalAdCategory"></span>
                <span class="badge rounded-pill px-3 py-1.5 fw-bold" id="modalAdType"></span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <div class="row g-4">
                    <div class="col-md-5">
                        <div class="bg-light rounded-4 overflow-hidden d-flex justify-content-center align-items-center border" style="min-height: 250px; max-height: 300px;">
                            <img id="modalAdImage" src="" alt="Ad Image" class="img-fluid w-100 h-100" style="object-fit: contain;" />
                            <div id="modalAdPlaceholder" class="text-center text-muted py-5 d-none">
                                <i class="fa-solid fa-image fa-4x mb-2 opacity-50"></i>
                                <span class="d-block small">No Image Available</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7 d-flex flex-column justify-content-between">
                        <div>
                            <h3 class="fw-bold text-dark mb-1" id="modalAdTitle"></h3>
                            <h2 class="text-warning fw-bold mb-3 font-monospace" id="modalAdPrice"></h2>
                            <h6 class="fw-bold text-secondary mb-2">Item Description:</h6>
                            <p class="text-muted small" id="modalAdDescription" style="white-space: pre-line; max-height: 150px; overflow-y: auto;"></p>
                        </div>

                        <div class="border-top pt-3 mt-3 bg-light rounded-4 p-3 border">
                            <h6 class="fw-bold text-dark mb-2"><i class="fa-solid fa-address-card text-muted me-1"></i> Seller Contacts:</h6>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted small">Seller:</span>
                                <span class="fw-bold text-dark small" id="modalOwnerName"></span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted small">Flat Number:</span>
                                <span class="fw-bold text-dark small" id="modalOwnerFlat"></span>
                            </div>
                            <div class="d-flex gap-2">
                                <a id="btnCall" href="" class="btn btn-primary rounded-pill px-4 fw-semibold w-100 shadow-sm"><i class="fa-solid fa-phone me-1"></i> Call Seller</a>
                                <a id="btnWhatsApp" href="" target="_blank" class="btn btn-success rounded-pill px-4 fw-semibold w-100 shadow-sm"><i class="fa-brands fa-whatsapp me-1"></i> WhatsApp</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Post Ad Modal -->
<div class="modal fade" id="postAdModal" tabindex="-1" aria-labelledby="postAdModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="postAdModalLabel"><i class="fa-solid fa-circle-plus me-2"></i> Post Ad - Society Bazaar</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="postAdForm" onsubmit="event.preventDefault(); submitClassifiedAd();" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="AdTitle" class="form-label fw-semibold small text-muted mb-1">Ad Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control bg-light border-0" id="AdTitle" name="Title" required placeholder="e.g. Wooden Dining Table for Sale" />
                    </div>
                    <div class="row mb-3">
                        <div class="col-6">
                            <label for="AdCategory" class="form-label fw-semibold small text-muted mb-1">Category <span class="text-danger">*</span></label>
                            <select class="form-select bg-light border-0" id="AdCategory" name="AdCategory" required>
                                <option value="Electronics">Electronics</option>
                                <option value="Furniture">Furniture</option>
                                <option value="Vehicles">Vehicles</option>
                                <option value="Books">Books</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label for="AdType" class="form-label fw-semibold small text-muted mb-1">Ad Type <span class="text-danger">*</span></label>
                            <select class="form-select bg-light border-0" id="AdType" name="AdType" required>
                                <option value="Sell">For Sale</option>
                                <option value="Rent">For Rent</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="AdPrice" class="form-label fw-semibold small text-muted mb-1">Price (₹) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control bg-light border-0" id="AdPrice" name="Price" required placeholder="e.g. 5000" min="1" step="any" />
                    </div>
                    <div class="mb-3">
                        <label for="AdDescription" class="form-label fw-semibold small text-muted mb-1">Item Description <span class="text-danger">*</span></label>
                        <textarea class="form-control bg-light border-0" id="AdDescription" name="Description" required rows="4" placeholder="Mention condition, usage time, dimensions, etc."></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="AdImage" class="form-label fw-semibold small text-muted mb-1">Upload Item Photo (Optional)</label>
                        <input type="file" class="form-control bg-light border-0" id="AdImage" name="ImageFile" accept=".jpg,.jpeg,.png,.webp" />
                        <div class="form-text text-muted small">Allowed formats: .jpg, .jpeg, .png, .webp (Max: 5MB)</div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-semibold" id="btnSubmitAd">
                            <i class="fa-solid fa-check me-2"></i> Post Ad
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    var postAdModal;
    var adDetailModal;

    $(document).ready(function() {
    postAdModal = new bootstrap.Modal(document.getElementById('postAdModal'));
    adDetailModal = new bootstrap.Modal(document.getElementById('adDetailModal'));
    });

    function openPostAdModal() {
    $('#postAdForm')[0].reset();
    postAdModal.show();
}

function viewAdDetails(adId, title, desc, price, category, type, imagePath, ownerName, ownerFlat, ownerPhone) {
$('#modalAdTitle').text(title);
$('#modalAdPrice').text('₹' + price);
$('#modalAdDescription').text(desc);
$('#modalAdCategory').text(category);
$('#modalAdType').text(type === 'Sell' ? 'For Sale' : 'For Rent')
.removeClass('bg-success bg-info')
.addClass(type === 'Sell' ? 'bg-success' : 'bg-info');

if (imagePath) {
$('#modalAdPlaceholder').addClass('d-none');
$('#modalAdImage').removeClass('d-none').attr('src', imagePath);
}
else
{
    $('#modalAdImage').addClass('d-none');
    $('#modalAdPlaceholder').removeClass('d-none');
}

$('#modalOwnerName').text(ownerName);
$('#modalOwnerFlat').text(ownerFlat);
$('#btnCall').attr('href', 'tel:' + ownerPhone);

// Format phone for WhatsApp link
var cleanedPhone = ownerPhone.replace(/\D/g, '');
if (!cleanedPhone.startsWith('91') && cleanedPhone.length === 10) {
cleanedPhone = '91' + cleanedPhone;
}
var waMessage = encodeURIComponent("Hi " + ownerName + ", I am interested in your item '" + title + "' posted on SmartSociety.");
$('#btnWhatsApp').attr('href', 'https://wa.me/' + cleanedPhone + '?text=' + waMessage);

adDetailModal.show();
}

function submitClassifiedAd() {
var form = $('#postAdForm')[0];
var formData = new FormData(form);

$('#btnSubmitAd').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Posting...');

$.ajax({
url: '/Classifieds/CreateAd',
type: 'POST',
data: formData,
processData: false,
contentType: false,
success: function (res) {
if (res.success) {
postAdModal.hide();
Swal.fire({
icon: 'success',
title: 'Success!',
text: res.message,
showConfirmButton: false,
timer: 2000
}).then(() => {
location.reload();
});
}
else
{
    Swal.fire('Failed', res.message, 'error');
    $('#btnSubmitAd').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Post Ad');
}
},
error: function () {
Swal.fire('Error', 'An unexpected error occurred.', 'error');
$('#btnSubmitAd').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Post Ad');
}
});
}

function deleteClassified(adId) {
Swal.fire({
title: 'Delete Ad?',
text: 'Are you sure you want to remove this classified advertisement?',
icon: 'warning',
showCancelButton: true,
confirmButtonColor: '#dc3545',
cancelButtonColor: '#6c757d',
confirmButtonText: 'Yes, Delete It'
}).then((result) => {
if (result.isConfirmed) {
var token = $('input[name="__RequestVerificationToken"]').val();
$.ajax({
url: '/Classifieds/DeleteAd/' + adId,
type: 'POST',
data: { __RequestVerificationToken: token },
success: function (res) {
if (res.success) {
Swal.fire({
icon: 'success',
title: 'Deleted!',
text: res.message,
showConfirmButton: false,
timer: 1500
}).then(() => {
location.reload();
});
}
else
{
    Swal.fire('Error', res.message, 'error');
}
},
error: function () {
Swal.fire('Error', 'Failed to delete advertisement.', 'error');
}
});
}
});
}
</script>
<style>
    .hover-scale {
    transition: all 0.25s ease-in-out;
}
.hover-scale:hover {
transform: translateY(-5px);
box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
}
.text-clamp-2 {
display: -webkit-box;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
overflow: hidden;
}
.letter-spacing-1 {
letter-spacing: 0.5px;
}
.ad-card {
border: 1px solid rgba(0, 0, 0, 0.04) !important;
}
</style>
}