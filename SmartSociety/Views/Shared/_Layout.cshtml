<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartSociety</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartSociety.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-light" style="overflow: hidden;">
    <div class="d-flex flex-nowrap" style="height: 100vh; width: 100vw; overflow: hidden;">
        <!-- Sidebar -->
        <partial name="_Sidebar" />

        <!-- Main Content Area -->
        <div class="d-flex flex-column w-100" style="background-color: #f8fafc; height: 100vh; overflow-y: auto;">
            
            <header class="top-header bg-white shadow-sm px-4 py-3 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <button class="btn btn-light d-md-none me-3" type="button" id="sidebarToggle">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <h5 class="mb-0 fw-bold text-dark d-none d-md-block">
                        @{
                            var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Guest";
                            if (role == "Admin") { <text>Admin Dashboard</text> }
                            else if (role == "Resident") { <text>Resident Portal</text> }
                            else if (role == "Guard") { <text>Security Post</text> }
                            else { <text>SmartSociety</text> }
                        }
                    </h5>
                </div>
                
                <div class="d-flex align-items-center">
                    <!-- Profile Dropdown -->
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="bg-light rounded-circle p-2 me-2">
                                <i class="fa-solid fa-user text-primary"></i>
                            </div>
                            <span class="d-none d-md-inline fw-medium">@User.Identity?.Name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="dropdownUser">
                            <li>
                                <div class="px-3 py-2">
                                    <span class="d-block fw-bold text-dark">@User.Identity?.Name</span>
                                    <span class="d-block small text-muted">Role: @(User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Profile"><i class="fa-solid fa-user-gear me-2 text-muted"></i> Profile & Family Settings</a></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger"><i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Sign out</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Render Body -->
            <main role="main" class="p-4 flex-grow-1">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="text-muted p-4 bg-white border-top mt-auto" style="position: relative; z-index: 10;">
                <div class="container-fluid text-center">
                    &copy; 2026 - SmartSociety - Premium Edition
                </div>
            </footer>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
