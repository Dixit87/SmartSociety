@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@functions {
    public string GetActiveCssClass(string controller, string action = null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        bool isSameController = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
        bool isSameAction = action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return isSameController && isSameAction ? "active" : "text-white";
    }
}

