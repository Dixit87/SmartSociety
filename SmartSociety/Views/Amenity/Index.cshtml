@model dynamic

@{
    ViewData["Title"] = "Amenity & Facility Booking";
    var amenities = Model.Amenities as IEnumerable<SmartSociety.Models.Amenity>;
    var bookings = Model.Bookings as IEnumerable<SmartSociety.Models.AmenityBooking>;
    var flats = Model.Flats as IEnumerable<SmartSociety.Models.Flat>;
    var users = Model.Users as IEnumerable<SmartSociety.Models.User>;
}

<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<style>
    .amenity-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .amenity-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .nav-tabs .nav-link.active {
        background-color: transparent;
        border-bottom: 3px solid var(--bs-primary);
    }
</style>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item text-muted">Admin</li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Amenity Booking</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1 text-dark"><i class="fa-regular fa-calendar-check me-2 text-primary"></i> Amenity Booking</h2>
        <p class="text-muted mb-0">Manage society facilities and resident booking requests.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm" onclick="openAmenityModal()">
            <i class="fa-solid fa-plus me-2"></i> Add Facility
        </button>
        <button class="btn btn-success fw-bold px-4 rounded-pill shadow-sm" onclick="openBookingModal()">
            <i class="fa-solid fa-calendar-plus me-2"></i> New Booking
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom pt-3 pb-0 px-4">
        <ul class="nav nav-tabs border-bottom-0 fw-semibold" id="amenityTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active text-dark border-0 pb-3 px-4" id="requests-tab" data-bs-toggle="tab" data-bs-target="#requests" type="button" role="tab">
                    <i class="fa-solid fa-list-check me-1 text-primary"></i> Booking Requests
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-dark border-0 pb-3 px-4" id="facilities-tab" data-bs-toggle="tab" data-bs-target="#facilities" type="button" role="tab">
                    <i class="fa-solid fa-building me-1 text-success"></i> Manage Facilities
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-dark border-0 pb-3 px-4" id="calendar-tab" data-bs-toggle="tab" data-bs-target="#calendar" type="button" role="tab">
                    <i class="fa-regular fa-calendar-days me-1 text-info"></i> Calendar View
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body p-4">
        <div class="tab-content" id="amenityTabsContent">
            
            <!-- Booking Requests Tab -->
            <div class="tab-pane fade show active" id="requests" role="tabpanel">
                <table class="table table-hover align-middle w-100" id="bookingsTable">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold text-muted py-3">Facility</th>
                            <th class="fw-semibold text-muted py-3">Resident</th>
                            <th class="fw-semibold text-muted py-3">Date & Time</th>
                            <th class="fw-semibold text-muted py-3">Purpose</th>
                            <th class="fw-semibold text-muted py-3">Status</th>
                            <th class="fw-semibold text-muted py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (bookings != null)
                        {
                            foreach (var b in bookings)
                            {
                                <tr>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@b.AmenityName</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@b.ResidentName</div>
                                        <div class="small text-muted"><i class="fa-solid fa-house me-1"></i> Flat @b.FlatNo</div>
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-semibold text-primary mb-1"><i class="fa-regular fa-calendar me-1"></i> @b.BookingDate.ToString("dd MMM yyyy")</div>
                                        <div class="small text-muted"><i class="fa-regular fa-clock me-1"></i> @DateTime.Today.Add(b.StartTime).ToString("hh:mm tt") - @DateTime.Today.Add(b.EndTime).ToString("hh:mm tt")</div>
                                    </td>
                                    <td class="py-3" style="max-width: 200px;">
                                        <div class="text-truncate" title="@b.Purpose">@b.Purpose</div>
                                    </td>
                                    <td class="py-3">
                                        @if (b.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-1"></i> Pending</span>
                                        }
                                        else if (b.Status == "Approved")
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check me-1"></i> Approved</span>
                                        }
                                        else if (b.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-xmark me-1"></i> Rejected</span>
                                        }
                                        else if (b.Status == "Cancelled")
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill"><i class="fa-solid fa-ban me-1"></i> Cancelled</span>
                                        }
                                    </td>
                                    <td class="py-3 text-end">
                                        @if (b.Status == "Pending")
                                        {
                                            <button class="btn btn-sm btn-success shadow-sm me-1" onclick="updateStatus(@b.BookingId, 'Approved')" title="Approve">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger shadow-sm me-1" onclick="updateStatus(@b.BookingId, 'Rejected')" title="Reject">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                            @if (b.BookingDate >= DateTime.Today)
                                            {
                                                <button class="btn btn-sm btn-warning shadow-sm" onclick="updateStatus(@b.BookingId, 'Cancelled')" title="Cancel">
                                                    <i class="fa-solid fa-ban"></i>
                                                </button>
                                            }
                                        }
                                        else if (b.Status == "Approved" && b.BookingDate >= DateTime.Today)
                                        {
                                            <button class="btn btn-sm btn-warning shadow-sm" onclick="updateStatus(@b.BookingId, 'Cancelled')" title="Cancel">
                                                <i class="fa-solid fa-ban"></i> Cancel
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Processed</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Manage Facilities Tab -->
            <div class="tab-pane fade" id="facilities" role="tabpanel">
                <div class="row g-4">
                    @if (amenities != null && amenities.Any())
                    {
                        foreach (var a in amenities)
                        {
                            <div class="col-md-4">
                                <div class="card amenity-card h-100 border rounded-4 @(a.IsActive ? "" : "bg-light opacity-75")">
                                    <div class="card-body p-4 position-relative">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                <i class="fa-solid fa-building fs-4"></i>
                                            </div>
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-light border-0" type="button" data-bs-toggle="dropdown">
                                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                    <li><a class="dropdown-item" href="#" onclick="openEditAmenityModal(@a.AmenityId, '@Uri.EscapeDataString(a.Name ?? "")', '@Uri.EscapeDataString(a.Description ?? "")', @a.Capacity, '@a.OpenTime.ToString(@"hh\:mm")', '@a.CloseTime.ToString(@"hh\:mm")', @a.PricePerHour, @a.IsActive.ToString().ToLower())"><i class="fa-solid fa-pen text-primary me-2"></i> Edit</a></li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li><a class="dropdown-item text-danger" href="#" onclick="deleteAmenity(@a.AmenityId)"><i class="fa-solid fa-trash me-2"></i> Delete</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                        <h5 class="fw-bold text-dark mb-2">@a.Name</h5>
                                        <p class="text-muted small mb-3 text-truncate-2" style="min-height: 40px;">@a.Description</p>
                                        
                                        <div class="d-flex gap-2 mb-3">
                                            <span class="badge bg-light text-dark border border-secondary-subtle px-2 py-1"><i class="fa-solid fa-users me-1 text-primary"></i> Max @a.Capacity</span>
                                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-2 py-1"><i class="fa-solid fa-indian-rupee-sign me-1"></i> @a.PricePerHour/hr</span>
                                            @if(a.IsActive) {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1"><i class="fa-solid fa-circle-check me-1"></i> Active</span>
                                            } else {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1"><i class="fa-solid fa-circle-xmark me-1"></i> Inactive</span>
                                            }
                                        </div>
                                        <div class="bg-light p-2 rounded-3 text-center small fw-semibold text-muted">
                                            <i class="fa-regular fa-clock me-1"></i> @DateTime.Today.Add(a.OpenTime).ToString("hh:mm tt") - @DateTime.Today.Add(a.CloseTime).ToString("hh:mm tt")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center py-5">
                            <i class="fa-solid fa-building fs-1 text-muted opacity-50 mb-3"></i>
                            <h5 class="fw-bold text-muted">No Facilities Added</h5>
                            <p class="text-muted">Click on "Add Facility" to create one.</p>
                        </div>
                    }
                </div>
        </div>
    </div>

    <!-- Calendar View Tab -->
    <div class="tab-pane fade" id="calendar" role="tabpanel">
        <div id="bookingCalendar" class="bg-white p-3 rounded-4 border"></div>
    </div>
    
</div>
    </div>
</div>

<!-- Add/Edit Facility Modal -->
<div class="modal fade" id="amenityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="amenityModalTitle"><i class="fa-solid fa-building me-2"></i> Add Facility</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="amenityForm" onsubmit="event.preventDefault(); submitAmenity();">
                    <input type="hidden" id="amId" name="amenityId" value="0" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Facility Name <span class="text-danger">*</span></label>
                            <input type="text" id="amName" name="name" class="form-control bg-light border-0 py-2" required placeholder="E.g., Clubhouse" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Max Capacity</label>
                            <input type="number" id="amCapacity" name="capacity" class="form-control bg-light border-0 py-2" required min="1" value="50" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Open Time <span class="text-danger">*</span></label>
                            <input type="time" id="amOpenTime" name="openTime" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Close Time <span class="text-danger">*</span></label>
                            <input type="time" id="amCloseTime" name="closeTime" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Price Per Hour (₹) <span class="text-danger">*</span></label>
                            <input type="number" id="amPricePerHour" name="pricePerHour" class="form-control bg-light border-0 py-2" required min="0" step="0.01" value="0" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Description & Rules</label>
                            <textarea id="amDescription" name="description" class="form-control bg-light border-0" rows="3" placeholder="Any rules or details about the facility..."></textarea>
                        </div>
                        <div class="col-12 mt-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="amIsActive" name="isActive" value="true" checked>
                                <label class="form-check-label fw-semibold" for="amIsActive">Is Currently Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitAmenity">
                            <i class="fa-solid fa-check me-2"></i> Save Facility
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Create Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-success text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="bookingModalTitle"><i class="fa-solid fa-calendar-plus me-2"></i> New Booking</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="bookingForm" onsubmit="event.preventDefault(); submitBooking();">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Select Facility <span class="text-danger">*</span></label>
                            <select id="bkAmenity" name="amenityId" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Choose Facility --</option>
                                @if(amenities != null) {
                                    foreach(var a in amenities.Where(x => x.IsActive)) {
                                        <option value="@a.AmenityId" data-price="@a.PricePerHour">@a.Name (Max: @a.Capacity)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Select Resident <span class="text-danger">*</span></label>
                            <select id="bkUser" name="userId" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Choose Resident --</option>
                                @if(users != null) {
                                    foreach(var u in users) {
                                        <option value="@u.UserId">@u.FullName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Select Flat <span class="text-danger">*</span></label>
                            <select id="bkFlat" name="flatId" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Choose Flat --</option>
                                @if(flats != null) {
                                    foreach(var f in flats) {
                                        <option value="@f.FlatId">@f.FlatNumber</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Booking Date <span class="text-danger">*</span></label>
                            <input type="date" id="bkDate" name="bookingDate" class="form-control bg-light border-0 py-2" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Start Time <span class="text-danger">*</span></label>
                            <input type="time" id="bkStart" name="startTime" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">End Time <span class="text-danger">*</span></label>
                            <input type="time" id="bkEnd" name="endTime" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Purpose / Event Details <span class="text-danger">*</span></label>
                            <input type="text" id="bkPurpose" name="purpose" class="form-control bg-light border-0 py-2" required placeholder="E.g., Son's Birthday Party" maxlength="250" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Total Amount (₹)</label>
                            <input type="number" id="bkTotalAmount" name="totalAmount" class="form-control bg-success-subtle text-success-emphasis border-0 py-2 fw-bold" readonly value="0" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Payment Status <span class="text-danger">*</span></label>
                            <select id="bkPaymentStatus" name="paymentStatus" class="form-select bg-light border-0 py-2" required>
                                <option value="Pending">Pending</option>
                                <option value="Paid">Paid</option>
                            </select>
                        </div>
                    </div>
                    <div class="alert alert-info mt-3 py-2 px-3 mb-0 small">
                        <i class="fa-solid fa-circle-info me-2"></i> Bookings created by admin are automatically approved.
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitBooking">
                            <i class="fa-solid fa-check me-2"></i> Confirm Booking
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>

    <script>
        var amenityModal, bookingModal;

        $(document).ready(function () {
            // DataTables
            $('#bookingsTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search bookings..."
                }
            });
            $('.dataTables_filter input').addClass('form-control form-control-sm');

            amenityModal = new bootstrap.Modal(document.getElementById('amenityModal'));
            bookingModal = new bootstrap.Modal(document.getElementById('bookingModal'));

            // FullCalendar Initialization
            var calendarEl = document.getElementById('bookingCalendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: [
                    @if(bookings != null) {
                        foreach (var b in bookings.Where(x => x.Status == "Approved"))
                        {
                            <text>
                            {
                                title: @Html.Raw(Json.Serialize(b.AmenityName + " - " + b.ResidentName)),
                                start: '@(b.BookingDate.ToString("yyyy-MM-dd") + "T" + b.StartTime.ToString("hh\\:mm\\:ss"))',
                                end: '@(b.BookingDate.ToString("yyyy-MM-dd") + "T" + b.EndTime.ToString("hh\\:mm\\:ss"))',
                                color: '#198754'
                            },
                            </text>
                        }
                    }
                ]
            });

            // Render calendar only when its tab is shown to fix sizing issues
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                if (e.target.id === 'calendar-tab') {
                    calendar.render();
                }
            });
        });

        // Facility Management
        function openAmenityModal() {
            $('#amenityForm')[0].reset();
            $('#amId').val('0');
            $('#amIsActive').prop('checked', true);
            $('#amenityModalTitle').html('<i class="fa-solid fa-building me-2"></i> Add Facility');
            amenityModal.show();
        }

        function openEditAmenityModal(id, name, desc, capacity, openTime, closeTime, isActive) {
            $('#amenityForm')[0].reset();
            $('#amId').val(id);
            $('#amName').val(decodeURIComponent(name));
            $('#amDescription').val(decodeURIComponent(desc));
            $('#amCapacity').val(capacity);
            $('#amOpenTime').val(openTime);
            $('#amCloseTime').val(closeTime);
            $('#amIsActive').prop('checked', isActive);
            $('#amenityModalTitle').html('<i class="fa-solid fa-pen me-2"></i> Edit Facility');
            amenityModal.show();
        }

        function submitAmenity() {
            var form = $('#amenityForm')[0];
            var formData = new FormData(form);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());
            // Need to handle checkbox value manually if it's unchecked
            if(!$('#amIsActive').is(':checked')){
                formData.set('isActive', 'false');
            } else {
                formData.set('isActive', 'true');
            }

            $('#btnSubmitAmenity').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

            $.ajax({
                url: '/Amenity/SaveAmenity',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitAmenity').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Save Facility');
                    }
                }
            });
        }

        function deleteAmenity(id) {
            Swal.fire({
                title: 'Delete Facility?',
                text: "Are you sure you want to remove this facility?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Amenity/DeleteAmenity',
                        type: 'POST',
                        data: { amenityId: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        // Booking Management
        function openBookingModal() {
            $('#bookingForm')[0].reset();
            $('#bkDate').val(new Date().toISOString().split('T')[0]);
            $('#bkTotalAmount').val('0');
            bookingModal.show();
        }

        function calculatePrice() {
            var start = $('#bkStart').val();
            var end = $('#bkEnd').val();
            var amenityId = $('#bkAmenity').val();
            
            if (start && end && amenityId) {
                var pricePerHour = $('#bkAmenity option:selected').data('price') || 0;
                var startDate = new Date("1970-01-01T" + start + ":00Z");
                var endDate = new Date("1970-01-01T" + end + ":00Z");
                var diff = endDate - startDate;
                
                if (diff > 0) {
                    var hours = diff / (1000 * 60 * 60);
                    var total = hours * pricePerHour;
                    $('#bkTotalAmount').val(total.toFixed(2));
                } else {
                    $('#bkTotalAmount').val('0');
                }
            } else {
                $('#bkTotalAmount').val('0');
            }
        }

        $('#bkStart, #bkEnd, #bkAmenity').on('change', calculatePrice);

        function submitBooking() {
            var form = $('#bookingForm')[0];
            var formData = new FormData(form);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $('#btnSubmitBooking').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Processing...');

            $.ajax({
                url: '/Amenity/CreateBooking',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitBooking').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Confirm Booking');
                    }
                }
            });
        }

        function updateStatus(id, status) {
            Swal.fire({
                title: status + ' Booking?',
                text: "Are you sure you want to mark this booking as " + status + "?",
                icon: status === 'Approved' ? 'success' : 'warning',
                showCancelButton: true,
                confirmButtonColor: status === 'Approved' ? '#198754' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, ' + status
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Amenity/UpdateBookingStatus',
                        type: 'POST',
                        data: { bookingId: id, status: status, remarks: '', __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}
