@model SmartSociety.Models.GuardDashboardViewModel
@{
    ViewData["Title"] = "Security Gate Terminal";
}

<div class="container-fluid py-4">
    <!-- Header with Gate Status and Live Clock -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary text-white rounded-circle p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 58px; height: 58px;">
                                <i class="fa-solid fa-shield-halved fs-4"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">Security Gate Post #1</h3>
                                <p class="mb-0 text-white-50 small">SmartSociety Live Security Guard Terminal</p>
                            </div>
                        </div>
                        <div class="text-md-end text-start">
                            <h4 class="fw-bold mb-0 text-warning" id="digitalClock">00:00:00 AM</h4>
                            <span class="text-white-50 small"><i class="fa-regular fa-calendar me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Action Cards and KPIs -->
    <div class="row g-4 mb-4">
        <!-- Actions Console -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-circle-play text-primary me-2"></i> Gate Quick Operations</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <button class="btn btn-primary w-100 py-3 rounded-3 shadow-sm transition-all hover-scale" onclick="openNewVisitorModal()">
                                <i class="fa-solid fa-person-walking-arrow-right fs-4 mb-2 d-block"></i>
                                <span class="fw-bold">Log New Visitor</span>
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-danger w-100 py-3 rounded-3 shadow-sm transition-all hover-scale" onclick="openEmergencyModal()">
                                <i class="fa-solid fa-triangle-exclamation fs-4 mb-2 d-block"></i>
                                <span class="fw-bold">Emergency Broadcast</span>
                            </button>
                        </div>
                        <div class="col-12">
                            <a href="/Visitor/Directory" class="btn btn-outline-secondary w-100 py-2.5 rounded-3 fw-semibold">
                                <i class="fa-solid fa-address-book me-2"></i> Search Resident Directory & Intercoms
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI Counters -->
        <div class="col-lg-6">
            <div class="row g-3 h-100">
                <div class="col-sm-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary bg-opacity-10 border-start border-primary border-4">
                        <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                            <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">Total Checked In</h6>
                            <h2 class="fw-bold text-primary mb-0 display-5">@Model.TodayTotalVisitorsCount</h2>
                        </div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning bg-opacity-10 border-start border-warning border-4">
                        <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                            <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">Currently Inside</h6>
                            <h2 class="fw-bold text-warning-emphasis mb-0 display-5">@Model.ActiveVisitorsCount</h2>
                        </div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-info bg-opacity-10 border-start border-info border-4">
                        <div class="card-body p-4 text-center d-flex flex-column justify-content-center">
                            <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">Expected Guests</h6>
                            <h2 class="fw-bold text-info mb-0 display-5">@Model.PendingApprovalsCount</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Gate Logs Grid -->
    <div class="row g-4">
        <!-- Visitors inside the society -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-hourglass-half text-warning me-2"></i> Visitors Inside Society</h5>
                        <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-1.5 rounded-pill fw-semibold">@Model.ActiveVisitors.Count Active</span>
                    </div>

                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light border-0">
                                <tr>
                                    <th class="border-0 rounded-start-3">Visitor</th>
                                    <th class="border-0">Flat</th>
                                    <th class="border-0">Entry Time</th>
                                    <th class="border-0 text-end rounded-end-3" style="width: 100px;">Checkout</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ActiveVisitors.Any())
                                {
                                    foreach (var visitor in Model.ActiveVisitors)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@visitor.FullName</div>
                                                <div class="small text-muted"><i class="fa-solid fa-phone fa-xs"></i> @visitor.PhoneNumber</div>
                                                <span class="badge bg-light text-secondary border mt-1">@visitor.VisitorType</span>
                                            </td>
                                            <td>
                                                <div class="fw-bold">@visitor.BlockName - @visitor.FlatNumber</div>
                                                @if (!string.IsNullOrEmpty(visitor.VehicleNumber))
                                                {
                                                    <span class="small text-muted"><i class="fa-solid fa-car-side"></i> @visitor.VehicleNumber</span>
                                                }
                                            </td>
                                            <td class="small text-secondary">
                                                <div class="fw-bold">@visitor.InTime.ToString("hh:mm tt")</div>
                                                <div>@visitor.InTime.ToString("dd MMM")</div>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-outline-danger btn-sm rounded-pill px-3 transition-all hover-scale" onclick="checkoutVisitor(@visitor.VisitorId, '@visitor.FullName')">
                                                    Exit <i class="fa-solid fa-arrow-right-from-bracket ms-1"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">No visitors currently inside.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Expected Pre-registered visitors -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-clock-rotate-left text-info me-2"></i> Expected Arrivals Today</h5>
                        <span class="badge bg-info bg-opacity-10 text-info px-3 py-1.5 rounded-pill fw-semibold">@Model.ExpectedVisitors.Count Pending</span>
                    </div>

                    <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                        @if (Model.ExpectedVisitors.Any())
                        {
                            foreach (var guest in Model.ExpectedVisitors)
                            {
                                <div class="list-group-item px-0 py-3 border-0 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1">@guest.FullName</h6>
                                            <div class="small text-muted mb-1"><i class="fa-solid fa-phone fa-xs"></i> @guest.PhoneNumber</div>
                                            <span class="badge bg-primary bg-opacity-10 text-primary">Pre-Registered</span>
                                            <span class="badge bg-light text-secondary border">Flat @guest.BlockName-@guest.FlatNumber</span>
                                        </div>
                                        <div class="text-end">
                                            <small class="text-secondary d-block mb-2">ETA: @guest.InTime.ToString("hh:mm tt")</small>
                                            <button class="btn btn-success btn-sm rounded-pill px-3 transition-all hover-scale" onclick="approveExpectedGuest(@guest.VisitorId, '@guest.FullName')">
                                                <i class="fa-solid fa-check me-1"></i> Allow In
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">No expected pre-registered guests today.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Log New Visitor Modal (Reuses Visitor Entry form structure) -->
<div class="modal fade" id="newVisitorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-user-plus me-2"></i> Log New Visitor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="entryForm" onsubmit="event.preventDefault(); submitVisitorEntry();">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Mobile Number <span class="text-danger">*</span></label>
                            <input type="text" id="PhoneNumber" name="PhoneNumber" class="form-control bg-light border-0" required placeholder="e.g. 9876543210" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Full Name <span class="text-danger">*</span></label>
                            <input type="text" id="FullName" name="FullName" class="form-control bg-light border-0" required placeholder="e.g. Ramesh Kumar" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Visitor Type <span class="text-danger">*</span></label>
                            <select id="VisitorType" name="VisitorType" class="form-select bg-light border-0" required>
                                <option value="">-- Select Type --</option>
                                <option value="Guest">Guest / Friend</option>
                                <option value="Delivery">Delivery (Zomato/Amazon/etc.)</option>
                                <option value="Maid/Helper">Maid / Helper</option>
                                <option value="Vendor">Vendor / Handyman</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Visiting Flat <span class="text-danger">*</span></label>
                            <select id="FlatId" name="FlatId" class="form-select bg-light border-0" required>
                                <option value="">Loading flats...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Vehicle Number (Optional)</label>
                            <input type="text" id="VehicleNumber" name="VehicleNumber" class="form-control bg-light border-0" placeholder="e.g. MH-01-AB-1234" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Purpose of Visit (Optional)</label>
                            <input type="text" id="Purpose" name="Purpose" class="form-control bg-light border-0" placeholder="e.g. Pizza delivery, AC repair" />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-semibold" id="btnSubmitVisitor">
                            <i class="fa-solid fa-circle-check me-1"></i> Grant Entry
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Emergency Broadcast Modal -->
<div class="modal fade" id="emergencyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-danger text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-triangle-exclamation me-2"></i> Broadcast Emergency Alert</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="emergencyForm" onsubmit="event.preventDefault(); submitEmergencyBroadcast();">
                    <div class="mb-3">
                        <label for="alertType" class="form-label fw-semibold small text-muted mb-1">Emergency Category</label>
                        <select id="alertType" name="alertType" class="form-select bg-light border-0" required>
                            <option value="">-- Select Alert Type --</option>
                            <option value="Fire Emergency">🔥 Fire Incident</option>
                            <option value="Medical Urgency">🚑 Medical Emergency</option>
                            <option value="Lift Breakdown">🛗 Lift Entrapment Alert</option>
                            <option value="General Security">⚠️ Security Intruder Warning</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="emergencyMessage" class="form-label fw-semibold small text-muted mb-1">Alert Broadcast Message</label>
                        <textarea id="emergencyMessage" name="emergencyMessage" class="form-control bg-light border-0" rows="3" required placeholder="Type emergency guidelines for residents..."></textarea>
                    </div>
                    <div class="alert alert-warning py-2 small border-0 bg-warning-subtle text-warning-emphasis">
                        <i class="fa-solid fa-circle-info me-1"></i> Note: This broadcast sends an immediate high-priority warning to all active society residents!
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger px-5 rounded-pill shadow-sm fw-semibold" id="btnSubmitEmergency">
                            <i class="fa-solid fa-bullhorn me-1"></i> Send Emergency Alert
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var newVisitorModal;
        var emergencyModal;

        $(document).ready(function () {
            newVisitorModal = new bootstrap.Modal(document.getElementById('newVisitorModal'));
            emergencyModal = new bootstrap.Modal(document.getElementById('emergencyModal'));

            // Start Live Clock
            updateClock();
            setInterval(updateClock, 1000);

            // Preload flats list
            loadFlats();

            // Auto-trigger emergency modal if redirected from sidebar alert
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('triggerEmergency') === 'true') {
                openEmergencyModal();
            }
        });

        // Digital Live Clock
        function updateClock() {
            var now = new Date();
            var hours = now.getHours();
            var minutes = now.getMinutes();
            var seconds = now.getSeconds();
            var ampm = hours >= 12 ? 'PM' : 'AM';
            
            hours = hours % 12;
            hours = hours ? hours : 12; // the hour '0' should be '12'
            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;
            
            var strTime = hours + ':' + minutes + ':' + seconds + ' ' + ampm;
            $('#digitalClock').text(strTime);
        }

        function loadFlats() {
            $.ajax({
                url: '/Visitor/GetFlatsDropdown',
                type: 'GET',
                success: function (res) {
                    var select = $('#FlatId');
                    select.empty();
                    select.append('<option value="">-- Select Flat --</option>');
                    res.forEach(function (f) {
                        select.append(`<option value="${f.value}">${f.text}</option>`);
                    });
                }
            });
        }

        function openNewVisitorModal() {
            $('#entryForm')[0].reset();
            newVisitorModal.show();
        }

        function openEmergencyModal() {
            $('#emergencyForm')[0].reset();
            emergencyModal.show();
        }

        function submitVisitorEntry() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var data = {
                FullName: $('#FullName').val(),
                PhoneNumber: $('#PhoneNumber').val(),
                VisitorType: $('#VisitorType').val(),
                FlatId: $('#FlatId').val(),
                VehicleNumber: $('#VehicleNumber').val(),
                Purpose: $('#Purpose').val(),
                __RequestVerificationToken: token
            };

            $('#btnSubmitVisitor').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Granting...');

            $.ajax({
                url: '/Visitor/Entry',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        newVisitorModal.hide();
                        Swal.fire({ icon: 'success', title: 'Entry Granted!', text: res.message, showConfirmButton: false, timer: 1500 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitVisitor').prop('disabled', false).html('<i class="fa-solid fa-circle-check me-1"></i> Grant Entry');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitVisitor').prop('disabled', false).html('<i class="fa-solid fa-circle-check me-1"></i> Grant Entry');
                }
            });
        }

        function checkoutVisitor(id, name) {
            Swal.fire({
                title: 'Confirm Checkout',
                text: `Mark ${name} as Exited?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Checkout'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Visitor/Checkout/' + id,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 1500 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        function approveExpectedGuest(id, name) {
            Swal.fire({
                title: 'Approve Entry',
                text: `Allow pre-registered guest ${name} inside?`,
                icon: 'success',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Allow Entry'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Visitor/Approve/' + id,
                        type: 'POST',
                        data: { __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 1500 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        function submitEmergencyBroadcast() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var data = {
                alertType: $('#alertType').val(),
                message: $('#emergencyMessage').val(),
                __RequestVerificationToken: token
            };

            $('#btnSubmitEmergency').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Broadcasting...');

            $.ajax({
                url: '/Notification/BroadcastEmergency',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        emergencyModal.hide();
                        Swal.fire({ icon: 'warning', title: 'Broadcast Dispatched!', text: res.message, showConfirmButton: true });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                    $('#btnSubmitEmergency').prop('disabled', false).html('<i class="fa-solid fa-bullhorn me-1"></i> Send Emergency Alert');
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitEmergency').prop('disabled', false).html('<i class="fa-solid fa-bullhorn me-1"></i> Send Emergency Alert');
                }
            });
        }
    </script>
    <style>
        .transition-all {
            transition: all 0.25s ease-in-out;
        }
        .hover-scale:hover {
            transform: scale(1.04);
        }
        .uppercase {
            text-transform: uppercase;
        }
        .tracking-wider {
            letter-spacing: 0.08em;
        }
        .opacity-20 {
            opacity: 0.2;
        }
    </style>
}
