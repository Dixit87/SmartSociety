@model SmartSociety.Models.TechnicianDashboardViewModel
@{
    ViewData["Title"] = "Technician Job Terminal";
}

<div class="container-fluid py-4">
    <!-- Header Card -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 rounded-4 shadow-sm text-white" style="background: linear-gradient(135deg, #134e5e 0%, #71b280 100%);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-white bg-opacity-25 rounded-circle p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 58px; height: 58px;">
                                <i class="fa-solid fa-screwdriver-wrench fs-4"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">Technician Maintenance Console</h3>
                                <p class="mb-0 text-white-50 small">Manage assigned jobs, update repairs status, and monitor facility equipment.</p>
                            </div>
                        </div>
                        <div class="text-md-end text-start">
                            <h4 class="fw-bold mb-0 text-warning" id="digitalClock">00:00:00 AM</h4>
                            <span class="text-white bg-dark bg-opacity-25 px-3 py-1.5 rounded-pill small fw-semibold"><i class="fa-regular fa-calendar me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats KPI Counters -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary bg-opacity-10 border-start border-primary border-4 card-kpi" onclick="filterTab('assigned')">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">Assigned Dues</h6>
                        <h2 class="fw-bold text-primary mb-0 display-6">@Model.AssignedComplaintsCount</h2>
                    </div>
                    <div class="bg-primary text-white rounded-3 p-3 shadow-sm"><i class="fa-solid fa-envelope-open-text fs-4"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-warning bg-opacity-10 border-start border-warning border-4 card-kpi" onclick="filterTab('progress')">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">In Progress</h6>
                        <h2 class="fw-bold text-warning-emphasis mb-0 display-6">@Model.InProgressComplaintsCount</h2>
                    </div>
                    <div class="bg-warning text-white rounded-3 p-3 shadow-sm"><i class="fa-solid fa-person-digging fs-4"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-success bg-opacity-10 border-start border-success border-4 card-kpi" onclick="filterTab('resolved')">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted small fw-bold mb-1 uppercase tracking-wider">Completed Jobs</h6>
                        <h2 class="fw-bold text-success mb-0 display-6">@Model.ResolvedComplaintsCount</h2>
                    </div>
                    <div class="bg-success text-white rounded-3 p-3 shadow-sm"><i class="fa-solid fa-check-double fs-4"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Job List -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-header bg-white border-bottom pt-4 pb-0 px-4">
                    <ul class="nav nav-tabs border-bottom-0" id="technicianTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-bold text-primary border-0" id="assigned-tab" data-bs-toggle="tab" data-bs-target="#activeJobs" type="button" role="tab">
                                <i class="fa-solid fa-list-check me-1"></i> Active Tasks (@Model.ActiveComplaints.Count)
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold text-secondary border-0" id="history-tab" data-bs-toggle="tab" data-bs-target="#resolvedHistory" type="button" role="tab">
                                <i class="fa-solid fa-clock-rotate-left me-1"></i> Work History (@Model.ResolvedHistory.Count)
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-4">
                    <div class="tab-content" id="technicianTabsContent">
                        <!-- Active Tasks -->
                        <div class="tab-pane fade show active" id="activeJobs" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="border-0 rounded-start-3">Ticket</th>
                                            <th class="border-0">Category & Location</th>
                                            <th class="border-0">Priority</th>
                                            <th class="border-0 text-end rounded-end-3">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ActiveComplaints.Any())
                                        {
                                            foreach (var c in Model.ActiveComplaints)
                                            {
                                                <tr class="task-row" data-status="@c.Status">
                                                    <td>
                                                        <div class="fw-bold text-dark">#@c.ComplaintId</div>
                                                        <small class="text-muted">@c.CreatedAt.ToString("dd MMM yyyy")</small>
                                                    </td>
                                                    <td>
                                                        <div class="fw-bold">@c.Title</div>
                                                        <div class="small text-secondary">
                                                            <span class="badge bg-light text-secondary border me-1">@c.Category</span>
                                                            <i class="fa-solid fa-location-dot fa-xs text-muted"></i> Flat @c.BlockName-@c.FlatNumber (@c.ResidentName)
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <span class="badge @c.GetPriorityBadgeClass() px-2.5 py-1">@c.Priority</span>
                                                        <span class="badge @c.GetStatusBadgeClass() px-2.5 py-1 text-uppercase small" style="font-size: 0.7rem;"><i class="@c.GetStatusIcon() me-1"></i> @c.Status</span>
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="btn-group shadow-sm rounded-pill">
                                                            <button class="btn btn-sm btn-outline-secondary px-3" onclick="viewComplaintDetails(@c.ComplaintId, '@Uri.EscapeDataString(c.Title)', '@Uri.EscapeDataString(c.Description)', '@c.Category', '@c.Priority', '@c.BlockName-@c.FlatNumber', '@c.ResidentName', '@c.PhotoUrl')">
                                                                <i class="fa-solid fa-circle-info"></i> View
                                                            </button>
                                                            @if(c.Status == "Open")
                                                            {
                                                                <button class="btn btn-sm btn-warning px-3 fw-semibold" onclick="updateStatus(@c.ComplaintId, 'InProgress')">
                                                                    <i class="fa-solid fa-person-digging me-1"></i> Start
                                                                </button>
                                                            }
                                                            else if(c.Status == "InProgress")
                                                            {
                                                                <button class="btn btn-sm btn-success px-3 fw-semibold" onclick="openResolveModal(@c.ComplaintId, '@Uri.EscapeDataString(c.Title)')">
                                                                    <i class="fa-solid fa-check me-1"></i> Resolve
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 text-muted">
                                                    <i class="fa-solid fa-circle-check text-success fs-1 mb-3 opacity-50"></i>
                                                    <p class="mb-0 fw-bold">All caught up! No active tasks assigned.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Resolved History -->
                        <div class="tab-pane fade" id="resolvedHistory" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="border-0 rounded-start-3">Ticket</th>
                                            <th class="border-0">Category & Location</th>
                                            <th class="border-0">Completed Date</th>
                                            <th class="border-0 text-end rounded-end-3">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.ResolvedHistory.Any())
                                        {
                                            foreach (var c in Model.ResolvedHistory)
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold text-dark">#@c.ComplaintId</div>
                                                        <small class="text-muted">@c.CreatedAt.ToString("dd MMM")</small>
                                                    </td>
                                                    <td>
                                                        <div class="fw-bold">@c.Title</div>
                                                        <div class="small text-secondary">
                                                            <span class="badge bg-light text-secondary border me-1">@c.Category</span>
                                                            <i class="fa-solid fa-location-dot fa-xs text-muted"></i> Flat @c.BlockName-@c.FlatNumber
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="fw-bold text-success"><i class="fa-solid fa-circle-check me-1"></i> Completed</div>
                                                        <small class="text-muted">@c.UpdatedAt.ToString("dd MMM yyyy hh:mm tt")</small>
                                                    </td>
                                                    <td class="text-end">
                                                        <button class="btn btn-sm btn-light border px-3 rounded-pill" onclick="viewComplaintDetails(@c.ComplaintId, '@Uri.EscapeDataString(c.Title)', '@Uri.EscapeDataString(c.Description)', '@c.Category', '@c.Priority', '@c.BlockName-@c.FlatNumber', '@c.ResidentName', '@c.PhotoUrl', '@Uri.EscapeDataString(c.AdminRemarks ?? "")')">
                                                            <i class="fa-solid fa-file-invoice me-1"></i> View Log
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 text-muted">No completed jobs yet.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Maintenance Alerts -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-triangle-exclamation text-warning me-2"></i> Facilities & AMC Alerts</h5>
                    <p class="text-muted small">Equipments requiring AMC service logs within next 30 days.</p>
                    
                    <div class="list-group list-group-flush mt-3" style="max-height: 420px; overflow-y: auto;">
                        @if (Model.AssetsRequiringService.Any())
                        {
                            foreach (var asset in Model.AssetsRequiringService)
                            {
                                <div class="list-group-item px-0 py-3 border-0 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1">@asset.AssetName</h6>
                                            <div class="small text-muted mb-1"><i class="fa-solid fa-location-dot me-1 text-muted"></i> @asset.Location</div>
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle">AMC Expiry Soon</span>
                                            <span class="badge bg-light text-secondary border">@asset.AssetType</span>
                                        </div>
                                        <div class="text-end">
                                            <small class="text-danger d-block mb-2 fw-semibold">
                                                Expiry: @asset.AmcExpiryDate?.ToString("dd MMM")
                                            </small>
                                            <a href="/AssetVendor/Index?activeTab=service" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                Log Service
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="fa-solid fa-circle-check text-success fs-1 mb-2 opacity-50 d-block"></i>
                                <span class="small fw-semibold">All facilities are contractually covered and serviced.</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================= MODALS ================= -->

<!-- View Complaint Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-dark text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-circle-info me-2"></i> Complaint Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div class="row g-3">
                    <div class="col-md-7">
                        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 mb-3">
                            <h6 class="fw-bold text-muted small uppercase mb-2">Complaint Info</h6>
                            <h4 class="fw-bold text-dark mb-1" id="detailTitle">Title</h4>
                            <p class="text-secondary small mb-3" id="detailDescription">Description</p>
                            
                            <div class="row g-2 border-top pt-3 text-secondary small">
                                <div class="col-sm-6"><strong>Ticket ID:</strong> <span id="detailTicket">#0</span></div>
                                <div class="col-sm-6"><strong>Category:</strong> <span id="detailCategory">Electric</span></div>
                                <div class="col-sm-6"><strong>Flat:</strong> <span id="detailFlat">A-101</span></div>
                                <div class="col-sm-6"><strong>Resident:</strong> <span id="detailResident">Name</span></div>
                                <div class="col-sm-6"><strong>Priority:</strong> <span id="detailPriority" class="badge">High</span></div>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm rounded-3 bg-white p-3" id="detailRemarksCard" style="display: none;">
                            <h6 class="fw-bold text-muted small uppercase mb-1">Technician Remarks Log</h6>
                            <p class="mb-0 text-dark small" id="detailRemarks">Remarks text</p>
                        </div>
                    </div>
                    <div class="col-md-5 text-center">
                        <div class="card border-0 shadow-sm rounded-3 bg-white p-3 h-100 d-flex flex-column justify-content-center align-items-center">
                            <h6 class="fw-bold text-muted small uppercase mb-3 align-self-start">Attached Photo</h6>
                            <div id="detailPhotoContainer" class="w-100">
                                <img src="/images/placeholder-image.png" class="img-fluid rounded border shadow-sm" style="max-height: 220px;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Resolve Complaint Modal -->
<div class="modal fade" id="resolveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-success text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-circle-check me-2"></i> Resolve Complaint</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="resolveForm" onsubmit="event.preventDefault(); submitResolve();">
                    <input type="hidden" id="resolveId" />
                    
                    <div class="alert alert-success bg-success bg-opacity-10 text-success-emphasis border-0 mb-4 py-2 small">
                        <i class="fa-solid fa-circle-info me-1"></i> You are marking the ticket <strong id="resolveTitleText">#</strong> as resolved. Please provide details.
                    </div>

                    <div class="mb-3">
                        <label for="resolveRemarks" class="form-label fw-semibold small text-muted mb-1">Technician Remarks / Actions Taken <span class="text-danger">*</span></label>
                        <textarea id="resolveRemarks" name="remarks" class="form-control bg-light border-0" rows="3" required placeholder="Describe details of repairs completed..."></textarea>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-semibold" id="btnSubmitResolve">
                            <i class="fa-solid fa-check me-2"></i> Mark As Resolved
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var detailsModal;
        var resolveModal;

        $(document).ready(function () {
            detailsModal = new bootstrap.Modal(document.getElementById('detailsModal'));
            resolveModal = new bootstrap.Modal(document.getElementById('resolveModal'));

            // Live digital clock
            updateClock();
            setInterval(updateClock, 1000);

            // Filter dashboard parameters on load
            const urlParams = new URLSearchParams(window.location.search);
            const filter = urlParams.get('filter');
            if (filter) {
                filterTab(filter);
            }

            // Manual tab click listener to reset filter and clear URL param
            $('#assigned-tab').on('click', function () {
                $('.task-row').show();
                const url = new URL(window.location);
                if (url.searchParams.has('filter')) {
                    url.searchParams.delete('filter');
                    window.history.pushState({}, '', url);
                }
            });
        });

        function updateClock() {
            var now = new Date();
            var hours = now.getHours();
            var minutes = now.getMinutes();
            var seconds = now.getSeconds();
            var ampm = hours >= 12 ? 'PM' : 'AM';
            
            hours = hours % 12;
            hours = hours ? hours : 12;
            minutes = minutes < 10 ? '0' + minutes : minutes;
            seconds = seconds < 10 ? '0' + seconds : seconds;
            
            var strTime = hours + ':' + minutes + ':' + seconds + ' ' + ampm;
            $('#digitalClock').text(strTime);
        }

        function filterTab(tab) {
            $('.task-row').show();

            if (tab === 'assigned') {
                var tabEl = document.getElementById('assigned-tab');
                if (tabEl) bootstrap.Tab.getOrCreateInstance(tabEl).show();
                $('.task-row').each(function () {
                    var status = $(this).data('status');
                    if (status && status !== 'Open') {
                        $(this).hide();
                    }
                });
            } else if (tab === 'progress') {
                var tabEl = document.getElementById('assigned-tab');
                if (tabEl) bootstrap.Tab.getOrCreateInstance(tabEl).show();
                $('.task-row').each(function () {
                    var status = $(this).data('status');
                    if (status && status !== 'InProgress') {
                        $(this).hide();
                    }
                });
            } else if (tab === 'resolved' || tab === 'history') {
                var tabEl = document.getElementById('history-tab');
                if (tabEl) bootstrap.Tab.getOrCreateInstance(tabEl).show();
            }
        }

        function viewComplaintDetails(id, title, desc, cat, priority, flat, resident, photoUrl, remarks) {
            $('#detailTicket').text('#' + id);
            $('#detailTitle').text(decodeURIComponent(title));
            $('#detailDescription').text(decodeURIComponent(desc));
            $('#detailCategory').text(cat);
            $('#detailFlat').text(flat);
            $('#detailResident').text(resident);
            $('#detailPriority').text(priority).removeClass().addClass('badge ' + getPriorityClass(priority));

            if (remarks) {
                $('#detailRemarks').text(decodeURIComponent(remarks));
                $('#detailRemarksCard').show();
            } else {
                $('#detailRemarksCard').hide();
            }

            if (photoUrl && photoUrl !== 'null' && photoUrl !== '') {
                $('#detailPhotoContainer').html('<img src="' + photoUrl + '" class="img-fluid rounded border shadow-sm" style="max-height: 220px;" />');
            } else {
                $('#detailPhotoContainer').html('<div class="bg-light rounded border py-5 text-muted small"><i class="fa-solid fa-image fs-1 mb-2 d-block opacity-25"></i> No photo attached</div>');
            }

            detailsModal.show();
        }

        function getPriorityClass(p) {
            if (p === 'Emergency') return 'bg-danger';
            if (p === 'High') return 'bg-warning text-dark';
            if (p === 'Medium') return 'bg-info text-dark';
            return 'bg-secondary';
        }

        function updateStatus(complaintId, status) {
            Swal.fire({
                title: 'Start work?',
                text: 'Mark this complaint status as In Progress?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#ffc107',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Start Work'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Complaint/UpdateStatus',
                        type: 'POST',
                        data: { complaintId: complaintId, status: status, adminRemarks: 'Work started by technician.', __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Work Started!', showConfirmButton: false, timer: 1500 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        function openResolveModal(id, title) {
            $('#resolveForm')[0].reset();
            $('#resolveId').val(id);
            $('#resolveTitleText').text('"' + decodeURIComponent(title) + '"');
            resolveModal.show();
        }

        function submitResolve() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var id = $('#resolveId').val();
            var remarks = $('#resolveRemarks').val();

            $('#btnSubmitResolve').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Resolving...');

            $.ajax({
                url: '/Complaint/UpdateStatus',
                type: 'POST',
                data: { complaintId: id, status: 'Resolved', adminRemarks: remarks, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        resolveModal.hide();
                        Swal.fire({ icon: 'success', title: 'Ticket Resolved!', text: 'Resident has been notified of completion.', showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitResolve').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Mark As Resolved');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitResolve').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Mark As Resolved');
                }
            });
        }
    </script>
    <style>
        .card-kpi {
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card-kpi:hover {
            transform: translateY(-4px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08)!important;
        }
        .uppercase {
            text-transform: uppercase;
        }
        .tracking-wider {
            letter-spacing: 0.08em;
        }
    </style>
}
