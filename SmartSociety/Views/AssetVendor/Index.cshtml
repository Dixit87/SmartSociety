@model Tuple<IEnumerable<SmartSociety.Models.Asset>, IEnumerable<SmartSociety.Models.Vendor>>

@{
    ViewData["Title"] = "Assets & Vendor Management";
    var assets = Model.Item1;
    var vendors = Model.Item2;
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<style>
    .nav-tabs .nav-link {
        color: #495057;
        font-weight: 600;
        border: none;
        padding: 12px 24px;
        margin-right: 5px;
        border-radius: 8px 8px 0 0;
        transition: all 0.2s;
    }
    .nav-tabs .nav-link:hover {
        background-color: #f8f9fa;
        color: #0d6efd;
    }
    .nav-tabs .nav-link.active {
        color: #0d6efd;
        background-color: #fff;
        border-bottom: 3px solid #0d6efd;
    }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Admin</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Assets & Vendor Management</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1 text-dark"><i class="fa-solid fa-toolbox text-primary me-2"></i> Assets & Vendors</h2>
        <p class="text-muted mb-0">Manage society infrastructure, AMCs, and external service providers.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-dark fw-bold px-4 rounded-pill shadow-sm" onclick="openVendorModal()">
            <i class="fa-solid fa-user-tie me-2"></i> Add Vendor
        </button>
        <button class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm" onclick="openAssetModal()">
            <i class="fa-solid fa-plus me-2"></i> Add Asset
        </button>
    </div>
</div>

<!-- Dashboard Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="bg-primary bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-boxes-stacked fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Total Assets</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalAssets</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-warning bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-warning text-dark rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Expiring AMCs (30 Days)</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.ExpiringAMCs</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-success bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-users-gear fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Active Vendors</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalVendors</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <ul class="nav nav-tabs border-bottom" id="assetVendorTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(ViewBag.ActiveTab == "assets" ? "active" : "")" id="assets-tab" data-bs-toggle="tab" data-bs-target="#assets" type="button" role="tab">
                    <i class="fa-solid fa-boxes-stacked me-2"></i> Society Assets
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(ViewBag.ActiveTab == "vendors" ? "active" : "")" id="vendors-tab" data-bs-toggle="tab" data-bs-target="#vendors" type="button" role="tab">
                    <i class="fa-solid fa-users-gear me-2"></i> External Vendors
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body p-4">
        <div class="tab-content" id="assetVendorTabsContent">
            
            <!-- ASSETS TAB -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "assets" ? "show active" : "")" id="assets" role="tabpanel">
                <table class="table table-hover align-middle w-100" id="assetsTable">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold text-muted py-3">Asset Name</th>
                            <th class="fw-semibold text-muted py-3">Type & Location</th>
                            <th class="fw-semibold text-muted py-3">AMC Vendor</th>
                            <th class="fw-semibold text-muted py-3">AMC Expiry</th>
                            <th class="fw-semibold text-muted py-3">Status</th>
                            <th class="fw-semibold text-muted py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in assets)
                        {
                            <tr>
                                <td class="py-3">
                                    <h6 class="fw-bold text-dark mb-1">@a.AssetName</h6>
                                    <div class="small text-muted fw-semibold">Pur: @a.PurchaseDate.ToString("dd MMM yyyy") | ₹@a.PurchaseCost</div>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3 py-1 mb-1">@a.AssetType</span>
                                    <div class="small text-dark fw-semibold"><i class="fa-solid fa-location-dot text-danger me-1"></i> @a.Location</div>
                                </td>
                                <td class="py-3">
                                    @if (!string.IsNullOrEmpty(a.VendorName))
                                    {
                                        <div class="fw-semibold text-primary"><i class="fa-solid fa-shield-halved me-1"></i> @a.VendorName</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">No AMC Assigned</span>
                                    }
                                </td>
                                <td class="py-3">
                                    @if (a.AmcExpiryDate.HasValue)
                                    {
                                        var isExpiring = a.AmcExpiryDate.Value <= DateTime.Now.AddDays(30) && a.AmcExpiryDate.Value >= DateTime.Now;
                                        var isExpired = a.AmcExpiryDate.Value < DateTime.Now;
                                        var textClass = isExpired ? "text-danger" : (isExpiring ? "text-warning text-dark" : "text-success");
                                        
                                        <div class="fw-bold @textClass">
                                            @if (isExpired) { <i class="fa-solid fa-circle-xmark me-1"></i> }
                                            else if (isExpiring) { <i class="fa-solid fa-triangle-exclamation me-1"></i> }
                                            else { <i class="fa-solid fa-circle-check me-1"></i> }
                                            @a.AmcExpiryDate.Value.ToString("dd MMM yyyy")
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                                <td class="py-3">
                                    @if (a.Status == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check me-1"></i> Active</span>
                                    }
                                    else if (a.Status == "Under Maintenance")
                                    {
                                        <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill"><i class="fa-solid fa-screwdriver-wrench me-1"></i> Maintenance</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-ban me-1"></i> Decommissioned</span>
                                    }
                                </td>
                                <td class="py-3 text-end">
                                    <div class="btn-group shadow-sm">
                                        <button type="button" class="btn btn-light btn-sm text-info" title="Service History" 
                                                onclick="openServiceHistoryModal(@a.AssetId, '@Uri.EscapeDataString(a.AssetName)')">
                                            <i class="fa-solid fa-clipboard-list"></i>
                                        </button>
                                        <button type="button" class="btn btn-light btn-sm text-primary" title="Edit Asset"
                                                onclick="openEditAssetModal(@a.AssetId, '@Uri.EscapeDataString(a.AssetName)', '@a.AssetType', '@Uri.EscapeDataString(a.Location)', '@a.PurchaseDate.ToString("yyyy-MM-dd")', '@a.PurchaseCost', '@a.VendorId', '@(a.AmcExpiryDate?.ToString("yyyy-MM-dd") ?? "")', '@a.Status', '@(a.InvoiceDocumentPath ?? "")')">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button type="button" class="btn btn-light btn-sm text-danger" title="Delete Asset" 
                                                onclick="deleteAsset(@a.AssetId)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- VENDORS TAB -->
            <div class="tab-pane fade @(ViewBag.ActiveTab == "vendors" ? "show active" : "")" id="vendors" role="tabpanel">
                <table class="table table-hover align-middle w-100" id="vendorsTable">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold text-muted py-3">Vendor Name</th>
                            <th class="fw-semibold text-muted py-3">Category</th>
                            <th class="fw-semibold text-muted py-3">Contact Details</th>
                            <th class="fw-semibold text-muted py-3">Contract Validity</th>
                            <th class="fw-semibold text-muted py-3">Status</th>
                            <th class="fw-semibold text-muted py-3 text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in vendors)
                        {
                            <tr>
                                <td class="py-3">
                                    <h6 class="fw-bold text-dark mb-1">@v.VendorName</h6>
                                    @if (v.Rating.HasValue && v.Rating > 0)
                                    {
                                        <div class="small text-warning mt-1">
                                            @for (int i = 0; i < v.Rating; i++) { <i class="fa-solid fa-star"></i> }
                                            @for (int i = v.Rating.Value; i < 5; i++) { <i class="fa-regular fa-star text-muted"></i> }
                                        </div>
                                    }
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-info-subtle text-info-emphasis rounded-pill px-3 py-2">@v.ServiceCategory</span>
                                </td>
                                <td class="py-3">
                                    <div class="small fw-semibold text-dark mb-1"><i class="fa-solid fa-user me-1 text-muted"></i> @v.ContactPerson</div>
                                    <div class="small text-muted"><i class="fa-solid fa-phone me-1"></i> @v.PhoneNumber</div>
                                </td>
                                <td class="py-3">
                                    <div class="small fw-semibold text-dark"><span class="text-muted">Start:</span> @v.ContractStartDate.ToString("dd MMM yy")</div>
                                    <div class="small fw-bold text-primary mt-1"><span class="text-muted fw-normal">End:</span> @v.ContractEndDate.ToString("dd MMM yy")</div>
                                </td>
                                <td class="py-3">
                                    @if (v.Status == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-check me-1"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-xmark me-1"></i> Inactive</span>
                                    }
                                </td>
                                <td class="py-3 text-end">
                                    <div class="btn-group shadow-sm">
                                        @if (!string.IsNullOrEmpty(v.ContractDocumentPath))
                                        {
                                            <a href="@v.ContractDocumentPath" target="_blank" class="btn btn-light btn-sm text-success" title="View Contract">
                                                <i class="fa-solid fa-file-pdf"></i>
                                            </a>
                                        }
                                        <button type="button" class="btn btn-light btn-sm text-primary" title="Edit Vendor"
                                                onclick="openEditVendorModal(@v.VendorId, '@Uri.EscapeDataString(v.VendorName)', '@v.ServiceCategory', '@Uri.EscapeDataString(v.ContactPerson)', '@v.PhoneNumber', '@v.Email', '@v.ContractStartDate.ToString("yyyy-MM-dd")', '@v.ContractEndDate.ToString("yyyy-MM-dd")', '@v.ContractCost', '@v.Status', '@(v.ContractDocumentPath ?? "")', '@(v.Rating ?? 0)')">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button type="button" class="btn btn-light btn-sm text-danger" title="Delete Vendor" 
                                                onclick="deleteVendor(@v.VendorId)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Add/Edit Asset Modal -->
<div class="modal fade" id="assetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="assetModalTitle"><i class="fa-solid fa-box-open me-2"></i> Add Asset</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="assetForm" onsubmit="event.preventDefault(); submitAsset();" enctype="multipart/form-data">
                    <input type="hidden" id="aId" name="assetId" value="0" />
                    
                    <h6 class="fw-bold text-primary mb-3 border-bottom pb-2">Asset Details</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Asset Name <span class="text-danger">*</span></label>
                            <input type="text" id="aName" name="assetName" class="form-control bg-light border-0 py-2" required placeholder="e.g. Lift Tower A, DG Set 1" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Asset Type <span class="text-danger">*</span></label>
                            <select id="aType" name="assetType" class="form-select bg-light border-0 py-2" required>
                                <option value="">Select Type</option>
                                <option value="Elevator">Elevator / Lift</option>
                                <option value="Generator">Generator</option>
                                <option value="Water Pump">Water Pump</option>
                                <option value="Gym Equipment">Gym Equipment</option>
                                <option value="Security System">Security System / CCTV</option>
                                <option value="Fire Safety">Fire Safety Equipment</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Location <span class="text-danger">*</span></label>
                            <input type="text" id="aLocation" name="location" class="form-control bg-light border-0 py-2" required placeholder="e.g. Tower A Lobby, Basement, Clubhouse" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Purchase Date <span class="text-danger">*</span></label>
                            <input type="date" id="aPurchaseDate" name="purchaseDate" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Purchase Cost (₹)</label>
                            <input type="number" step="0.01" id="aPurchaseCost" name="purchaseCost" class="form-control bg-light border-0 py-2" />
                        </div>
                        <div class="col-md-12 border-top pt-3 mt-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Purchase Invoice (PDF/Image)</label>
                            <input type="file" id="aInvoice" name="invoiceFile" class="form-control bg-light border-0 py-2" accept=".pdf,image/*" />
                            <div id="currentInvoiceDiv" class="mt-2 d-none">
                                <span class="badge bg-success-subtle text-success-emphasis p-2">
                                    <i class="fa-solid fa-file-pdf me-1"></i> Current Invoice 
                                    <a href="#" id="nCurrentInvoiceLink" target="_blank" class="ms-2 fw-bold text-decoration-none">View</a>
                                </span>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-info mb-3 border-bottom pb-2">AMC & Maintenance</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">AMC Provider (Vendor)</label>
                            <select id="aVendorId" name="vendorId" class="form-select bg-light border-0 py-2">
                                <option value="0">-- No AMC Assigned --</option>
                                @foreach (var v in ViewBag.VendorList)
                                {
                                    <option value="@v.VendorId">@v.VendorName (@v.ServiceCategory)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">AMC Expiry Date</label>
                            <input type="date" id="aAmcExpiryDate" name="amcExpiryDate" class="form-control bg-light border-0 py-2" />
                        </div>
                        <div class="col-12 mt-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Current Status <span class="text-danger">*</span></label>
                            <select id="aStatus" name="status" class="form-select bg-light border-0 py-2" required>
                                <option value="Active">Active & Working</option>
                                <option value="Under Maintenance">Under Maintenance</option>
                                <option value="Decommissioned">Decommissioned / Broken</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitAsset">
                            <i class="fa-solid fa-save me-2"></i> Save Asset
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Vendor Modal -->
<div class="modal fade" id="vendorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-dark text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="vendorModalTitle"><i class="fa-solid fa-user-tie me-2"></i> Add Vendor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="vendorForm" onsubmit="event.preventDefault(); submitVendor();" enctype="multipart/form-data">
                    <input type="hidden" id="vId" name="vendorId" value="0" />
                    
                    <h6 class="fw-bold text-dark mb-3 border-bottom pb-2">Vendor Information</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Company / Vendor Name <span class="text-danger">*</span></label>
                            <input type="text" id="vName" name="vendorName" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Service Category <span class="text-danger">*</span></label>
                            <select id="vCategory" name="serviceCategory" class="form-select bg-light border-0 py-2" required>
                                <option value="">Select Category</option>
                                <option value="Lift Maintenance">Lift Maintenance</option>
                                <option value="Plumbing">Plumbing</option>
                                <option value="Electrical">Electrical & Generator</option>
                                <option value="Security Agency">Security Agency</option>
                                <option value="Housekeeping">Housekeeping & Cleaning</option>
                                <option value="Pest Control">Pest Control</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Contact Person <span class="text-danger">*</span></label>
                            <input type="text" id="vContactPerson" name="contactPerson" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Phone Number <span class="text-danger">*</span></label>
                            <input type="text" id="vPhone" name="phoneNumber" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Email Address</label>
                            <input type="email" id="vEmail" name="email" class="form-control bg-light border-0 py-2" />
                        </div>
                    </div>

                    <h6 class="fw-bold text-success mb-3 border-bottom pb-2">Contract Details</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Contract Start Date <span class="text-danger">*</span></label>
                            <input type="date" id="vStartDate" name="contractStartDate" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Contract End Date <span class="text-danger">*</span></label>
                            <input type="date" id="vEndDate" name="contractEndDate" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Annual Contract Cost (₹)</label>
                            <input type="number" step="0.01" id="vCost" name="contractCost" class="form-control bg-light border-0 py-2" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Status <span class="text-danger">*</span></label>
                            <select id="vStatus" name="status" class="form-select bg-light border-0 py-2" required>
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive / Terminated</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold small text-muted mb-1">Rating</label>
                            <select id="vRating" name="rating" class="form-select bg-light border-0 py-2">
                                <option value="0">Not Rated</option>
                                <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                <option value="4">⭐⭐⭐⭐ (Good)</option>
                                <option value="3">⭐⭐⭐ (Average)</option>
                                <option value="2">⭐⭐ (Poor)</option>
                                <option value="1">⭐ (Terrible)</option>
                            </select>
                        </div>
                        <div class="col-12 border-top pt-3 mt-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Contract Document (PDF)</label>
                            <input type="file" id="vContractFile" name="contractFile" class="form-control bg-light border-0 py-2" accept=".pdf,image/*" />
                            <div id="currentContractDiv" class="mt-2 d-none">
                                <span class="badge bg-primary-subtle text-primary-emphasis p-2">
                                    <i class="fa-solid fa-file-contract me-1"></i> Current Contract 
                                    <a href="#" id="nCurrentContractLink" target="_blank" class="ms-2 fw-bold text-decoration-none">View</a>
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-dark px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitVendor">
                            <i class="fa-solid fa-save me-2"></i> Save Vendor
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Service History Modal -->
<div class="modal fade" id="serviceHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-info text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="shModalTitle"><i class="fa-solid fa-clipboard-list me-2"></i> Service History</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 bg-white">
                <div class="p-4 bg-light border-bottom">
                    <form id="serviceLogForm" onsubmit="event.preventDefault(); submitServiceLog();">
                        <input type="hidden" id="shLogId" name="logId" value="0" />
                        <input type="hidden" id="shAssetId" name="assetId" value="0" />
                        
                        <h6 class="fw-bold text-dark mb-3">Add New Maintenance Record</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold small text-muted mb-1">Service Date <span class="text-danger">*</span></label>
                                <input type="date" id="shDate" name="serviceDate" class="form-control bg-white border-0 py-2 shadow-sm" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold small text-muted mb-1">Cost (₹)</label>
                                <input type="number" step="0.01" id="shCost" name="cost" class="form-control bg-white border-0 py-2 shadow-sm" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-semibold small text-muted mb-1">Vendor (Optional)</label>
                                <select id="shVendor" name="vendorId" class="form-select bg-white border-0 py-2 shadow-sm">
                                    <option value="0">-- Internal / Other --</option>
                                    @foreach (var v in ViewBag.VendorList)
                                    {
                                        <option value="@v.VendorId">@v.VendorName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-9">
                                <label class="form-label fw-semibold small text-muted mb-1">Description / Parts Replaced <span class="text-danger">*</span></label>
                                <input type="text" id="shDesc" name="description" class="form-control bg-white border-0 py-2 shadow-sm" required placeholder="e.g. Changed motor belt, oil filter..." />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-info text-white fw-bold w-100 rounded-pill shadow-sm" id="btnSaveLog">
                                    <i class="fa-solid fa-plus me-1"></i> Add Log
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="p-4" style="max-height: 400px; overflow-y: auto;">
                    <h6 class="fw-bold text-muted mb-3">Past Records</h6>
                    <div id="serviceLogContainer">
                        <div class="text-center py-4 text-muted"><i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i><br>Loading history...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        var assetModal, vendorModal, serviceHistoryModal;

        $(document).ready(function () {
            $('#assetsTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": { "search": "", "searchPlaceholder": "Search Assets..." },
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
            });
            
            $('#vendorsTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": { "search": "", "searchPlaceholder": "Search Vendors..." },
                "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
            });
            
            $('.dataTables_filter input').addClass('form-control form-control-sm border-0 shadow-sm bg-light').css('width', '250px');

            assetModal = new bootstrap.Modal(document.getElementById('assetModal'));
            vendorModal = new bootstrap.Modal(document.getElementById('vendorModal'));
            serviceHistoryModal = new bootstrap.Modal(document.getElementById('serviceHistoryModal'));
        });

        // --- ASSET FUNCTIONS ---
        function openAssetModal() {
            $('#assetForm')[0].reset();
            $('#aId').val('0');
            $('#currentInvoiceDiv').addClass('d-none');
            $('#assetModalTitle').html('<i class="fa-solid fa-box-open me-2"></i> Add Asset');
            assetModal.show();
        }

        function openEditAssetModal(id, name, type, location, pDate, pCost, vId, amcDate, status, invoicePath) {
            $('#assetForm')[0].reset();
            $('#aId').val(id);
            $('#aName').val(decodeURIComponent(name));
            $('#aType').val(type);
            $('#aLocation').val(decodeURIComponent(location));
            $('#aPurchaseDate').val(pDate);
            $('#aPurchaseCost').val(pCost);
            $('#aVendorId').val(vId || '0');
            $('#aAmcExpiryDate').val(amcDate);
            $('#aStatus').val(status);
            
            if(invoicePath && invoicePath !== '') {
                $('#currentInvoiceDiv').removeClass('d-none');
                $('#nCurrentInvoiceLink').attr('href', invoicePath);
            } else {
                $('#currentInvoiceDiv').addClass('d-none');
            }
            
            $('#assetModalTitle').html('<i class="fa-solid fa-pen-to-square me-2"></i> Edit Asset');
            assetModal.show();
        }

        function submitAsset() {
            var form = $('#assetForm')[0];
            var formData = new FormData(form);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $('#btnSubmitAsset').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

            $.ajax({
                url: '/AssetVendor/SaveAsset',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => window.location.href = '/AssetVendor?activeTab=assets', 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitAsset').prop('disabled', false).html('<i class="fa-solid fa-save me-2"></i> Save Asset');
                    }
                }
            });
        }

        function deleteAsset(id) {
            Swal.fire({
                title: 'Delete Asset?',
                text: "Are you sure you want to delete this asset? This cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/AssetVendor/DeleteAsset',
                        type: 'POST',
                        data: { assetId: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => window.location.href = '/AssetVendor?activeTab=assets', 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        // --- VENDOR FUNCTIONS ---
        function openVendorModal() {
            $('#vendorForm')[0].reset();
            $('#vId').val('0');
            $('#vRating').val('0');
            $('#currentContractDiv').addClass('d-none');
            $('#vendorModalTitle').html('<i class="fa-solid fa-user-tie me-2"></i> Add Vendor');
            vendorModal.show();
        }

        function openEditVendorModal(id, name, cat, contact, phone, email, sDate, eDate, cost, status, contractPath, rating) {
            $('#vendorForm')[0].reset();
            $('#vId').val(id);
            $('#vName').val(decodeURIComponent(name));
            $('#vCategory').val(cat);
            $('#vContactPerson').val(decodeURIComponent(contact));
            $('#vPhone').val(phone);
            $('#vEmail').val(email);
            $('#vStartDate').val(sDate);
            $('#vEndDate').val(eDate);
            $('#vCost').val(cost);
            $('#vStatus').val(status);
            $('#vRating').val(rating || '0');
            
            if(contractPath && contractPath !== '') {
                $('#currentContractDiv').removeClass('d-none');
                $('#nCurrentContractLink').attr('href', contractPath);
            } else {
                $('#currentContractDiv').addClass('d-none');
            }
            
            $('#vendorModalTitle').html('<i class="fa-solid fa-pen-to-square me-2"></i> Edit Vendor');
            vendorModal.show();
        }

        function submitVendor() {
            var form = $('#vendorForm')[0];
            var formData = new FormData(form);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $('#btnSubmitVendor').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

            $.ajax({
                url: '/AssetVendor/SaveVendor',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => window.location.href = '/AssetVendor?activeTab=vendors', 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitVendor').prop('disabled', false).html('<i class="fa-solid fa-save me-2"></i> Save Vendor');
                    }
                }
            });
        }

        function deleteVendor(id) {
            Swal.fire({
                title: 'Delete Vendor?',
                text: "Are you sure? This will remove the vendor and detach them from any linked assets.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/AssetVendor/DeleteVendor',
                        type: 'POST',
                        data: { vendorId: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => window.location.href = '/AssetVendor?activeTab=vendors', 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }

        // --- SERVICE HISTORY FUNCTIONS ---
        function openServiceHistoryModal(assetId, assetName) {
            $('#serviceLogForm')[0].reset();
            $('#shAssetId').val(assetId);
            $('#shDate').val(new Date().toISOString().split('T')[0]);
            $('#shModalTitle').html('<i class="fa-solid fa-clipboard-list me-2"></i> Service History: ' + decodeURIComponent(assetName));
            
            $('#serviceLogContainer').html('<div class="text-center py-4 text-muted"><i class="fa-solid fa-spinner fa-spin fa-2x mb-2"></i><br>Loading history...</div>');
            
            serviceHistoryModal.show();
            loadServiceLogs(assetId);
        }

        function loadServiceLogs(assetId) {
            $.get('/AssetVendor/GetServiceLogs?assetId=' + assetId, function(res) {
                if(res.success) {
                    var html = '';
                    if(res.data.length === 0) {
                        html = '<div class="alert alert-light border text-center text-muted">No service records found.</div>';
                    } else {
                        html = '<div class="list-group list-group-flush">';
                        res.data.forEach(function(log) {
                            var dateObj = new Date(log.serviceDate);
                            var formattedDate = dateObj.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
                            
                            html += `<div class="list-group-item px-0 py-3 border-bottom">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-bold text-dark mb-1">${log.description}</div>
                                                <div class="small text-muted">
                                                    <i class="fa-regular fa-calendar me-1"></i> ${formattedDate}
                                                    <span class="mx-2">|</span>
                                                    <i class="fa-solid fa-screwdriver-wrench me-1"></i> ${log.vendorName || 'Internal / Other'}
                                                </div>
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-bold text-success mb-1">₹${log.cost || '0.00'}</div>
                                                <button class="btn btn-sm btn-link text-danger p-0 text-decoration-none" onclick="deleteServiceLog(${log.logId}, ${assetId})">Delete</button>
                                            </div>
                                        </div>
                                     </div>`;
                        });
                        html += '</div>';
                    }
                    $('#serviceLogContainer').html(html);
                }
            });
        }

        function submitServiceLog() {
            var formData = $('#serviceLogForm').serialize() + '&__RequestVerificationToken=' + $('input[name="__RequestVerificationToken"]').val();
            $('#btnSaveLog').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i> Saving...');

            $.ajax({
                url: '/AssetVendor/SaveServiceLog',
                type: 'POST',
                data: formData,
                success: function (res) {
                    $('#btnSaveLog').prop('disabled', false).html('<i class="fa-solid fa-plus me-1"></i> Add Log');
                    if (res.success) {
                        $('#serviceLogForm')[0].reset();
                        $('#shDate').val(new Date().toISOString().split('T')[0]);
                        loadServiceLogs($('#shAssetId').val());
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                }
            });
        }

        function deleteServiceLog(logId, assetId) {
            Swal.fire({
                title: 'Delete Record?',
                text: "This will remove the service record.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/AssetVendor/DeleteServiceLog',
                        type: 'POST',
                        data: { logId: logId, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                loadServiceLogs(assetId);
                            }
                        }
                    });
                }
            });
        }
    </script>
}
