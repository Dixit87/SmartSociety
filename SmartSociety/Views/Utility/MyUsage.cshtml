@model IEnumerable<SmartSociety.Models.UtilityBill>
@{
    ViewData["Title"] = "Utility Usage & Bills";
    var flat = ViewBag.Flat as SmartSociety.Models.Flat;
    var unpaidTotal = Model.Where(b => b.Status != "Paid").Sum(b => b.BalanceAmount);
    
    // Group consumption for Chart.js - aligned correctly by cycle to prevent dataset drift
    var sortedCycles = Model.OrderBy(b => b.BillYear).ThenBy(b => b.BillMonth)
                            .Select(b => new { b.BillYear, b.BillMonth })
                            .Distinct()
                            .ToList();

    var chartLabels = sortedCycles.Select(c => new DateTime(c.BillYear, c.BillMonth, 1).ToString("MMM yyyy")).ToList();

    var electricityData = new List<decimal>();
    var waterData = new List<decimal>();
    var gasData = new List<decimal>();

    foreach (var cycle in sortedCycles)
    {
        var elecBill = Model.FirstOrDefault(b => b.BillYear == cycle.BillYear && b.BillMonth == cycle.BillMonth && 
                                                (b.UtilityName != null && (b.UtilityName.ToLower().Contains("power") || b.UtilityName.ToLower().Contains("electricity"))));
        electricityData.Add(elecBill?.ConsumedUnits ?? 0);

        var waterBill = Model.FirstOrDefault(b => b.BillYear == cycle.BillYear && b.BillMonth == cycle.BillMonth && 
                                                 (b.UtilityName != null && b.UtilityName.ToLower().Contains("water")));
        waterData.Add(waterBill?.ConsumedUnits ?? 0);

        var gasBill = Model.FirstOrDefault(b => b.BillYear == cycle.BillYear && b.BillMonth == cycle.BillMonth && 
                                               (b.UtilityName != null && b.UtilityName.ToLower().Contains("gas")));
        gasData.Add(gasBill?.ConsumedUnits ?? 0);
    }
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Resident</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Utility Usage Tracker</li>
      </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Utility Usage & Bills</h2>
            <p class="text-muted mb-0">Track monthly utility readings (Water, Gas, Electricity) and clear pending invoices.</p>
        </div>
    </div>

    <!-- Header Stats -->
    <div class="row g-4 mb-4">
        <!-- Flat Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 d-flex align-items-center justify-content-center me-4" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-gauge-high fs-3"></i>
                    </div>
                    <div>
                        <h6 class="fw-semibold text-muted mb-1">Active Meters</h6>
                        <h4 class="fw-bold text-dark mb-1">Block @flat?.BlockName - @flat?.FlatNumber</h4>
                        <div class="small text-muted">
                            <span class="badge bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle me-1"><i class="fa-solid fa-bolt me-1"></i> Power</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle me-1"><i class="fa-solid fa-droplet me-1"></i> Water</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle"><i class="fa-solid fa-fire me-1"></i> Gas</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Utility Dues -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-4 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-3 d-flex align-items-center justify-content-center me-4" style="width: 70px; height: 70px;">
                            <i class="fa-solid fa-indian-rupee-sign fs-3"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold text-muted mb-1">Utility Invoices Pending</h6>
                            <h3 class="fw-bold text-dark mb-0">₹@unpaidTotal.ToString("N2")</h3>
                        </div>
                    </div>
                    @if (unpaidTotal > 0)
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-2 rounded-pill fs-6">Pending Dues</span>
                    }
                    else
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill fs-6">No Pending Dues</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Consumption Graph & Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-chart-line text-primary me-2"></i> Monthly Consumption Tracker</h5>
                    <div style="height: 300px; position: relative;">
                        <canvas id="utilityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bills Table -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-file-lines text-success me-2"></i> Utility Invoices</h5>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Bill ID</th>
                            <th>Billing Cycle</th>
                            <th>Utility Category</th>
                            <th>Readings (Prev | Curr)</th>
                            <th>Units Consumed</th>
                            <th>Invoice Dues</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var bill in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">#UTL-@bill.BillYear-@bill.BillMonth-@bill.BillId</td>
                                    <td class="fw-semibold text-dark">@bill.DisplayMonthYear</td>
                                    <td class="fw-semibold">
                                        @if (bill.UtilityName.ToLower().Contains("power") || bill.UtilityName.ToLower().Contains("electricity"))
                                        {
                                            <span class="text-warning"><i class="fa-solid fa-bolt me-1"></i> @bill.UtilityName</span>
                                        }
                                        else if (bill.UtilityName.ToLower().Contains("water"))
                                        {
                                            <span class="text-primary"><i class="fa-solid fa-droplet me-1"></i> @bill.UtilityName</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger"><i class="fa-solid fa-fire me-1"></i> @bill.UtilityName</span>
                                        }
                                    </td>
                                    <td class="small text-muted">@bill.PreviousReading.ToString("N1") &rarr; @bill.CurrentReading.ToString("N1")</td>
                                    <td class="fw-bold">@bill.ConsumedUnits.ToString("N1") @bill.MeasurementUnit</td>
                                    <td class="fw-bold text-dark">₹@bill.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (bill.Status == "Paid")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill">Paid</span>
                                        }
                                        else if (bill.Status == "Partial")
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning-emphasis border border-warning-subtle px-3 py-2 rounded-pill">Partial</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-3 py-2 rounded-pill">Unpaid</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        @if (bill.Status != "Paid")
                                        {
                                            <button class="btn btn-sm btn-success px-3 rounded-pill fw-semibold shadow-sm" onclick="openUtilityCheckout(@bill.BillId, @bill.BalanceAmount, '@bill.DisplayMonthYear', '@bill.UtilityName')">
                                                <i class="fa-solid fa-credit-card me-1"></i> Pay Bill
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-action="Receipt" asp-route-id="@bill.BillId" class="btn btn-sm btn-outline-secondary px-3 rounded-pill fw-semibold"><i class="fa-solid fa-file-invoice"></i> Receipt</a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">No utility bills logged for your flat.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Mock Secure Checkout Modal -->
<div class="modal fade" id="utilityCheckoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-dark text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-shield-halved me-2 text-success"></i> Secure Checkout - Utilities</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div class="card border-0 shadow-sm rounded-3 mb-4 bg-white">
                    <div class="card-body p-3 d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold text-dark mb-0" id="checkoutUtilityTitle">Water Bill</h6>
                            <small class="text-muted" id="checkoutCycleText">June 2026</small>
                        </div>
                        <div class="text-end">
                            <span class="small text-muted d-block">Payable Dues</span>
                            <h4 class="fw-bold text-success mb-0" id="checkoutAmountText">₹320.00</h4>
                        </div>
                    </div>
                </div>

                <form id="utilityCheckoutForm" onsubmit="event.preventDefault(); submitUtilityMockPayment();">
                    <input type="hidden" id="utilBillId" />
                    <input type="hidden" id="utilPayAmount" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted mb-1">Select Payment Mode</label>
                        <select id="utilPaymentMode" class="form-select bg-white border py-2" required onchange="toggleUtilFields()">
                            <option value="UPI">UPI ID / App</option>
                            <option value="Card">Debit / Credit Card</option>
                            <option value="BankTransfer">Internet Banking</option>
                        </select>
                    </div>

                    <!-- UPI -->
                    <div id="utilUpiFields" class="mb-3">
                        <label class="form-label small fw-bold text-muted mb-1">UPI Address</label>
                        <input type="text" id="utilUpiId" class="form-control bg-white" placeholder="yourname@upi" required />
                    </div>

                    <!-- Card -->
                    <div id="utilCardFields" class="mb-3 d-none">
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted mb-1">Card Number</label>
                            <input type="text" id="utilCardNum" class="form-control bg-white" placeholder="xxxx xxxx xxxx xxxx" maxlength="19" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">Expiry</label>
                                <input type="text" id="utilCardExp" class="form-control bg-white" placeholder="MM/YY" maxlength="5" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted mb-1">CVV</label>
                                <input type="password" id="utilCardCvv" class="form-control bg-white" placeholder="***" maxlength="3" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 rounded-pill shadow fw-semibold" id="btnConfirmUtilPay">
                            <i class="fa-solid fa-lock me-2"></i> Pay Securely
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var utilityCheckoutModal;

        $(document).ready(function() {
            utilityCheckoutModal = new bootstrap.Modal(document.getElementById('utilityCheckoutModal'));
            renderChart();
        });

        function openUtilityCheckout(billId, balance, displayCycle, utilityName) {
            $('#utilityCheckoutForm')[0].reset();
            $('#utilBillId').val(billId);
            $('#utilPayAmount').val(balance);
            $('#checkoutUtilityTitle').text(utilityName + ' Bill');
            $('#checkoutCycleText').text('Cycle: ' + displayCycle);
            $('#checkoutAmountText').text('₹' + balance.toFixed(2));
            toggleUtilFields();
            utilityCheckoutModal.show();
        }

        function toggleUtilFields() {
            var mode = $('#utilPaymentMode').val();
            $('#utilUpiFields').addClass('d-none');
            $('#utilCardFields').addClass('d-none');
            $('#utilUpiId').prop('required', false);
            $('#utilCardNum').prop('required', false);
            $('#utilCardExp').prop('required', false);
            $('#utilCardCvv').prop('required', false);

            if (mode === 'UPI') {
                $('#utilUpiFields').removeClass('d-none');
                $('#utilUpiId').prop('required', true);
            } else if (mode === 'Card') {
                $('#utilCardFields').removeClass('d-none');
                $('#utilCardNum').prop('required', true);
                $('#utilCardExp').prop('required', true);
                $('#utilCardCvv').prop('required', true);
            }
        }

        function submitUtilityMockPayment() {
            var billId = $('#utilBillId').val();
            var paidAmount = $('#utilPayAmount').val();
            var paymentMode = $('#utilPaymentMode').val();
            var token = $('input[name="__RequestVerificationToken"]').val();
            var transactionId = 'TXN-UTL-' + Math.random().toString(36).substring(2, 10).toUpperCase();

            $('#btnConfirmUtilPay').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Authorizing...');

            $.ajax({
                url: '/Utility/RecordPayment',
                type: 'POST',
                data: {
                    billId: billId,
                    paidAmount: paidAmount,
                    paymentMode: paymentMode,
                    transactionId: transactionId,
                    remarks: 'Paid through Resident Utility tracker',
                    __RequestVerificationToken: token
                },
                success: function (res) {
                    if (res.success) {
                        Swal.fire({
                            title: 'Utility Payment Cleared!',
                            text: 'Your payment of ₹' + parseFloat(paidAmount).toFixed(2) + ' was accepted successfully.',
                            icon: 'success',
                            confirmButtonColor: '#198754'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Failed', res.message, 'error');
                        $('#btnConfirmUtilPay').prop('disabled', false).html('<i class="fa-solid fa-lock me-2"></i> Pay Securely');
                    }
                },
                error: function() {
                    Swal.fire('Error', 'Unable to execute checkout gateway call.', 'error');
                    $('#btnConfirmUtilPay').prop('disabled', false).html('<i class="fa-solid fa-lock me-2"></i> Pay Securely');
                }
            });
        }

        function renderChart() {
            var ctx = document.getElementById('utilityChart').getContext('2d');
            
            // Labels and data generated from C# Razor code
            var labels = @Html.Raw(Json.Serialize(chartLabels));
            var electricity = @Html.Raw(Json.Serialize(electricityData));
            var water = @Html.Raw(Json.Serialize(waterData));
            var gas = @Html.Raw(Json.Serialize(gasData));

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Electricity (Units)',
                            data: electricity,
                            backgroundColor: 'rgba(255, 193, 7, 0.75)',
                            borderColor: '#ffc107',
                            borderWidth: 1,
                            borderRadius: 6
                        },
                        {
                            label: 'Water (Units)',
                            data: water,
                            backgroundColor: 'rgba(13, 110, 253, 0.75)',
                            borderColor: '#0d6efd',
                            borderWidth: 1,
                            borderRadius: 6
                        },
                        {
                            label: 'Gas (Units)',
                            data: gas,
                            backgroundColor: 'rgba(220, 53, 69, 0.75)',
                            borderColor: '#dc3545',
                            borderWidth: 1,
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                boxWidth: 12,
                                font: {
                                    family: 'Inter, sans-serif',
                                    weight: 'bold'
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
}
