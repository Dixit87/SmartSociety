@model SmartSociety.Models.UtilityReceiptViewModel

@{
    ViewData["Title"] = "Utility Bill Receipt";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receipt - @Model.Bill.UtilityName Bill #@Model.Bill.BillId - SmartSociety</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .receipt-container { max-width: 800px; margin: 40px auto; background: #fff; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-radius: 8px; position: relative; }
        .watermark { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg); font-size: 8rem; color: rgba(0, 0, 0, 0.03); z-index: 0; pointer-events: none; font-weight: bold; text-transform: uppercase; white-space: nowrap; }
        .receipt-header { border-bottom: 2px solid #0d6efd; padding-bottom: 20px; margin-bottom: 30px; position: relative; z-index: 1; }
        .company-logo { width: 60px; height: 60px; background: #0d6efd; color: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .bill-to { background: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #0d6efd; position: relative; z-index: 1; }
        .table th { background-color: #f1f5f9; color: #475569; font-weight: 600; }
        .total-row { background-color: #0d6efd; color: white; font-weight: bold; }
        .status-stamp { position: absolute; top: 40px; right: 40px; border: 4px solid #198754; color: #198754; font-size: 24px; font-weight: bold; padding: 10px 20px; border-radius: 8px; transform: rotate(15deg); opacity: 0.8; z-index: 1; text-transform: uppercase; letter-spacing: 2px; }
        .partial-stamp { border-color: #ffc107; color: #ffc107; }
        @@media print {
            body { background: white; margin: 0; padding: 0; }
            .receipt-container { margin: 0; padding: 20px; box-shadow: none; border-radius: 0; max-width: 100%; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="mb-3 mt-4 no-print text-center">
            <button onclick="window.print()" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm me-2">
                <i class="fa-solid fa-print me-2"></i> Print Receipt
            </button>
            <a href="/Utility" class="btn btn-outline-secondary px-4 py-2 rounded-pill shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Back to Utility
            </a>
        </div>

        <div class="receipt-container">
            <div class="watermark">SMART SOCIETY</div>
            
            @if(Model.Bill.Status == "Paid") {
                <div class="status-stamp">PAID</div>
            } else if (Model.Bill.Status == "Partial") {
                <div class="status-stamp partial-stamp">PARTIAL</div>
            }

            <div class="receipt-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <div class="company-logo me-3 shadow-sm">
                        <i class="fa-solid fa-building"></i>
                    </div>
                    <div>
                        <h2 class="mb-0 fw-bold text-dark">SmartSociety</h2>
                        <p class="text-muted mb-0 small">Premium Apartment Management</p>
                    </div>
                </div>
                <div class="text-end">
                    <h3 class="text-primary fw-bold mb-1">UTILITY RECEIPT</h3>
                    <p class="mb-0 fw-semibold text-secondary">Receipt #: UTL-@Model.Bill.BillId.ToString("D6")</p>
                    <p class="mb-0 small text-muted">Date: @DateTime.Now.ToString("dd MMM yyyy")</p>
                </div>
            </div>

            <div class="row mb-4 position-relative z-index-1">
                <div class="col-md-6">
                    <div class="bill-to h-100 shadow-sm">
                        <p class="text-muted small fw-bold mb-2 text-uppercase letter-spacing-1">Billed To</p>
                        <h5 class="fw-bold text-dark mb-1">@Model.Bill.OwnerName</h5>
                        <p class="mb-1 text-secondary"><i class="fa-solid fa-door-open me-2 text-muted"></i> Block @Model.Bill.BlockName, Flat @Model.Bill.FlatNumber</p>
                        @if(!string.IsNullOrEmpty(Model.Bill.OwnerPhone))
                        {
                            <p class="mb-1 text-secondary"><i class="fa-solid fa-phone me-2 text-muted"></i> @Model.Bill.OwnerPhone</p>
                        }
                        @if(!string.IsNullOrEmpty(Model.Bill.OwnerEmail))
                        {
                            <p class="mb-0 text-secondary"><i class="fa-solid fa-envelope me-2 text-muted"></i> @Model.Bill.OwnerEmail</p>
                        }
                    </div>
                </div>
                <div class="col-md-6 text-end d-flex flex-column justify-content-center">
                    <div class="p-3">
                        <p class="text-muted small fw-bold mb-1 text-uppercase letter-spacing-1">Billing Month</p>
                        <h4 class="fw-bold text-dark mb-3">@Model.Bill.DisplayMonthYear</h4>
                        <p class="text-muted small fw-bold mb-1 text-uppercase letter-spacing-1">Utility Type</p>
                        <h5 class="fw-bold text-primary mb-0"><i class="fa-solid fa-bolt me-2"></i> @Model.Bill.UtilityName</h5>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-file-invoice-dollar text-primary me-2"></i> Bill Details</h5>
            <div class="table-responsive mb-4 position-relative z-index-1">
                <table class="table table-bordered mb-0">
                    <thead>
                        <tr>
                            <th class="py-3">Description</th>
                            <th class="py-3 text-center">Reading</th>
                            <th class="py-3 text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="py-3">
                                <strong>Current Meter Reading</strong>
                            </td>
                            <td class="py-3 text-center">@Model.Bill.CurrentReading @Model.Bill.MeasurementUnit</td>
                            <td class="py-3 text-end">-</td>
                        </tr>
                        <tr>
                            <td class="py-3">
                                <strong>Previous Meter Reading</strong>
                            </td>
                            <td class="py-3 text-center">@Model.Bill.PreviousReading @Model.Bill.MeasurementUnit</td>
                            <td class="py-3 text-end">-</td>
                        </tr>
                        <tr class="bg-light">
                            <td class="py-3">
                                <strong>Total Units Consumed</strong><br/>
                                <small class="text-muted">(Current - Previous)</small>
                            </td>
                            <td class="py-3 text-center fw-bold text-primary">@Model.Bill.ConsumedUnits @Model.Bill.MeasurementUnit</td>
                            <td class="py-3 text-end">-</td>
                        </tr>
                        <tr>
                            <td class="py-3">
                                <strong>Rate per Unit</strong>
                            </td>
                            <td class="py-3 text-center">₹@Model.Bill.RatePerUnit</td>
                            <td class="py-3 text-end">-</td>
                        </tr>
                        <tr>
                            <td colspan="2" class="py-3 text-end fw-bold">Total Bill Amount:</td>
                            <td class="py-3 text-end fw-bold fs-5 text-dark">₹@Model.Bill.TotalAmount.ToString("N2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            @if (Model.Payments.Any())
            {
                <h5 class="fw-bold text-dark mb-3 mt-4"><i class="fa-solid fa-clock-rotate-left text-success me-2"></i> Payment History</h5>
                <div class="table-responsive mb-4 position-relative z-index-1">
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Mode</th>
                                <th>Txn Ref</th>
                                <th class="text-end">Amount Paid</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td>@p.PaymentDate.ToString("dd MMM yyyy hh:mm tt")</td>
                                    <td><span class="badge bg-secondary">@p.PaymentMode</span></td>
                                    <td><small class="text-muted">@(string.IsNullOrEmpty(p.TransactionId) ? "N/A" : p.TransactionId)</small></td>
                                    <td class="text-end fw-bold text-success">₹@p.PaidAmount.ToString("N2")</td>
                                </tr>
                            }
                            <tr class="table-success text-dark">
                                <td colspan="3" class="text-end fw-bold">Total Paid:</td>
                                <td class="text-end fw-bold fs-5">₹@Model.Bill.AmountPaid.ToString("N2")</td>
                            </tr>
                            @if (Model.Bill.BalanceAmount > 0)
                            {
                                <tr class="table-danger text-dark">
                                    <td colspan="3" class="text-end fw-bold">Balance Due:</td>
                                    <td class="text-end fw-bold fs-5">₹@Model.Bill.BalanceAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="row mt-5 pt-4 border-top">
                <div class="col-8">
                    <p class="small text-muted mb-1"><strong>Terms & Conditions:</strong></p>
                    <p class="small text-muted mb-0">1. This is a computer-generated receipt and does not require a physical signature.</p>
                    <p class="small text-muted mb-0">2. For any discrepancies in meter reading, please contact the society office within 7 days.</p>
                </div>
                <div class="col-4 text-center d-flex flex-column justify-content-end">
                    <div class="border-bottom border-dark mb-2 mt-4"></div>
                    <p class="fw-bold text-dark mb-0">Authorized Signatory</p>
                    <p class="small text-muted">SmartSociety Admin</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
