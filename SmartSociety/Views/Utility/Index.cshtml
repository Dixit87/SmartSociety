@model dynamic

@{
    ViewData["Title"] = "Utility Bills & Meter Readings";
    var stats = Model.Stats as SmartSociety.Models.UtilityDashboardStats;
    var bills = Model.Bills as IEnumerable<SmartSociety.Models.UtilityBill>;
    var utilityTypes = Model.UtilityTypes as IEnumerable<SmartSociety.Models.UtilityType>;
    var flats = Model.Flats as IEnumerable<SmartSociety.Models.Flat>;
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Meter & Utility Management</h2>
        <p class="text-muted mb-0">Record readings and track consumption-based utility bills.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Settings" class="btn btn-outline-secondary px-3 py-2 fw-semibold rounded-pill shadow-sm">
            <i class="fa-solid fa-gear me-1"></i> Settings
        </a>
        <button type="button" class="btn btn-primary px-4 py-2 fw-semibold rounded-pill shadow-sm" onclick="openRecordReadingModal()">
            <i class="fa-solid fa-gauge-high me-2"></i> Record New Reading
        </button>
    </div>
</div>

<!-- Dashboard Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0 opacity-75">Billed This Month</h6>
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-file-invoice fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-0">₹@stats.TotalBilledThisMonth.ToString("N0")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0 opacity-75">Collected This Month</h6>
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-wallet fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-0">₹@stats.TotalCollectedThisMonth.ToString("N0")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0 opacity-75">Pending Overall</h6>
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-clock-rotate-left fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-0">₹@stats.TotalPendingOverall.ToString("N0")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-semibold mb-0 opacity-75">Defaulters</h6>
                    <div class="bg-white bg-opacity-25 rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-users-slash fs-5"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-0">@stats.DefaultersCount</h3>
            </div>
        </div>
    </div>
</div>

<!-- Bills Table -->
<div class="card border-0 shadow-sm rounded-4 mb-5">
    <div class="card-body p-4">
        
        <div class="d-flex flex-wrap gap-3 mb-4 align-items-end bg-light p-3 rounded-3 border">
            <div>
                <label class="form-label small fw-semibold text-muted mb-1">Filter Month</label>
                <select id="filterMonth" class="form-select border-0 shadow-sm">
                    <option value="">All Months</option>
                    @for(int i=1; i<=12; i++) {
                        if(ViewBag.CurrentMonth == i) { <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option> }
                        else { <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option> }
                    }
                </select>
            </div>
            <div>
                <label class="form-label small fw-semibold text-muted mb-1">Filter Year</label>
                <select id="filterYear" class="form-select border-0 shadow-sm">
                    <option value="">All Years</option>
                    @for(int i = DateTime.Now.Year; i >= DateTime.Now.Year - 2; i--) {
                        if(ViewBag.CurrentYear == i) { <option value="@i" selected>@i</option> }
                        else { <option value="@i">@i</option> }
                    }
                </select>
            </div>
            <div class="ms-auto">
                <button class="btn btn-dark px-4 fw-semibold shadow-sm rounded-pill" onclick="filterData()"><i class="fa-solid fa-filter me-2"></i> Apply Filter</button>
            </div>
        </div>

        <table class="table table-hover align-middle border-bottom" id="billsTable">
            <thead class="table-light">
                <tr>
                    <th class="fw-semibold text-muted">Bill ID</th>
                    <th class="fw-semibold text-muted">Flat Details</th>
                    <th class="fw-semibold text-muted">Utility & Reading</th>
                    <th class="fw-semibold text-muted">Amount</th>
                    <th class="fw-semibold text-muted text-center">Status</th>
                    <th class="fw-semibold text-muted text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @if(bills != null)
                {
                    foreach (var bill in bills)
                    {
                        <tr>
                            <td class="fw-bold text-muted py-3">#@bill.BillYear-@bill.BillMonth-@bill.BillId</td>
                            <td class="py-3">
                                <div class="fw-bold text-dark mb-1">@bill.OwnerName</div>
                                <div class="small"><span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Block @bill.BlockName - @bill.FlatNumber</span></div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-primary mb-1">@bill.UtilityName</div>
                                <div class="small text-muted">
                                    Units: <strong>@bill.ConsumedUnits.ToString("N1")</strong> @bill.MeasurementUnit
                                    <br />(Prv: @bill.PreviousReading.ToString("N1") | Cur: @bill.CurrentReading.ToString("N1"))
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-dark">₹@bill.TotalAmount.ToString("N2")</div>
                                @if(bill.AmountPaid > 0)
                                {
                                    <div class="small text-success"><i class="fa-solid fa-check fa-xs me-1"></i> Paid: ₹@bill.AmountPaid.ToString("N2")</div>
                                }
                            </td>
                            <td class="text-center py-3">
                                @if (bill.Status == "Paid")
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-check-double me-1"></i> Paid</span>
                                }
                                else if (bill.Status == "Partial")
                                {
                                    <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-half-stroke me-1"></i> Partial</span>
                                }
                                else
                                {
                                    if(bill.DueDate < DateTime.Now)
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-triangle-exclamation me-1"></i> Overdue</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill"><i class="fa-solid fa-xmark me-1"></i> Unpaid</span>
                                    }
                                }
                                <div class="small text-muted mt-1" style="font-size: 0.75rem;">Due: @bill.DueDate.ToString("dd MMM")</div>
                            </td>
                            <td class="py-3 text-end">
                                <div class="btn-group shadow-sm rounded-pill">
                                    @if (bill.Status != "Paid")
                                    {
                                        <button class="btn btn-sm btn-success px-3 fw-semibold border-0" onclick="openPaymentModal(@bill.BillId, @bill.BalanceAmount, '@bill.BlockName-@bill.FlatNumber', '@bill.UtilityName')" title="Pay Bill">
                                            <i class="fa-solid fa-indian-rupee-sign"></i> Pay
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-action="Receipt" asp-route-id="@bill.BillId" class="btn btn-sm btn-outline-secondary px-3 fw-semibold border-0" title="View Receipt">
                                            <i class="fa-solid fa-file-pdf"></i> Receipt
                                        </a>
                                    }
                                    
                                    <button class="btn btn-sm btn-light px-2 border-start" onclick="openEditBillModal(@bill.BillId, @bill.PreviousReading, @bill.CurrentReading)" title="Edit Bill">
                                        <i class="fa-solid fa-pen text-primary"></i>
                                    </button>
                                    @if (bill.AmountPaid == 0)
                                    {
                                        <button class="btn btn-sm btn-light px-2 border-start text-danger" onclick="deleteBill(@bill.BillId)" title="Delete Bill">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Record Reading Modal -->
<div class="modal fade" id="readingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-gauge-high me-2"></i> Record Meter Reading</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="readingForm" onsubmit="event.preventDefault(); submitReading();">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Select Flat <span class="text-danger">*</span></label>
                            <select id="readFlatId" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Select Flat --</option>
                                @foreach(var flat in flats)
                                {
                                    <option value="@flat.FlatId">Block @flat.BlockName - @flat.FlatNumber</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Utility Type <span class="text-danger">*</span></label>
                            <select id="readUtilityId" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Select Utility --</option>
                                @foreach(var u in utilityTypes)
                                {
                                    if(u.IsActive) {
                                        <option value="@u.UtilityTypeId">@u.Name (₹@u.RatePerUnit/@u.MeasurementUnit)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Billing Month</label>
                            <select id="readMonth" class="form-select bg-light border-0 py-2" required>
                                @for(int i=1; i<=12; i++) {
                                    if(DateTime.Now.Month == i) { <option value="@i" selected>@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option> }
                                    else { <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option> }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Billing Year</label>
                            <select id="readYear" class="form-select bg-light border-0 py-2" required>
                                @for(int i = DateTime.Now.Year; i >= DateTime.Now.Year - 1; i--) {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Previous Reading (Auto-Fetched)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" id="readPrevious" class="form-control bg-light border-0" placeholder="0.00" readonly />
                                <div class="input-group-text bg-light border-0">
                                    <input class="form-check-input mt-0" type="checkbox" id="overridePrevCheck" onchange="toggleOverridePrev()" title="Override Previous Reading (First Time Setup)">
                                </div>
                            </div>
                        </div>
                        <div class="col-12 mt-4">
                            <div class="bg-primary bg-opacity-10 p-3 rounded-3 border border-primary border-opacity-25">
                                <label class="form-label fw-bold text-primary mb-1"><i class="fa-solid fa-stopwatch me-1"></i> Current Meter Reading <span class="text-danger">*</span></label>
                                <input type="number" step="0.01" id="readCurrent" class="form-control form-control-lg border-0 shadow-sm" required placeholder="Enter current reading..." />
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-semibold" id="btnSubmitReading">
                            <i class="fa-solid fa-file-invoice me-2"></i> Generate Bill
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-success text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-indian-rupee-sign me-2"></i> Record Utility Payment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="paymentForm" onsubmit="event.preventDefault(); submitPayment();">
                    <input type="hidden" id="payBillId" />
                    
                    <div class="alert alert-success bg-success bg-opacity-10 border-0 mb-4 rounded-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 text-success fw-bold" id="payFlatInfo">Flat Info</h6>
                                <div class="small text-muted" id="payUtilityInfo">Utility Info</div>
                            </div>
                            <div class="text-end">
                                <div class="small text-muted fw-semibold">Balance Due</div>
                                <h4 class="mb-0 text-success fw-bold" id="payBalanceText">₹0</h4>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Paying Amount (₹) <span class="text-danger">*</span></label>
                            <input type="number" id="payAmount" class="form-control bg-light border-0 py-2" required min="1" step="0.01" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Payment Mode <span class="text-danger">*</span></label>
                            <select id="payMode" class="form-select bg-light border-0 py-2" required>
                                <option value="Cash">Cash</option>
                                <option value="UPI">UPI</option>
                                <option value="Cheque">Cheque</option>
                                <option value="BankTransfer">Bank Transfer</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Transaction Ref / Cheque No.</label>
                            <input type="text" id="payTxnId" class="form-control bg-light border-0 py-2" placeholder="Required for UPI/Cheque/Bank Transfer" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Remarks</label>
                            <input type="text" id="payRemarks" class="form-control bg-light border-0 py-2" placeholder="Any optional remarks..." />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 rounded-pill shadow-sm fw-semibold" id="btnRecordPayment">
                            <i class="fa-solid fa-check me-2"></i> Confirm Payment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Bill Modal -->
<div class="modal fade" id="editBillModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-info text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i> Edit Reading</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="editBillForm" onsubmit="event.preventDefault(); submitEditBill();">
                    <input type="hidden" id="editBillId" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Previous Reading <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" id="editPrevious" class="form-control bg-light border-0" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Current Reading <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" id="editCurrent" class="form-control bg-light border-0" required />
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-info px-4 rounded-pill shadow-sm fw-semibold text-white" id="btnEditBill">
                            <i class="fa-solid fa-save me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        var readingModal;
        var paymentModal;
        var editModal;

        $(document).ready(function () {
            $('#billsTable').DataTable({
                "pageLength": 25,
                "ordering": false,
                "responsive": true,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search flats or owners..."
                }
            });
            
            readingModal = new bootstrap.Modal(document.getElementById('readingModal'));
            paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));
            editModal = new bootstrap.Modal(document.getElementById('editBillModal'));

            $('#readFlatId, #readUtilityId').change(function() {
                fetchPreviousReading();
            });
        });

        function filterData() {
            var m = $('#filterMonth').val();
            var y = $('#filterYear').val();
            var url = '/Utility/Index?';
            if(m) url += 'month=' + m + '&';
            if(y) url += 'year=' + y;
            window.location.href = url;
        }

        function fetchPreviousReading() {
            var flatId = $('#readFlatId').val();
            var utilityId = $('#readUtilityId').val();
            
            if(flatId && utilityId && !$('#overridePrevCheck').is(':checked')) {
                $.get('/Utility/GetPreviousReading', { flatId: flatId, utilityTypeId: utilityId }, function(res) {
                    if(res.success) {
                        $('#readPrevious').val(res.previousReading.toFixed(2));
                    }
                });
            }
        }

        function toggleOverridePrev() {
            var isChecked = $('#overridePrevCheck').is(':checked');
            $('#readPrevious').prop('readonly', !isChecked);
            if(!isChecked) {
                fetchPreviousReading();
            }
        }

        function openRecordReadingModal() {
            $('#readingForm')[0].reset();
            $('#overridePrevCheck').prop('checked', false);
            $('#readPrevious').prop('readonly', true);
            readingModal.show();
        }

        function submitReading() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var data = {
                flatId: $('#readFlatId').val(),
                utilityTypeId: $('#readUtilityId').val(),
                month: $('#readMonth').val(),
                year: $('#readYear').val(),
                currentReading: $('#readCurrent').val(),
                __RequestVerificationToken: token
            };

            if ($('#overridePrevCheck').is(':checked')) {
                data.overridePreviousReading = $('#readPrevious').val();
            }

            $('#btnSubmitReading').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Processing...');

            $.ajax({
                url: '/Utility/RecordReading',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnSubmitReading').prop('disabled', false).html('<i class="fa-solid fa-file-invoice me-2"></i> Generate Bill');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnSubmitReading').prop('disabled', false).html('<i class="fa-solid fa-file-invoice me-2"></i> Generate Bill');
                }
            });
        }

        function openPaymentModal(billId, balance, flatInfo, utilityInfo) {
            $('#paymentForm')[0].reset();
            $('#payBillId').val(billId);
            $('#payFlatInfo').text(flatInfo);
            $('#payUtilityInfo').text(utilityInfo);
            $('#payBalanceText').text('₹' + balance.toFixed(2));
            $('#payAmount').val(balance.toFixed(2));
            $('#payAmount').attr('max', balance);
            paymentModal.show();
        }

        function submitPayment() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var data = {
                billId: $('#payBillId').val(),
                paidAmount: $('#payAmount').val(),
                paymentMode: $('#payMode').val(),
                transactionId: $('#payTxnId').val(),
                remarks: $('#payRemarks').val(),
                __RequestVerificationToken: token
            };

            if ((data.paymentMode === 'UPI' || data.paymentMode === 'BankTransfer' || data.paymentMode === 'Cheque') && !data.transactionId) {
                Swal.fire('Required', 'Please enter Transaction ID or Cheque No.', 'warning');
                return;
            }

            $('#btnRecordPayment').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Processing...');

            $.ajax({
                url: '/Utility/RecordPayment',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnRecordPayment').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Confirm Payment');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An unexpected error occurred.', 'error');
                    $('#btnRecordPayment').prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i> Confirm Payment');
                }
            });
        }

        function openEditBillModal(id, prev, current) {
            $('#editBillForm')[0].reset();
            $('#editBillId').val(id);
            $('#editPrevious').val(prev.toFixed(2));
            $('#editCurrent').val(current.toFixed(2));
            editModal.show();
        }

        function submitEditBill() {
            var token = $('input[name="__RequestVerificationToken"]').val();
            var data = {
                billId: $('#editBillId').val(),
                previousReading: $('#editPrevious').val(),
                currentReading: $('#editCurrent').val(),
                __RequestVerificationToken: token
            };

            $('#btnEditBill').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

            $.ajax({
                url: '/Utility/EditBill',
                type: 'POST',
                data: data,
                success: function (res) {
                    if (res.success) {
                        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        Swal.fire('Error', res.message, 'error');
                        $('#btnEditBill').prop('disabled', false).html('<i class="fa-solid fa-save me-2"></i> Save Changes');
                    }
                }
            });
        }

        function deleteBill(id) {
            Swal.fire({
                title: 'Delete Bill?',
                text: "Are you sure you want to delete this bill? This cannot be undone.",
                icon: 'error',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Yes, delete it'
            }).then((result) => {
                if (result.isConfirmed) {
                    var token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '/Utility/DeleteBill',
                        type: 'POST',
                        data: { billId: id, __RequestVerificationToken: token },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}
