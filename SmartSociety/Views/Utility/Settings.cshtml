@model IEnumerable<SmartSociety.Models.UtilityType>

@{
    ViewData["Title"] = "Utility Settings";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<nav aria-label="breadcrumb">
  <ol class="breadcrumb mb-2">
    <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Utility Management</a></li>
    <li class="breadcrumb-item active fw-bold" aria-current="page">Utility Types</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Utility Types Configuration</h2>
        <p class="text-muted mb-0">Manage measurement units and rates for metered utilities.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-semibold me-2"><i class="fa-solid fa-arrow-left me-1"></i> Back</a>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold" onclick="openUtilityModal()">
            <i class="fa-solid fa-plus me-1"></i> Add Utility Type
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <i class="fa-solid fa-circle-xmark me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle border-bottom" id="utilityTypesTable">
                <thead class="table-light">
                    <tr>
                        <th class="fw-semibold text-muted">Utility Name</th>
                        <th class="fw-semibold text-muted">Measurement Unit</th>
                        <th class="fw-semibold text-muted">Rate Per Unit (₹)</th>
                        <th class="fw-semibold text-muted text-center">Status</th>
                        <th class="fw-semibold text-muted text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">
                                @if (item.Name.Contains("Gas", StringComparison.OrdinalIgnoreCase))
                                {
                                    <i class="fa-solid fa-fire-flame-simple text-danger me-2"></i>
                                }
                                else if (item.Name.Contains("Electric", StringComparison.OrdinalIgnoreCase))
                                {
                                    <i class="fa-solid fa-bolt text-warning me-2"></i>
                                }
                                else if (item.Name.Contains("Water", StringComparison.OrdinalIgnoreCase))
                                {
                                    <i class="fa-solid fa-droplet text-info me-2"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-gauge-high text-secondary me-2"></i>
                                }
                                @item.Name
                            </td>
                            <td><span class="badge bg-light text-dark border px-3 py-2">@item.MeasurementUnit</span></td>
                            <td class="fw-semibold text-success">₹@item.RatePerUnit.ToString("N2")</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-1">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-light text-primary me-2 shadow-sm rounded-pill px-3" onclick="openUtilityModal(@item.UtilityTypeId, '@item.Name', @item.RatePerUnit, '@item.MeasurementUnit', @item.IsActive.ToString().ToLower())">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                <form asp-action="DeleteUtilityType" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this utility type?');">
                                    <input type="hidden" name="id" value="@item.UtilityTypeId" />
                                    <button type="submit" class="btn btn-sm btn-light text-danger shadow-sm rounded-pill px-3">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="utilityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="modalTitle"><i class="fa-solid fa-gauge me-2"></i> Add Utility Type</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="SaveUtilityType" method="post">
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" name="UtilityTypeId" id="UtilityTypeId" value="0" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted small">Utility Name</label>
                        <input type="text" name="Name" id="Name" class="form-control bg-light border-0 py-2" required placeholder="e.g. Backup Electricity" />
                    </div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Measurement Unit</label>
                            <input type="text" name="MeasurementUnit" id="MeasurementUnit" class="form-control bg-light border-0 py-2" required placeholder="e.g. kWh, m³, Ltr" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold text-muted small">Rate Per Unit (₹)</label>
                            <input type="number" step="0.01" name="RatePerUnit" id="RatePerUnit" class="form-control bg-light border-0 py-2" required placeholder="e.g. 10.50" />
                        </div>
                    </div>
                    
                    <div class="mb-3 form-check form-switch mt-4">
                        <input class="form-check-input" type="checkbox" role="switch" name="IsActive" id="IsActive" value="true" checked>
                        <label class="form-check-label fw-semibold text-dark" for="IsActive">Active (Available for billing)</label>
                    </div>
                </div>
                <div class="modal-footer border-top bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm"><i class="fa-solid fa-save me-1"></i> Save Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        var utilityModal;
        $(document).ready(function() {
            utilityModal = new bootstrap.Modal(document.getElementById('utilityModal'));
            $('#utilityTypesTable').DataTable({
                "pageLength": 10,
                "ordering": false,
                "language": {
                    "search": "_INPUT_",
                    "searchPlaceholder": "Search utilities..."
                }
            });
        });

        function openUtilityModal(id = 0, name = '', rate = '', unit = '', isActive = true) {
            $('#UtilityTypeId').val(id);
            $('#Name').val(name);
            $('#RatePerUnit').val(rate);
            $('#MeasurementUnit').val(unit);
            $('#IsActive').prop('checked', isActive);
            
            if (id === 0) {
                $('#modalTitle').html('<i class="fa-solid fa-gauge me-2"></i> Add Utility Type');
            } else {
                $('#modalTitle').html('<i class="fa-solid fa-pen me-2"></i> Edit Utility Type');
            }
            
            utilityModal.show();
        }
    </script>
}
