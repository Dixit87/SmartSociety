@model IEnumerable<SmartSociety.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

@functions {
    public string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return dt.ToString("dd MMM yyyy");
    }

    public string GetCategoryIcon(string category)
    {
        return category.ToLower() switch
        {
            "maintenance" => "fa-credit-card text-success",
            "visitor" => "fa-car-side text-primary",
            "complaint" => "fa-headset text-danger",
            "notice" => "fa-bullhorn text-warning",
            _ => "fa-bell text-secondary"
        };
    }

    public string GetCategoryBadgeClass(string category)
    {
        return category.ToLower() switch
        {
            "maintenance" => "bg-success-subtle text-success border border-success-subtle",
            "visitor" => "bg-primary-subtle text-primary border border-primary-subtle",
            "complaint" => "bg-danger-subtle text-danger border border-danger-subtle",
            "notice" => "bg-warning-subtle text-warning border border-warning-subtle",
            _ => "bg-secondary-subtle text-secondary border border-secondary-subtle"
        };
    }
}

<div class="container-fluid py-4">
    <!-- Header Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
        <div class="card-body p-4 text-white">
            <div class="d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h2 class="fw-bold mb-1"><i class="fa-solid fa-bell me-2"></i> Notifications Center</h2>
                    <p class="mb-0 opacity-75">Stay updated with the latest society announcements, bills, and visitor entries.</p>
                </div>
                <div class="mt-3 mt-md-0 d-flex gap-2">
                    @if (ViewBag.UnreadCount > 0)
                    {
                        <button id="btnMarkAllRead" class="btn btn-light text-primary fw-bold rounded-pill px-4 shadow-sm transition-all hover-scale">
                            <i class="fa-solid fa-check-double me-1"></i> Mark All as Read
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Stats & Filters Row -->
    <div class="row mb-4 align-items-center">
        <div class="col-lg-8 mb-3 mb-lg-0">
            <!-- Category Filter Pills -->
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" asp-route-category="All" class="btn rounded-pill px-3 py-2 fw-medium border-0 @(ViewBag.CurrentCategory == "All" ? "btn-primary shadow" : "btn-white text-secondary shadow-sm")">
                    All <span class="badge rounded-pill bg-dark-subtle text-dark ms-1">@ViewBag.TotalCount</span>
                </a>
                <a asp-action="Index" asp-route-category="Maintenance" class="btn rounded-pill px-3 py-2 fw-medium border-0 @(ViewBag.CurrentCategory == "Maintenance" ? "btn-success text-white shadow" : "btn-white text-secondary shadow-sm")">
                    Maintenance
                </a>
                <a asp-action="Index" asp-route-category="Visitor" class="btn rounded-pill px-3 py-2 fw-medium border-0 @(ViewBag.CurrentCategory == "Visitor" ? "btn-primary shadow" : "btn-white text-secondary shadow-sm")">
                    Visitors
                </a>
                <a asp-action="Index" asp-route-category="Complaint" class="btn rounded-pill px-3 py-2 fw-medium border-0 @(ViewBag.CurrentCategory == "Complaint" ? "btn-danger text-white shadow" : "btn-white text-secondary shadow-sm")">
                    Complaints
                </a>
                <a asp-action="Index" asp-route-category="Notice" class="btn rounded-pill px-3 py-2 fw-medium border-0 @(ViewBag.CurrentCategory == "Notice" ? "btn-warning text-dark shadow" : "btn-white text-secondary shadow-sm")">
                    Notices
                </a>
            </div>
        </div>
        <div class="col-lg-4 text-lg-end">
            <span class="text-secondary small">
                Unread: <strong class="text-primary" id="unread-count-text">@ViewBag.UnreadCount</strong> / Total: <strong>@ViewBag.TotalCount</strong>
            </span>
        </div>
    </div>

    <!-- Notification Feed Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="list-group list-group-flush" id="notification-list">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <div class="bg-light rounded-circle d-inline-flex p-4 mb-3">
                        <i class="fa-solid fa-bell-slash text-secondary fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">No notifications found</h5>
                    <p class="text-muted">You are all caught up!</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="list-group-item p-4 border-bottom transition-all notification-card @(item.IsRead ? "bg-white opacity-85" : "bg-primary-subtle bg-opacity-10 border-start border-primary border-4")" data-id="@item.NotificationId" style="border-left-width: @(item.IsRead ? "0" : "4px") !important;">
                        <div class="d-flex align-items-start">
                            <!-- Icon and Status dot -->
                            <div class="position-relative me-3">
                                <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 52px; height: 52px;">
                                    <i class="fa-solid @GetCategoryIcon(item.Category) fs-5"></i>
                                </div>
                                @if (!item.IsRead)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle p-2 bg-primary border border-light rounded-circle unread-dot shadow-sm" title="Unread"></span>
                                }
                            </div>

                            <!-- Body details -->
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-1">
                                    <div>
                                        <h6 class="mb-0 fw-bold text-dark @(item.IsRead ? "text-opacity-75" : "")">@item.Title</h6>
                                        <span class="badge rounded-pill @GetCategoryBadgeClass(item.Category) mt-1 px-2.5 py-1 text-xs uppercase font-semibold tracking-wider">
                                            @item.Category
                                        </span>
                                    </div>
                                    <span class="text-secondary small d-flex align-items-center">
                                        <i class="fa-regular fa-clock me-1"></i> @GetTimeAgo(item.CreatedAt)
                                    </span>
                                </div>
                                <p class="mb-0 text-secondary @(item.IsRead ? "text-opacity-75" : "text-dark") mt-2" style="font-size: 0.95rem; line-height: 1.5;">
                                    @item.Message
                                </p>
                            </div>

                            <!-- Quick Action Buttons -->
                            <div class="ms-3 d-flex align-items-center gap-1">
                                @if (!item.IsRead)
                                {
                                    <button class="btn btn-icon btn-light rounded-circle hover-scale mark-read-btn" data-id="@item.NotificationId" title="Mark as read">
                                        <i class="fa-solid fa-check text-success"></i>
                                    </button>
                                }
                                <button class="btn btn-icon btn-light text-danger rounded-circle hover-scale delete-btn" data-id="@item.NotificationId" title="Delete notification">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Anti-Forgery Token
            const token = $('input[name="__RequestVerificationToken"]').val();

            // Setup AJAX default header for anti-forgery
            $.ajaxSetup({
                headers: {
                    'RequestVerificationToken': token
                }
            });

            // Mark single notification as read
            $('#notification-list').on('click', '.mark-read-btn', function () {
                const btn = $(this);
                const notificationId = btn.data('id');
                const card = btn.closest('.notification-card');

                $.post('/Notification/MarkAsRead', { id: notificationId }, function (response) {
                    if (response.success) {
                        // Update UI classes
                        card.removeClass('bg-primary-subtle bg-opacity-10 border-start border-primary border-4');
                        card.addClass('bg-white opacity-85');
                        card.css('border-left-width', '0');
                        card.find('.unread-dot').fadeOut(300, function() { $(this).remove(); });
                        btn.fadeOut(300, function() { $(this).remove(); });

                        // Update badges
                        updateBadgeCounts();
                    } else {
                        alert(response.message);
                    }
                });
            });

            // Delete notification
            $('#notification-list').on('click', '.delete-btn', function () {
                if (confirm('Are you sure you want to delete this notification?')) {
                    const btn = $(this);
                    const notificationId = btn.data('id');
                    const card = btn.closest('.notification-card');

                    $.post('/Notification/Delete', { id: notificationId }, function (response) {
                        if (response.success) {
                            card.fadeOut(400, function () {
                                $(this).remove();
                                if ($('#notification-list .notification-card').length === 0) {
                                    location.reload();
                                } else {
                                    updateBadgeCounts();
                                }
                            });
                        } else {
                            alert(response.message);
                        }
                    });
                }
            });

            // Mark all notifications as read
            $('#btnMarkAllRead').click(function () {
                $.post('/Notification/MarkAllAsRead', {}, function (response) {
                    if (response.success) {
                        $('.notification-card').each(function () {
                            const card = $(this);
                            card.removeClass('bg-primary-subtle bg-opacity-10 border-start border-primary border-4');
                            card.addClass('bg-white opacity-85');
                            card.css('border-left-width', '0');
                            card.find('.unread-dot').remove();
                            card.find('.mark-read-btn').remove();
                        });
                        $('#btnMarkAllRead').fadeOut(300);
                        updateBadgeCounts();
                    } else {
                        alert(response.message);
                    }
                });
            });

            // Update sidebar & header counts
            function updateBadgeCounts() {
                $.get('/Notification/GetUnreadCount', function (response) {
                    if (response.success) {
                        $('#unread-count-text').text(response.count);
                        
                        // Sidebar badge update
                        const badge = $('#sidebar-notification-badge');
                        if (response.count > 0) {
                            badge.text(response.count).fadeIn();
                        } else {
                            badge.fadeOut();
                        }
                    }
                });
            }
        });
    </script>
    <style>
        .transition-all {
            transition: all 0.25s ease-in-out;
        }
        .hover-scale:hover {
            transform: scale(1.08);
        }
        .btn-icon {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }
        .bg-primary-subtle {
            background-color: rgba(37, 99, 235, 0.1) !important;
        }
        .opacity-85 {
            opacity: 0.85;
        }
    </style>
}

@Html.AntiForgeryToken()
