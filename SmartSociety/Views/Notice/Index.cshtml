@model IEnumerable<SmartSociety.Models.Notice>

@{
ViewData["Title"] = "Notice Board";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
<style>
    .notice-card {
    transition: transform 0.2s, box-shadow 0.2s;
}
.notice-card:hover {
transform: translateY(-5px);
box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
}
.note-editor .note-toolbar {
background-color: #f8f9fa;
border-bottom: 1px solid #e9ecef;
}
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none"><i class="fa-solid fa-house"></i> Home</a></li>
        <li class="breadcrumb-item text-muted">Admin</li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Notice Board</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1 text-dark"><i class="fa-solid fa-bullhorn text-warning me-2"></i> Notice Board</h2>
        <p class="text-muted mb-0">Publish and manage society announcements, rules, and circulars.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm" onclick="openNoticeModal()">
            <i class="fa-solid fa-plus me-2"></i> Publish Notice
        </button>
    </div>
</div>

<!-- Dashboard Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="bg-primary bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-file-lines fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Total Notices</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.TotalNotices</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-success bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-success text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-circle-check fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Active Notices</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.ActiveNotices</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-warning bg-opacity-10 rounded-4 p-3 border-0 shadow-sm d-flex align-items-center h-100">
            <div class="bg-warning text-dark rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-thumbtack fa-lg"></i>
            </div>
            <div>
                <p class="text-muted small fw-bold mb-0 text-uppercase">Pinned Notices</p>
                <h3 class="fw-bold text-dark mb-0">@ViewBag.PinnedNotices</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3 flex-wrap gap-3">
            <div class="d-flex gap-2">
                <a href="#" onclick="applyFilters(null)" class="btn @(string.IsNullOrEmpty(ViewBag.CurrentStatus) ? "btn-dark shadow-sm" : "btn-light") rounded-pill px-4 fw-semibold">All Notices</a>
                <a href="#" onclick="applyFilters('Active')" class="btn @(ViewBag.CurrentStatus == "Active" ? "btn-dark shadow-sm" : "btn-light") rounded-pill px-4 fw-semibold">Active</a>
                <a href="#" onclick="applyFilters('Draft')" class="btn @(ViewBag.CurrentStatus == "Draft" ? "btn-dark shadow-sm" : "btn-light") rounded-pill px-4 fw-semibold">Drafts</a>
                <a href="#" onclick="applyFilters('Expired')" class="btn @(ViewBag.CurrentStatus == "Expired" ? "btn-dark shadow-sm" : "btn-light") rounded-pill px-4 fw-semibold">Expired</a>
            </div>

            <div class="d-flex gap-2 align-items-center">
                <select id="filterCategory" class="form-select border-0 shadow-sm bg-light" style="width: 180px;">
                    <option value="">All Categories</option>
                    <option value="General" selected="@(ViewBag.CurrentCategory == "General")">General</option>
                    <option value="Urgent" selected="@(ViewBag.CurrentCategory == "Urgent")">Urgent</option>
                    <option value="Maintenance" selected="@(ViewBag.CurrentCategory == "Maintenance")">Maintenance</option>
                    <option value="Event" selected="@(ViewBag.CurrentCategory == "Event")">Event</option>
                    <option value="Rules" selected="@(ViewBag.CurrentCategory == "Rules")">Rules & Guidelines</option>
                </select>
                <button class="btn btn-outline-dark fw-semibold shadow-sm" onclick="applyFilters('@ViewBag.CurrentStatus')"><i class="fa-solid fa-filter"></i></button>
            </div>
        </div>

        <table class="table table-hover align-middle w-100" id="noticesTable">
            <thead class="table-light">
                <tr>
                    <th class="fw-semibold text-muted py-3">Notice</th>
                    <th class="fw-semibold text-muted py-3">Category</th>
                    <th class="fw-semibold text-muted py-3">Audience</th>
                    <th class="fw-semibold text-muted py-3">Validity</th>
                    <th class="fw-semibold text-muted py-3">Status</th>
                    <th class="fw-semibold text-muted py-3 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var n in Model)
                    {
                        <tr>
                            <td class="py-3" style="max-width: 300px;">
                                <div class="d-flex align-items-start">
                                    @if (n.IsPinned)
                                    {
                                        <i class="fa-solid fa-thumbtack text-warning mt-1 me-2" title="Pinned to top"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-file-lines text-muted mt-1 me-2"></i>
                                    }
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0 text-truncate" title="@n.Title" style="max-width: 250px;">@n.Title</h6>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                @{
                                var catBadge = "bg-secondary";
                                if(n.Category == "Urgent") catBadge = "bg-danger";
                                else if(n.Category == "Maintenance") catBadge = "bg-warning text-dark";
                                else if(n.Category == "Event") catBadge = "bg-success";
                                else if(n.Category == "General") catBadge = "bg-info text-dark";
                            }
                            <span class="badge @catBadge rounded-pill px-3 py-2">@n.Category</span>
                        </td>
                        <td class="py-3 text-dark fw-semibold">
                            <i class="fa-solid fa-users me-1 text-muted"></i> @n.TargetAudience
                        </td>
                        <td class="py-3">
                            <div class="small text-dark fw-semibold"><i class="fa-regular fa-calendar-check text-success me-1"></i> @n.ValidFrom.ToString("dd MMM yyyy")</div>
                            @if (n.ValidTill.HasValue)
                            {
                                <div class="small text-muted mt-1"><i class="fa-regular fa-calendar-xmark text-danger me-1"></i> @n.ValidTill.Value.ToString("dd MMM yyyy")</div>
                            }
                            else
                            {
                                <div class="small text-muted mt-1"><i class="fa-solid fa-infinity text-primary me-1"></i> No Expiry</div>
                            }
                        </td>
                        <td class="py-3">
                            @if (n.Status == "Active")
                            {
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-check me-1"></i> Active</span>
                            }
                            else if (n.Status == "Draft")
                            {
                                <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill"><i class="fa-solid fa-pen-ruler me-1"></i> Draft</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill"><i class="fa-solid fa-clock-rotate-left me-1"></i> Expired</span>
                            }
                        </td>
                        <td class="py-3 text-end">
                            <div class="btn-group shadow-sm">
                                <button type="button" class="btn btn-light btn-sm text-info" title="View Details"
                                onclick="viewNotice(@n.NoticeId, '@Uri.EscapeDataString(n.Title)', '@Uri.EscapeDataString(n.Description)', '@n.Category', '@n.TargetAudience', '@n.ValidFrom.ToString("dd MMM yyyy")', '@(n.ValidTill.HasValue ? n.ValidTill.Value.ToString("dd MMM yyyy") : "No Expiry")', '@(n.AttachmentPath ?? "")', '@n.Status')">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                            <button type="button" class="btn btn-light btn-sm text-primary" title="Edit Notice"
                            onclick="openEditModal(@n.NoticeId, '@Uri.EscapeDataString(n.Title)', '@Uri.EscapeDataString(n.Description)', '@n.Category', '@n.TargetAudience', '@n.ValidFrom.ToString("yyyy-MM-dd")', '@(n.ValidTill.HasValue ? n.ValidTill.Value.ToString("yyyy-MM-dd") : "")', '@n.Status', @n.IsPinned.ToString().ToLower(), '@(n.AttachmentPath ?? "")')">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <button type="button" class="btn btn-light btn-sm @(n.IsPinned ? "text-secondary" : "text-warning")" title="@(n.IsPinned ? "Unpin Notice" : "Pin to Top")"
                        onclick="togglePin(@n.NoticeId, @((!n.IsPinned).ToString().ToLower()))">
                        <i class="fa-solid fa-thumbtack"></i>
                    </button>
                    <button type="button" class="btn btn-light btn-sm text-danger" title="Delete Notice"
                    onclick="deleteNotice(@n.NoticeId)">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </div>
        </td>
    </tr>
}
}
</tbody>
</table>
</div>
</div>

<!-- Add/Edit Notice Modal -->
<div class="modal fade" id="noticeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom bg-primary text-white rounded-top-4 pb-3">
                <h5 class="modal-title fw-bold" id="noticeModalTitle"><i class="fa-solid fa-bullhorn me-2"></i> Publish Notice</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white">
                <form id="noticeForm" onsubmit="event.preventDefault(); submitNotice();" enctype="multipart/form-data">
                    <input type="hidden" id="nId" name="noticeId" value="0" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Notice Title <span class="text-danger">*</span></label>
                            <input type="text" id="nTitle" name="title" class="form-control bg-light border-0 py-2 fs-5 fw-semibold" required placeholder="Main subject of the notice" maxlength="200" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted mb-1">Description <span class="text-danger">*</span></label>
                            <textarea id="nDescription" name="description" class="form-control bg-light border-0" required></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Category <span class="text-danger">*</span></label>
                            <select id="nCategory" name="category" class="form-select bg-light border-0 py-2" required>
                                <option value="">-- Select Category --</option>
                                <option value="General">General Information</option>
                                <option value="Urgent">Urgent / Emergency</option>
                                <option value="Maintenance">Maintenance & Outages</option>
                                <option value="Event">Society Events</option>
                                <option value="Rules">Rules & Guidelines</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Target Audience <span class="text-danger">*</span></label>
                            <select id="nAudience" name="targetAudience" class="form-select bg-light border-0 py-2" required>
                                <option value="All Residents">All Residents</option>
                                <option value="Owners Only">Owners Only</option>
                                <option value="Tenants Only">Tenants Only</option>
                                <option value="Staff & Guards">Staff & Guards</option>
                                <option value="Committee Members">Committee Members</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Valid From Date <span class="text-danger">*</span></label>
                            <input type="date" id="nValidFrom" name="validFrom" class="form-control bg-light border-0 py-2" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted mb-1">Valid Till Date (Optional)</label>
                            <input type="date" id="nValidTill" name="validTill" class="form-control bg-light border-0 py-2" />
                            <small class="text-muted">Leave empty if notice never expires.</small>
                        </div>

                        <div class="col-12 border-top pt-3 mt-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Attachment (PDF/Image) - Optional</label>
                            <input type="file" id="nAttachment" name="attachmentFile" class="form-control bg-light border-0 py-2" accept=".pdf,image/*" />
                            <div id="currentAttachmentDiv" class="mt-2 d-none">
                                <span class="badge bg-info-subtle text-info-emphasis p-2">
                                    <i class="fa-solid fa-paperclip me-1"></i> Current File Attached
                                    <a href="#" id="nCurrentAttachmentLink" target="_blank" class="ms-2 fw-bold text-decoration-none">View</a>
                                </span>
                            </div>
                        </div>

                        <div class="col-md-6 mt-4">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="nIsPinned" name="isPinned" value="true">
                                <label class="form-check-label fw-semibold text-dark" for="nIsPinned">Pin to Top of Board</label>
                            </div>
                        </div>
                        <div class="col-md-6 mt-3">
                            <label class="form-label fw-semibold small text-muted mb-1">Status</label>
                            <select id="nStatus" name="status" class="form-select bg-light border-0 py-2">
                                <option value="Active">Publish Now (Active)</option>
                                <option value="Draft">Save as Draft</option>
                            </select>
                        </div>

                        <div class="col-12 mt-3 bg-primary bg-opacity-10 p-3 rounded-3 border-0">
                            <div class="form-check form-switch d-flex align-items-center">
                                <input class="form-check-input me-3 mt-0" type="checkbox" id="nNotify" name="notifyAudience" value="true" checked style="transform: scale(1.3);">
                                <div>
                                    <label class="form-check-label fw-bold text-dark mb-0" for="nNotify"><i class="fa-solid fa-bell text-warning me-1"></i> Send Email & Push Notification</label>
                                    <div class="small text-muted mt-1">Residents in the target audience will be notified immediately upon publishing.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light px-4 rounded-pill fw-semibold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold" id="btnSubmitNotice">
                            <i class="fa-solid fa-paper-plane me-2"></i> Save Notice
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- View Notice Modal -->
<div class="modal fade" id="viewNoticeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header border-bottom-0 pb-0 pt-4 px-4 justify-content-between align-items-start">
                <div>
                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-2" id="vCategory">Category</span>
                    <h3 class="fw-bold text-dark mb-1" id="vTitle">Notice Title</h3>
                    <p class="text-muted small fw-semibold"><i class="fa-solid fa-users me-1"></i> Target: <span id="vAudience"></span></p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-white" id="printableNoticeArea">
                <div class="text-center d-none" id="printHeader" style="margin-bottom: 30px;">
                    <h2 style="font-weight: bold; margin-bottom: 5px;">SMART SOCIETY</h2>
                    <p style="color: #666; margin-bottom: 20px;">Official Notice & Circular</p>
                    <hr style="border-top: 2px solid #000; margin-bottom: 20px;" />
                    <h3 style="font-weight: bold;" id="pTitle"></h3>
                    <p style="text-align: right; color: #555;"><strong>Date:</strong> <span id="pDate"></span></p>
                </div>

                <div class="bg-light p-4 rounded-4 mb-4" id="vDescriptionContainer">
                    <div class="text-dark" id="vDescription" style="font-size: 1.05rem; line-height: 1.6;"></div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100">
                            <h6 class="fw-bold text-muted small text-uppercase mb-2">Validity Period</h6>
                            <div class="d-flex align-items-center">
                                <i class="fa-regular fa-calendar-check text-success fs-4 me-3"></i>
                                <div>
                                    <div class="fw-semibold text-dark">From: <span id="vValidFrom"></span></div>
                                    <div class="text-muted small">Till: <span id="vValidTill"></span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100 d-flex flex-column justify-content-center">
                            <h6 class="fw-bold text-muted small text-uppercase mb-2">Attachment</h6>
                            <div id="vAttachmentContainer">
                                <p class="text-muted small fst-italic mb-0">No attachment</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0 justify-content-center pb-4 pt-3 gap-2">
                <button type="button" class="btn btn-outline-dark rounded-pill px-4 fw-semibold shadow-sm" onclick="printNotice()"><i class="fa-solid fa-print me-2"></i> Print Notice</button>
                <button type="button" class="btn btn-secondary rounded-pill px-5 fw-semibold shadow-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

<script>
    var noticeModal, viewNoticeModal;

    $(document).ready(function () {
    $('#noticesTable').DataTable({
    "pageLength": 10,
    "ordering": false,
    "language": {
    "search": "",
    "searchPlaceholder": "Search notices..."
    },
    "dom": "<'row mb-3'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6 d-flex justify-content-end'f>>" +
    "<'row'<'col-sm-12'tr>>" +
    "<'row mt-3'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7 d-flex justify-content-end'p>>"
    });
    $('.dataTables_filter input').addClass('form-control form-control-sm border-0 shadow-sm bg-light').css('width', '250px');

    $('#nDescription').summernote({
    placeholder: 'Write the complete notice details here...',
    tabsize: 2,
    height: 250,
    toolbar: [
    ['style', ['style']],
    ['font', ['bold', 'italic', 'underline', 'clear']],
    ['color', ['color']],
    ['para', ['ul', 'ol', 'paragraph']],
    ['insert', ['link']],
    ['view', ['fullscreen']]
    ]
    });

    noticeModal = new bootstrap.Modal(document.getElementById('noticeModal'));
    viewNoticeModal = new bootstrap.Modal(document.getElementById('viewNoticeModal'));
    });

    function applyFilters(status) {
    var url = '/Notice?';
    if (status) {
    url += 'status=' + status + '&';
}
var cat = $('#filterCategory').val();
if (cat) url += 'category=' + cat + '&';

window.location.href = url;
}

function openNoticeModal() {
$('#noticeForm')[0].reset();
$('#nDescription').summernote('code', '');
$('#nId').val('0');
$('#nValidFrom').val(new Date().toISOString().split('T')[0]);
$('#nIsPinned').prop('checked', false);
$('#currentAttachmentDiv').addClass('d-none');
$('#noticeModalTitle').html('<i class="fa-solid fa-bullhorn me-2"></i> Publish Notice');
noticeModal.show();
}

function openEditModal(id, title, desc, cat, audience, validFrom, validTill, status, isPinned, attachment) {
$('#noticeForm')[0].reset();
$('#nId').val(id);
$('#nTitle').val(decodeURIComponent(title));
$('#nDescription').summernote('code', decodeURIComponent(desc));
$('#nCategory').val(cat);
$('#nAudience').val(audience);
$('#nValidFrom').val(validFrom);
$('#nValidTill').val(validTill);
$('#nStatus').val(status);
$('#nIsPinned').prop('checked', isPinned);

if(attachment && attachment !== '') {
$('#currentAttachmentDiv').removeClass('d-none');
$('#nCurrentAttachmentLink').attr('href', attachment);
}
else
{
    $('#currentAttachmentDiv').addClass('d-none');
}

$('#noticeModalTitle').html('<i class="fa-solid fa-pen-to-square me-2"></i> Edit Notice');
noticeModal.show();
}

function viewNotice(id, title, desc, cat, audience, validFrom, validTill, attachment, status) {
var decodedTitle = decodeURIComponent(title);
$('#vTitle').text(decodedTitle);
$('#pTitle').text(decodedTitle);
$('#pDate').text(validFrom);
$('#vDescription').html(decodeURIComponent(desc));
$('#vCategory').text(cat);
$('#vAudience').text(audience);
$('#vValidFrom').text(validFrom);
$('#vValidTill').text(validTill);

if(attachment && attachment !== '') {
$('#vAttachmentContainer').html('<a href="' + attachment + '" target="_blank" class="btn btn-outline-primary btn-sm rounded-pill fw-semibold"><i class="fa-solid fa-download me-1"></i> Download File</a>');
}
else
{
    $('#vAttachmentContainer').html('<p class="text-muted small fst-italic mb-0">No attachment provided</p>');
}

viewNoticeModal.show();
}

function submitNotice() {
var form = $('#noticeForm')[0];
var formData = new FormData(form);

if (!$('#nIsPinned').is(':checked')) formData.append('isPinned', 'false');

formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

$('#btnSubmitNotice').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-2"></i> Saving...');

$.ajax({
url: '/Notice/SaveNotice',
type: 'POST',
data: formData,
processData: false,
contentType: false,
success: function (res) {
if (res.success) {
Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
setTimeout(() => location.reload(), 1500);
}
else
{
    Swal.fire('Error', res.message, 'error');
    $('#btnSubmitNotice').prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-2"></i> Save Notice');
}
}
});
}

function deleteNotice(id) {
Swal.fire({
title: 'Delete Notice?',
text: "Are you sure you want to delete this notice? This action cannot be undone.",
icon: 'warning',
showCancelButton: true,
confirmButtonColor: '#d33',
cancelButtonColor: '#3085d6',
confirmButtonText: 'Yes, delete it!'
}).then((result) => {
if (result.isConfirmed) {
var token = $('input[name="__RequestVerificationToken"]').val();
$.ajax({
url: '/Notice/DeleteNotice',
type: 'POST',
data: { noticeId: id, __RequestVerificationToken: token },
success: function (res) {
if (res.success) {
Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
setTimeout(() => location.reload(), 1500);
}
else
{
    Swal.fire('Error', res.message, 'error');
}
}
});
}
});
}

function togglePin(id, pin) {
var token = $('input[name="__RequestVerificationToken"]').val();
$.ajax({
url: '/Notice/TogglePin',
type: 'POST',
data: { noticeId: id, isPinned: pin, __RequestVerificationToken: token },
success: function (res) {
if (res.success) {
Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: res.message, showConfirmButton: false, timer: 2000 });
setTimeout(() => location.reload(), 1500);
}
else
{
    Swal.fire('Error', res.message, 'error');
}
}
});
}

function printNotice() {
var printContents = document.getElementById('printableNoticeArea').innerHTML;
var originalContents = document.body.innerHTML;

// Prepare for print
document.body.innerHTML = printContents;
$('#printHeader').removeClass('d-none');
$('#vDescriptionContainer').removeClass('bg-light p-4 rounded-4');

window.print();

// Restore
document.body.innerHTML = originalContents;
window.location.reload(); // Reload to restore event listeners
}
</script>
}